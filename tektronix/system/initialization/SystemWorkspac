llsOn:	(TextConstants associationAt: #Centered)Smalltalk browseAllCallsOn:	(Object classPool			associationAt: #DependentsFields).Smalltalk browseAllSelect:	[:meth | meth numLiterals > 40].FileStream instanceCountFormView allInstances inspect.Undeclared VariablesUndeclared inspect.Dependents"Look at dependents " (Object classPool at: #DependentsFields) keys "Release dependents of the specified type" (Object classPool at: #DependentsFields)	keysDo: 	[:each |	(each isKindOf: TextCollector)		ifTrue: [each release]]."Release unscheduled views which are still in Object''s dependency dictionary" Checker allUnscheduledDependentViews	do: [:aView | aView release]Globals"Names in Smalltalk other than Classes and Pools:"	Disk -- a FileDirectory	Sensor -- an InputSensor	Display -- a DisplayScreen	ScheduledControllers -- a ControlManager	Transcript -- a TextCollector	Processor --  a ProcessorScheduler 	SourceFiles -- Array of FileStreams	SystemOrganization -- a SystemOrganizer	ImageName -- fileName of last snapshot	FontManager -- a StrikeFontManager	StyleManager -- a TextStyleManager"Variable Pools (Dictionaries)  "	Smalltalk 	FilePool	BitMaskPool	TextConstants	Undeclared	OSEnvironmentVariablesSmalltalk removeKey: #GlobalName.Smalltalk declare: #GlobalName	from: Undeclared."Example use of a transcript "Transcript show: (3+4) printString; cr."Don't repaint occluded windows if frills is false "Smalltalk frills: false.  "for slow machines""Repaint windows the slow way if saveSpace is true "Smalltalk saveSpace: true.  "for limited memory machines"Fonts and Text Styles"Inspect resident StrikeFonts"FontManager inspect."Inspect resident TextStyles"StyleManager inspect."Installation of a new TextStyle.  Font family names are derived from font files in the /fonts directory.  More textStyle templates are in the /smalltalk/textStyles directory. "StyleManager	styleName: 'Pellucida Sans-Serif 12 and 14' 		"name of new textStyle"	baseNames: #('PellucidaSans-Serif12' 'PellucidaSans-Serif14')	"font family names"	lead: 3."Pop up a menu of available TextStyles.  Selecting one propagates it to:		default TextStyle		system menus		all scheduled views and their subviews"StyleManager changeDefaultTextStyle."Discard all existing StrikeFonts and TextStyles, read in small fonts, andcreate a new default text style"Compiler evaluate:	((Disk file: '/smalltalk/textStyles/pruneToPellucidaDefault08and10.ws')		contentsOfEntireFile).Display"Set extent to the virtual screen size" DisplayScreen displayExtent: 1376@1024. "Set extent to the some other size" DisplayScreen displayExtent:  800@800."Set mouse bound to be visible display"Display setMouseBounds: Display boundingBox."Set mouse bound to be outside visible display"Display setMouseBounds: (-50@-50 corner: 1500@1500)."Center cursor in viewport - Function key 12"Sensor cursorPoint: Display viewportCenter"Access display system functions" Display getViewportLocation.Display setInverseVideo.Display setNormalVideo.Measurements"#Objects, #words of data (takes a long time):"Smalltalk coreSmalltalk oopsLeftSmalltalk coreLeft"Free space on Disk"TekSystemCall execSystemUtility: '/bin/free' withArgs: (OrderedCollection with: '/dev/disk')"Number of instances of a class"MethodContext instanceCount"Time code execution"Time millisecondsToRun:	[SystemOrganization printString]"Open an edit window on the results of spying "  MessageTally spyOn: [Behavior compileAll]" or write results to a file" MessageTally spyOn: [Behavior compileAll] to: 'spy.results'.	(FileStream oldFileNamed: 'spy.results') edit.Change Management and Crash recovery"Create a blank view for change recovery." ChangeListView open."Create a view for change recovery from a given file" ChangeListView openOn: (ChangeList new recoverFile: (FileStream oldFileNamed: 'fileName.st'))."After a crash, create a view to browse changes since the last snapshot:" ChangeListView recover."Or copy most recent 5000 chars to st80.recent and open an edit window on it:" Smalltalk recover: 5000.