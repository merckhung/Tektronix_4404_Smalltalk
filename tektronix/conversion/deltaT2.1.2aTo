Behavior removeSelector: #kindOfSubclass !!Class methodsFor: 'subclass creation'!nonVariableSubclass: t instanceVariableNames: f 	classVariableNames: d poolDictionaries: s category: cat	"This is the standard initialization message for creating a new class as a subclass	of an existing class (the receiver) in which the subclass does not have indexable	pointer variables  but self is variable."	self isBits 		ifTrue: 			[^self error: 				'cannot make a pointer subclass of a class with non-pointer fields'].	^self class name: t 		inEnvironment: Smalltalk		subclassOf: self 		instanceVariableNames: f		variable: false 		words: true 		pointers: true		classVariableNames: d 		poolDictionaries: s 		category: cat 		comment: nil		changed: false! !!ClassDescription methodsFor: 'fileIn-Out'!kindOfSubclass	"Answer a string that describes what kind of subclass the 	receiver is, i.e., variable, variable byte, variable word, nonVariable	or regular subclass."	self isVariable		ifTrue: [self isBits				ifTrue: [self isBytes						ifTrue: [^' variableByteSubclass: ']						ifFalse: [^' variableWordSubclass: ']]				ifFalse: [^' variableSubclass: ']]		ifFalse: [superclass notNil ifTrue: [superclass isVariable 				ifTrue: [^' nonVariableSubclass: ']]].^' subclass: '! !!Class methodsFor: 'class name'!replaceNameWith: aSymbol 	"Replace the name of the receiver with a new symbol to make a class appear to 	be some other class.  For use in clone preparation only."	name _ aSymbol! !!ClassDescription methodsFor: 'printing'!definition	"Answer a string that defines the receiver."	| aStream name |	aStream _ WriteStream on: (String new: 300).	self hasMultipleSuperclasses		ifTrue:			[aStream nextPutAll: 'Class named: '.			self name storeOn: aStream.			aStream cr; tab; nextPutAll: 'superclasses: '.			aStream store: self superclassesString.			aStream cr; tab; nextPutAll: 'instanceVariableNames: '.			aStream store: self instanceVariablesString.			aStream cr; tab; nextPutAll: 'classVariableNames: '.			aStream store: self classVariablesString]		ifFalse:			[aStream nextPutAll: (superclass == nil ifTrue: ['nil'] ifFalse: [superclass name]).			aStream nextPutAll: self kindOfSubclass.			self name storeOn: aStream.			aStream cr; tab; nextPutAll: 'instanceVariableNames: '.			aStream store: self instanceVariablesString.			aStream cr; tab; nextPutAll: 'classVariableNames: '.			aStream store: self classVariablesString.			aStream cr; tab; nextPutAll: 'poolDictionaries: '.			aStream store: self sharedPoolsString].	aStream cr; tab; nextPutAll: 'category: '.	(name _ SystemOrganization categoryOfElement: self name) notNil 		ifTrue: [name asString storeOn: aStream]		ifFalse: [' Tracer-Support' storeOn: aStream].	^aStream contents! !!ClassDescription methodsFor: 'fileIn-Out'!moveChangesToSources: newFile 	"Used in the process of condensing changes, this message requests that the source	code of all methods of the receiver that have been changed should be moved to	newFile, sources, corresponding to index of 1."	| changes |	self organization moveChangedCommentToFile: newFile numbered: 1.	changes _ methodDict keys select: [:sel | (methodDict at: sel) fileIndex > 1].	self fileOutChangedMessages: changes		on: newFile		moveSource: true		toFile: 1! !!SystemDictionary methodsFor: 'system compression'!appendChangesToSourceFileWithout: setOfClasses 	"Append source stored in the changes file to the source file, omitting references to 	any classes in the set, setOfClasses.  This method is intended for use in the creation of	multiple images with slightly differing sources.		Smalltalk appendChangesToSourceFileWithout: (Array new).	Make sure versionName is updated and make a snapshot, renaming the image similarly."	| source class |	source _ SourceFiles at: 1.	source readWrite; setToEnd.	Smalltalk allBehaviorsDo:		[:class | 		(setOfClasses includes: class)			ifFalse: 				[class moveChangesToSources: source]].	(SourceFiles at: 1) readOnly	"Check for contents of changes file still referenced in the image:		| compiledMethod |	 Smalltalk		allBehaviorsDo: 			[:class | 			class selectors do: 				[:aSelector | 				compiledMethod _ class compiledMethodAt: aSelector.				Cursor read					showWhile: [						compiledMethod fileIndex > 1 ifTrue: [						Transcript cr; show: class name; crtab; show: aSelector]]]]	"! !!DisplayScreen methodsFor: 'display functions'!viewport	"Answer a rectangle indicating the location and extent of 	the viewport."	| buffer origin |	buffer _ self getDisplayReport.	origin _ self getViewportLocation.	^origin corner: (buffer at: 29) @ (buffer at: 30)!viewportCenter	"Answer a point indicating the center of the viewport."	| buffer |	buffer _ self getDisplayReport.	^(buffer at: 29)/2 @ ((buffer at: 30)/2)!setDisplayStateFrom: aDisplayReport 	"Set the status of the display system based on a 36 word 	buffer, previously filled by a call to getDisplayReport.	Only state appropriate for modification from Smalltalk is reset."	| stateBits upperLeftMouse lowerRightMouse |	stateBits _ aDisplayReport at: 2.	(stateBits allMask: 2r1)		ifTrue: [Display makeDisplayVisible]		ifFalse: [Display makeDisplayBlank].	(stateBits allMask: 2r10)		ifTrue: [Display enableScreenSaver]		ifFalse: [Display disableScreenSaver].	(stateBits allMask: 2r100)		ifTrue: [Display setNormalVideo]		ifFalse: [Display setInverseVideo].	(stateBits allMask: 16r400)		ifTrue: [Display enableCursorPanning]		ifFalse: [Display disableCursorPanning].	(stateBits allMask: 16r800)		ifTrue: [Display enableJoydiskPanning]		ifFalse: [Display disableJoydiskPanning].	"viewport upper left"	Display setViewportLocation: 			(aDisplayReport at: 3) @ (aDisplayReport at: 4).	"mouse bounds"	upperLeftMouse	_ (aDisplayReport at: 5) @ (aDisplayReport at: 6).	lowerRightMouse _ (aDisplayReport at: 7) @ (aDisplayReport at: 8).	Display setMouseBounds: 		(upperLeftMouse corner: lowerRightMouse)! !!NotifierView class methodsFor: 'instance creation'!openInterrupt: aString onProcess: interruptedProcess 	"Create and schedule an instance of me whose model is a Debugger on	interruptedProcess.  Sent to notify the user that the system is low in space or that	the user typed ctrl c.  The label of the scheduled view is aString."	| debugger topView cont savedView |	cont _ ScheduledControllers activeController.	(cont notNil and: [cont class ~= ScreenController]) 		ifTrue: 			[cont view repaintScrollBar.			(Smalltalk saveSpace == false and: [cont view isKindOf: StandardSystemView])				ifTrue: [cont view saveDisplayForm]].	debugger _ Debugger interruptProcess: interruptedProcess.	topView _ 		self openDebugger: debugger			contents: debugger interruptedContext shortStack			label: aString			displayAt: Display viewportCenter.	^topView! !!Pen methodsFor: 'geometric designs'!mandala: npoints diameter: d 	"On a circle of diameter d, place n points.  Draw all possible connecting 	lines directly on the display.  The circle is centered in the current viewport."	|points radius angle|	Display white.	self place: Display viewportCenter;		turn: direction degreesToRadians - direction.  "Work in radians for efficiency"	radius _ Float new coerce: d / 2.         "Compute these outside of the loop"	angle _ (360 / npoints) degreesToRadians.	points _ Array new: npoints.	1 to: npoints do:                      "Compute the locations of the points"		[:i | 		points at: i put: ((direction cos @ direction sin) * radius + location) rounded.		self turn: angle].                "Increment direction by angle"	self turn: direction radiansToDegrees - direction; down.  "Switch back to degrees"	npoints // 2		to: 1		by: -1		do: 			[:i | 			self color: npoints // 2 - i * 20 \\ 250.			1 to: npoints do: 				[:j | 				self place: (points at: j).				self goto: (points at: j + i - 1 \\ npoints + 1)]]	" 	Pen new mandala: 30 diameter: 400	"! !!ScreenController methodsFor: 'menu messages'!forkOSshell	"Fork an operating system shell with history.	Type 'exit' to the shell to return to Smalltalk."	| task aDisplayReport oldSIGHUPValue oldSIGINTValue oldSIGTERMValue error oldSIGQUITValue |	FileStream releaseExternalReferences.	Display fill: (Display boundingBox) mask: Form white.	aDisplayReport _ Display getDisplayReport.	TekSystemCall write: 1 from: (String with: Character esc), '[1;1H' size: 6. "home the underscore cursor"	oldSIGHUPValue _ TekSystemCall setInterrupt: 1 to: 1.	oldSIGINTValue _TekSystemCall setInterrupt: 2 to: 1.	oldSIGQUITValue _  TekSystemCall setInterrupt: 3 to: 1.	oldSIGTERMValue _  TekSystemCall setInterrupt: 11 to: 1.	TekSystemCall clearAlarm value.		task _ Subtask fork: '/bin/shell'  withArgs: (OrderedCollection with: '+i') then: [		TekSystemCall setInterrupt: 1 to: 0.		TekSystemCall setInterrupt: 2 to: 0.		TekSystemCall setInterrupt: 3 to: 0.		TekSystemCall setInterrupt: 11 to: 0.		TekSystemCall clearAlarm value.		TekSystemCall cursorOff value.		TekSystemCall eventsDisable value.		TekSystemCall terminalOn value].	error _ task start.	error isNil 		ifFalse: [task absoluteWait.			task release].	TekSystemCall setInterrupt: 1 to: oldSIGHUPValue.	TekSystemCall setInterrupt: 2 to: oldSIGINTValue.	TekSystemCall setInterrupt: 3 to: oldSIGQUITValue.	TekSystemCall setInterrupt: 11 to: oldSIGTERMValue.	Subtask initializeBrokenPipeCatch.	Subtask initializeWaitManagement.	TekSystemCall terminalOff value.	TekSystemCall cursorOn value.	Cursor cursorLink: true.	Display setDisplayStateFrom: aDisplayReport. 	TekSystemCall eventsEnable value.	TekSystemCall eventSignalOn value.	(TekSystemCall setKeyboardCode: 0) value.	Delay reissueTimingSignal.	Sensor resetCapsLockState. 	Display gray.	Cursor currentCursor centerCursorInViewport.	ScheduledControllers restore.	error isNil ifTrue: [^self error: 'Cannot fork shell'].! !!Cursor methodsFor: 'displaying'!centerCursorInViewport	| upperLeftPoint centerPoint | 	"Center the current cursor in the current viewport and link it to the mouse"	Cursor cursorLink: true.	Sensor cursorPoint: Display viewportCenter.! !!DisplayScreen methodsFor: 'display functions'!setMouseBounds: boundingRectangle	"Set the allowable mouse bounds to an upper left coordinate and 	a lower right coordinate within the display bitmap."	| sysCall xyUpper xyLower mouseArea upperPoint lowerPoint | 	mouseArea _ Display boundingBox.	upperPoint _ boundingRectangle origin.	lowerPoint _ boundingRectangle corner.	((mouseArea containsPoint: upperPoint) and: [mouseArea containsPoint: lowerPoint])		ifFalse: [Transcript cr; show: 'Mouse bounds set outside display bounds'].	xyUpper _ upperPoint x * 65536 + upperPoint y.	xyLower _ lowerPoint x * 65536 + lowerPoint y.	sysCall _ TekSystemCall setMouseBounds: xyUpper lowerRight: xyLower.	sysCall value! setMouseBoundsUpper: upperPoint lowerCorner: lowerPoint	"Set the allowable mouse bounds to an upper left coordinate and 	a lower right coordinate within the display bitmap."	| sysCall xyUpper xyLower mouseArea | 	mouseArea _ 0@0 corner: 1025@1025.	((mouseArea containsPoint: upperPoint) and: [mouseArea containsPoint: lowerPoint])		ifFalse: [Transcript cr; show: 'Mouse bounds set outside display bounds'].	xyUpper _ upperPoint x * 65536 + upperPoint y.	xyLower _ lowerPoint x * 65536 + lowerPoint y.	sysCall _ TekSystemCall setMouseBounds: xyUpper lowerRight: xyLower.	sysCall value! !!Set class methodsFor: 'constants'!maxSize	"Answer the largest basicSize which is valid for the receiver."	^MaxObjectSize - self instSize! !!Collection methodsFor: 'private'!growSize	"Answer an amount by which the receiver should grow to make room for more elements (in response to the message 'grow')."	self basicSize >= self maxSize ifTrue: [self error: 'unable to grow this collection'].	^(self basicSize max: 2) min: self maxSize - self basicSize!maxSize	"Answer the largest basicSize which is valid for the receiver's class.	Should answer infinity, but this is close enough."	^self class maxSize! !!SequenceableCollection methodsFor: 'comparing'!hash	"Equal has been redefined -- hash is redefined"	self size = 0 ifTrue: [^31874].	^31874 + (5 * self size hash) + (7 * (self at: 1) hash) + (self at: self size) hash! !!PositionableStream methodsFor: 'accessing'!through: anObject	"Answer a subcollection from position to the occurrence 	(inclusive) of anObject.  If not there, answer everything."	| newStream element |	newStream _ WriteStream on: (collection species new: 64).	[(self atEnd or: [(element _ self next) = anObject]) or: [newStream size > newStream contents maxSize]]		whileFalse: [newStream nextPut: element].	self atEnd		ifFalse:	[newStream nextPut: element].	^newStream contents!upTo: anObject 	"Answer a subcollection from position up to the occurrence (not  	inclusive) of anObject.  If not there, answer everything."	| newStream element maxSize |	newStream _ WriteStream on: (collection species new: 64).	maxSize _ newStream contents maxSize.	[(self atEnd 		or: [newStream size == maxSize]) 		or: [(element _ self next) = anObject]]				whileFalse: [newStream nextPut: element].	^newStream contents! !!FileStream methodsFor: 'accessing'!contentsOfEntireFile	"Read all of the contents of the receiver."	| s size |	self readOnly.	self reset.	(size _ self size) > 				(self isBinary					ifTrue: [ByteArray]					ifFalse: [String]) maxSize 			ifTrue: [^self error: 'File too large to read entire contents.'].	s _ self next: size.	self close.	^s! !!PipeReadStream methodsFor: 'accessing'!contentsOfEntireFile	"Read all of the contents of the receiver.  If the Stream buffer contains something, 	prepend it to the results."	| buffer sysCall newSpecies oldCollection oldCollectionSize newCollection bufferSize collectionSize newCollectionSize |	newSpecies _ self isBinary				ifTrue: [ByteArray]				ifFalse: [String].	buffer _ newSpecies new: 4096.	bufferSize _ SystemCall				read: fileDescriptor				into: buffer.	collectionSize _ readLimit - position.	collectionSize ~= 0    "Was anything previously buffered? "			ifTrue: [newCollection _ newSpecies new: (bufferSize + collectionSize).				newCollection  replaceFrom: 1 to: collectionSize with: collection startingAt: position.				newCollection  replaceFrom: (collectionSize + 1) to: (bufferSize + collectionSize) with: buffer startingAt: 1.				oldCollection _ newCollection.				position _ readLimit _ bufferSize]			ifFalse: [oldCollection _ buffer copyFrom: 1 to: bufferSize].	[bufferSize = 0]			whileFalse: 				[bufferSize _ SystemCall						read: fileDescriptor						into: buffer.				oldCollectionSize _ oldCollection size.				((newCollectionSize _ bufferSize + oldCollectionSize) > newSpecies maxSize)					ifTrue: [^self error: 'File too large to read entire contents.'].				newCollection _ newSpecies new: newCollectionSize.				newCollection  replaceFrom: 1 to: oldCollectionSize with: oldCollection startingAt: 1.				newCollection  replaceFrom: oldCollectionSize +1 to: newCollectionSize with: buffer startingAt: 1.				oldCollection _ newCollection].	foundEnd _ true.	^oldCollection! !!Stream methodsFor: 'accessing'!nextPutAll: aCollection startingAt: startIndex to: stopIndex	| newCollection newSize |  	"Append the elements of aCollection, if it is of an appropriate type, onto the	receiver starting at startIndex.  Answer aCollection."	(aCollection isKindOf: ArrayedCollection)		ifTrue: [newSize _ stopIndex - startIndex + 1.				newCollection _ aCollection species new: newSize.				newCollection  replaceFrom: 1 to: newSize with: aCollection startingAt: startIndex.				self nextPutAll: newCollection]		ifFalse: [(aCollection isKindOf: Stream)			ifTrue: 				[aCollection position: startIndex.				self nextPutAll: aCollection]			ifFalse: [^self error: 'Cannot perform position dependent putting with this object']].	^aCollection! !!FileStream methodsFor: 'accessing'!nextPutAll: aCollection 	"Write the elements of aCollection onto the receiver.  If aCollection will	fit in the receiver's buffer then buffer it.  Otherwise write it directly to	the receiver's file.  If aCollection is of kind other than String or ByteArray	(a Set of Characters, for example) write each of its elements individually."	| collectionSize |	(aCollection isKindOf: FileStream) ifTrue: [^self appendFileStream: aCollection].	((aCollection isKindOf: String) or: [aCollection isKindOf: ByteArray])		ifFalse: [^super nextPutAll: aCollection].	writeLimit - position > (collectionSize _ aCollection size)		ifTrue:			[^collection				replaceFrom: position + 1				to: (position _ position + aCollection size)				with: aCollection	"answer aCollection?"				startingAt: 1].	writeLimit > 0		ifTrue: [self flush]		ifFalse: [self beginWriting].	writeLimit >= collectionSize		ifTrue:			[super nextPutAll: aCollection]		ifFalse:			[self writeAccess.			SystemCall write: fileDescriptor from: aCollection size: collectionSize.			filePosition _ filePosition + collectionSize].	^aCollection!nextPutAll: aCollection startingAt: startIndex	| newCollection |  	"Append the elements of aCollection, if it is of an appropriate type, onto the	receiver starting at startIndex.  Answer aCollection."	(aCollection isKindOf: ArrayedCollection)		ifTrue: [collection  replaceFrom: (position + 1) to: (position _ position + aCollection size - startIndex + 1) with: aCollection startingAt: startIndex]		ifFalse: [(aCollection isKindOf: Stream)			ifTrue: 				[super nextPutAll: aCollection startingAt: startIndex]			ifFalse: [^self error: 'Cannot perform position dependent putting with this object']].	^aCollection!nextPutAll: aCollection startingAt: startIndex to: stopIndex	| newCollection newSize |  	"Append the elements of aCollection, if it is of an appropriate type, onto the	receiver starting at startIndex.  Answer aCollection."	(aCollection isKindOf: ArrayedCollection)		ifTrue: [newSize _ stopIndex - startIndex + 1.				collection replaceFrom: (position + 1) to: (position _ position + newSize) with: aCollection startingAt: startIndex]		ifFalse: [(aCollection isKindOf: Stream)			ifTrue: 				[super nextPutAll: aCollection startingAt: startIndex to: stopIndex]			ifFalse: [^self error: 'Cannot perform position dependent putting with this object']].	^aCollection!size	"Answer the size of the receiver's file in characters (or bytes)."	^self exists ifTrue:[self status fileSize max: self position] ifFalse:[0]! !!FileStream methodsFor: 'nonhomogeneous positioning'!padTo: bsize 	"Pad (skip) to next boundary of bsize characters, and answer how many characters	were skipped."	| mod |	mod _ self position \\ bsize.	mod == 0 ifFalse:[self skip: bsize - mod].	^bsize - mod! !!FileStream methodsFor: 'file modes'!binary	| size | 	"Set the receiver's file to be buffered in binary mode.  Copy any already	buffered data to the new buffer, a ByteArray."	size _ collection size.	self isBinary		ifFalse:			[collection _ (ByteArray new: size)				replaceFrom: 1 to: size				withString: collection startingAt: 1]!text	| size | 	"Set the receiver's file to be buffered in text mode.  Copy any already	buffered data to the new buffer, a String."	size _ collection size.	self isBinary		ifTrue:			[collection _ (String new: size)				replaceFrom: 1 to: size				withByteArray: collection startingAt: 1]! !!FileStream methodsFor: 'private'!appendFileStream: aFileStream	" write the contexts of another file stream to the receiver which is also a fileStream"	|size buffer bufferClass| 	size _ aFileStream size - aFileStream position.	bufferClass _ aFileStream isBinary		ifTrue: [ByteArray]		ifFalse: [String].	size >= 1024 ifTrue:[buffer _ bufferClass new: 1024].	size // 1024 timesRepeat: [aFileStream next: 1024 into: buffer. self nextPutAll: buffer].	size _ size \\ 1024.	size > 0 ifTrue: [		buffer _ bufferClass new: size.		aFileStream next: size into: buffer.		self nextPutAll: buffer].	^aFileStream! !!CompiledMethod class methodsFor: 'instance creation'!newBytes: numberOfBytes flags: flags nTemps: numberTemps  nArgs:numberArgs nStack: stackSpace nLits: numberLiterals primitive: prim	"Answer an instance of me.  The header is specified by the message	arguments.  The remaining parts are not as yet determined."	| flagBits |	flags >= 4 ifTrue: [flagBits _ flags - 8]			ifFalse: [flagBits _ flags].	"ensure 15-bit integer result"	^self 		newMethod: numberOfBytes + 3 	"+3 to store source location" 		header: flagBits * 4096 + (numberTemps * 128) 				+ (numberTemps + stackSpace > SmallFrame						ifTrue: [64]						ifFalse: [0]) 				+ numberLiterals!newBytes: numberOfBytes flags: flags nTemps: numberTemps nStack: stackSpace nLits: numberLiterals 	"Answer an instance of me.  The header is specified by the message	arguments.  The remaining parts are not as yet determined."	^self newBytes: numberOfBytes flags: flags nTemps: numberTemps nArgs: 0 nStack: stackSpace nLits: numberLiterals primitive: 0! !!CompiledMethod class methodsFor: 'source code management'!nullSourceDescriptor	"return a 3 byte trailer value for a method with no source code"	^#(0 0 0)! !!CompiledMethod class methodsFor: 'inquiries'!quickReturnPC	"No code is generated for a quick return."	^3! !!CompiledMethod methodsFor: 'source code management'!nullSourceDescriptor	"return a 3 byte trailer value for a method with no source code"	^#(0 0 0)! !!CompiledMethod methodsFor: 'bytecodes'!openByteCodeStream	| strm | 	strm _ ReadWriteStream with: self.	strm position: self initialPC - 1.	^strm! !!CompiledMethod methodsFor: 'source code management'!sourceDescriptor	"return the 3 byte trailer value which describes the location of the method's source code"		^(self size - 2 to: self size) collect: [:i | self at: i]!sourceDescriptor: trailer	"set the 3 byte trailer value which describes the location of the method's source code"			1 to: 3 do: [:i | self at: self size - 3 + i put: (trailer at: i)].!sourceOffset	"Answer the byte offset of the source code for this method within its file"	|pos siz|	siz _ self size.	pos _ (self at: siz) bitAnd: 63.	pos _ pos * 256 + (self at: siz - 1).	^pos * 256 + (self at: siz - 2)!trailerSize	^3! !!Compiler methodsFor: 'public access'!evaluate: textOrStream in: aContext to: receiver notifying: aRequestor ifFail: failBlock	"Compiles the sourceStream into a parse tree, then generates code into a method.	This method is then installed in the receiver's class so that it can be invoked.	In other words, if receiver is not nil, then the text can refer to instance variables	of that receiver (the Inspector uses this).  If aContext is not nil, the text can refer to	temporaries in that context (the Debugger uses this).  If aRequestor is not nil, then	it will receive a notify:at: message before the attempt to evaluate is aborted.	Finally, the compiled method is invoked from here as DoIt or	(in the case of evaluation in aContext) DoItIn:.	The method is subsequently removed from the class, but this will not get done	if the invocation causes an error which is terminated.  Such garbage can be	removed by executing:		Smalltalk allBehaviorsDo: 			[:cl | cl removeSelector: #DoIt; removeSelector: #DoItIn:]."	| methodNode method value |	Cursor execute show.	class _ (aContext == nil ifTrue: [receiver] ifFalse: [aContext receiver]) class.	self from: textOrStream class: class context: aContext notifying: aRequestor.	methodNode _ self translate: sourceStream noPattern: true ifFail:		[^failBlock value].	method _ methodNode generate: CompiledMethod nullSourceDescriptor.	context == nil			ifTrue: [class addSelector: #DoIt withMethod: method.					value _ receiver DoIt.					class removeSelectorSimply: #DoIt.					Cursor normal show.					^value]			ifFalse: [class addSelector: #DoItIn: withMethod: method.					value _ receiver DoItIn: context.					class removeSelectorSimply: #DoItIn:.					Cursor normal show.					^value]! !!Behavior methodsFor: 'compiling'!compileUnchecked: code	"Compile the argument, code, and install the result in the receiver's method dictionary.	Do not check for possible effect on inheritance, since that's what this is doing."	| selector methodNode |	methodNode _ self compilerClass new				compile: code				in: self				notifying: nil				ifFail: [^nil].	selector _ methodNode selector.	self addSelectorUnchecked: selector withMethod: (methodNode generate: CompiledMethod nullSourceDescriptor).	^selector!recompile: selector from: oldClass	"Recompile the method associated with selector in the receiver's method dictionary.	Take care not to write out any new source code - just generate new bytes.	oldClass may differ from self in order to decompile right (if sourceFiles == nil)	when adding or removing fields of a class."	| method trailer methodNode |	method _ oldClass compiledMethodAt: selector.	trailer _ method sourceDescriptor.	methodNode _ self compilerClass new				compile: (oldClass sourceCodeAt: selector)				in: self				notifying: nil				ifFail: [].	methodNode == nil  "Try again after proceed from SyntaxError"		ifTrue: [^self recompile: selector].	selector == methodNode selector ifFalse: [self error: 'selector changed!!'].	self addSelector: selector withMethod: (methodNode generate: trailer).! !!Benchmark methodsFor: 'macro operations'!testCompiler	self test:			[Benchmark compile:'dummy: aBlock repeated: nTimes | i emptyBlock emptyTime blockTime |	nTimes > 1000 ifTrue: [^self time: aBlock repeatedK: nTimes // 1000].	emptyBlock _ [].	emptyTime _ Time millisecondsToRun:					[i _ 0.					 [(i _ i + 1) <= nTimes] whileTrue: [emptyBlock value]].	blockTime _ Time millisecondsToRun:					[i _ 0.					 [(i _ i + 1) <= nTimes] whileTrue: [aBlock value]].	^blockTime - emptyTime'				notifying: nil trailer: CompiledMethod nullSourceDescriptor]		labeled: 'compile dummy method' repeated: 5.	Benchmark removeSelector: #dummy:repeated:	"Benchmark new testCompiler"! !!ClassDescription methodsFor: 'compiling'!compile: code classified: heading notifying: requestor 	"Compile the argument, code, as source code in the context of the receiver and	install the result in the receiver's method dictionary under the classification 	indicated by the second argument, heading  The third argument,	requestor, is to be notified if an error occurs. The argument code is either a string or	an object that converts to a string or a PositionableStream on an object that converts	to a string."	| selector |	selector _ 		self compile: code			notifying: requestor			trailer: CompiledMethod nullSourceDescriptor			ifFail: [^nil].	(methodDict at: selector)		putSource: code asString		class: self		category: heading		inFile: 2.	self organization classify: selector under: heading.	^selector! !!Debugger methodsFor: 'pc selection'!pcRange	"Answer the indices in the source code for the method corresponding	to the selected context's program counter value."	| i methodNode pc end |	(HighlightPC and: [context ~~ nil])		ifFalse: [^1 to: 0].	(sourceMap == nil or: [sourceMap size = 0])		 ifTrue: [^1 to: 0].	pc _ context pc - ((context == processHandle topContext and:		[processHandle interrupted])			ifTrue: [1]			ifFalse: [2]).	i _ sourceMap indexForInserting: (Association key: pc value: nil).	i < 1 ifTrue: [^1 to: 0].	i > sourceMap size		ifTrue:			[end _ sourceMap inject: 0 into:				[:prev :this | prev max: this value last].			^ end+1 to: end].	^(sourceMap at: i) value! !!Debugger methodsFor: 'menu messages'!spawnEdits: aText from: aController	context == nil  "can't spawn changes when deselected"		ifFalse: [super spawnEdits: aText from: aController]! !!Debugger methodsFor: 'stack manipulation'!step	"Some context is selected (force top if none).  When this is so, either 	some message is about to be sent in that context, or that context is 	about to return.  Step will cause the next message to be sent or the 	return to be executed.  In either case, the debugger regains control 	so that you can step your way down through a method, and out to 	the caller when it returns.  Note that the execution invoked by step 	is actually simulated, so it will run much slower than normal"	| currentContext |	self checkContextSelection.	processHandle interrupted ifFalse: [processHandle topContext push: processHandle proceedValue].	processHandle interrupted: true.	"simulation leaves same state as interrupting"	context == processHandle topContext		ifTrue: 			[currentContext _ context.			currentContext stepToSendOrReturn.			currentContext willReturn				ifTrue: 					[currentContext _ currentContext step.					currentContext stepToSendOrReturn.					self resetContext: currentContext]				ifFalse: 					[currentContext completeCallee: currentContext step.					self changed: #pc.					self updateInspectors]]		ifFalse: 			["Have to complete any stuff called from here"			context completeCallee: processHandle topContext.			self resetContext: context]! !!Encoder methodsFor: 'source mapping'!noteSourceRange: range forNode: node	sourceRanges at: node put: range!sourceMap	"Answer with a sorted set of associations (pc . range) used for 	highlighting in the debugger."	| key |	^(sourceRanges keys collect: 		[:key | Association key: key pc value: (sourceRanges at: key)]) 			asSortedCollection!sourceMap: deltaPC	"Answer with a sorted set of associations (pc . range).  Delta is the difference	between the parsed number of literals (startpc) and the generated number of	literals. Retained for compatability."	^self sourceMap! !!MessageNode methodsFor: 'code generation'!emitForEffect: stack on: strm	| delta |  	special > 0		ifTrue: 			[self perform: (MacroEmitters at: special) with: stack with: strm with: false.			pc _ 0]		ifFalse: 			[super emitForEffect: stack on: strm.			pc _ strm position]!emitForValue: stack on: strm 	| argument delta |	special > 0		ifTrue: 			[self				perform: (MacroEmitters at: special)				with: stack				with: strm				with: true.			pc _ 0]		ifFalse: 			[receiver ~~ nil ifTrue: [receiver emitForValue: stack on: strm].			arguments do: [:argument | argument emitForValue: stack on: strm].			selector				emit: stack				args: arguments size				on: strm				super: receiver == NodeSuper.			pc _ strm position]! !!MethodDefinitionChange methodsFor: 'accessing'!accept: newText notifying: requestor	"Check to make sure the current definition is valid"	| methodNode |	methodNode _ Compiler new		compile: newText		in: (Smalltalk at: className ifAbsent: [^nil])		notifying: requestor		ifFail: [^nil].	methodNode generate: CompiledMethod nullSourceDescriptor.	^self class new text: self text; className: className; selector: methodNode selector; category: category! !!MethodDefinitionChange methodsFor: 'source code'!sourceFileAndPosition: aBlock	"Get the source code for this method from information currently in the system."	| class method fileIndex pos |	(class _ self classObject) isNil ifTrue: [^nil].	(class includesSelector: selector) ifFalse: [^nil].	method _ class compiledMethodAt: selector.	SourceFiles isNil ifTrue: [^nil].	(fileIndex _ method fileIndex) > SourceFiles size ifTrue: [^nil].	"The following code should be in CompiledMethod ..."	pos _ method sourceOffset.	pos = 0 ifTrue: [^nil].	^aBlock value: (SourceFiles at: method fileIndex) value: pos! !!MethodNode methodsFor: 'code generation'!generate: trailer	"I am the root of a parse tree; answer with an instance of CompiledMethod."	| blkSize method nLits lit stack strm nArgs i |	self generateIfQuick: 		[:method | 		method sourceDescriptor: trailer.		method cacheTempNames: self tempNames.		^method].	nArgs _ arguments size.	blkSize _ block sizeForEvaluatedValue: encoder.	literals _ encoder literals: primitive nArgs: nArgs.	encoder maxTemp > 31		ifTrue: [^self error: 'Too many temporary variables'].		(nLits _ literals size) > 63		ifTrue: [^self error: 'Too many literals referenced'].	method _ CompiledMethod		"Dummy to allocate right size"				newBytes: blkSize				flags: ((nArgs <= 4 and: [primitive = 0]) ifTrue: [nArgs] ifFalse: [7])				nTemps: encoder maxTemp				nArgs: nArgs				nStack: 0				nLits: nLits				primitive: primitive.	strm _ method openByteCodeStream.	stack _ ParseStack new init.	block emitForEvaluatedValue: stack on: strm.	stack position ~= 1 ifTrue: [^self error: 'Compiler stack discrepancy'].	strm position ~= (method size - method trailerSize) 		ifTrue: [^self error: 'Compiler code size discrepancy'].	1 to: nLits do: [:lit | method literalAt: lit put: (literals at: lit)].	method needsStack: stack size encoder: encoder.	method sourceDescriptor: trailer.	method cacheTempNames: self tempNames.	^method!generateNoQuick	"Assumes would have been quick.  Forces numArgs > 0 so will compile real code.	The debugger needs this to look simulate a quick return"	arguments _ Array new: 1.	^ self generate: CompiledMethod nullSourceDescriptor!sourceMap	"I am the root of a parse tree; answer with a sorted collection of associations	of the form: pc (byte offset in me) -> sourceRange (an Interval) in source text."	self generate: CompiledMethod nullSourceDescriptor.	^encoder sourceMap! !!ReturnNode methodsFor: 'code generation'!emitForReturn: stack on: strm	| delta |  	expr emitForReturn: stack on: strm.	pc _ strm position!emitForValue: stack on: strm	| delta |  	expr emitForReturn: stack on: strm.	pc _ strm position!pc	"used by encoder source mapping"	pc == nil		ifTrue: [^CompiledMethod quickReturnPC].  "quick returns never generate, so pc=nil"	^pc! !CompiledMethod removeSelector: #storeOn: !!CompiledMethod methodsFor: 'accessing'!setPrimitive: primitiveIndex	"Make the method specify the execution of primitive primitiveIndex, anInteger."		self 		literalAt: 2 		put: ((self literalAt: 2) bitAnd: -256) + primitiveIndex! !!ContextPart methodsFor: 'private'!doPrimitive: primitiveIndex receiver: receiver args: arguments 	"Simulate a primitive method whose index is primitiveIndex.  The	simulated receiver and arguments are given as arguments to this message."	| numberArguments primitiveMethod value |	(primitiveIndex = 80 and: [receiver isKindOf: ContextPart])		ifTrue: [^self push: ((BlockContext new: receiver size)					home: receiver home					startpc: pc + 2					nargs: arguments first)]		ifFalse: [(primitiveIndex = 81 and: [receiver isMemberOf: BlockContext])				ifTrue: [^receiver pushArgs: arguments from: self]				ifFalse: [primitiveIndex = 83						ifTrue: [^self								send: arguments first								to: receiver								with: (arguments copyFrom: 2 to: arguments size)								super: false]						ifFalse: 							[numberArguments _ arguments size.							numberArguments > 4								ifTrue: [^#primitiveFail]								ifFalse: 									[primitiveMethod _ TryPrimitiveMethods at: numberArguments + 1.									primitiveMethod setPrimitive: primitiveIndex.									Class flushCache.									numberArguments = 0 ifTrue: [value _ receiver tryPrimitive0].									numberArguments = 1 ifTrue: [value _ receiver tryPrimitive1: (arguments at: 1)].									numberArguments = 2 ifTrue: [value _ receiver tryPrimitive2: (arguments at: 1)													with: (arguments at: 2)].									numberArguments = 3 ifTrue: [value _ receiver													tryPrimitive3: (arguments at: 1)													with: (arguments at: 2)													with: (arguments at: 3)].									numberArguments = 4 ifTrue: [value _ receiver													tryPrimitive4: (arguments at: 1)													with: (arguments at: 2)													with: (arguments at: 3)													with: (arguments at: 4)].									numberArguments > 4 ifTrue: [self error: 'too many arguments to this primitive'].									value == #primitiveFail										ifTrue: [^value]										ifFalse: [^self push: value]]]]]! !Object subclass: #ProcessorScheduler	instanceVariableNames: 'quiescentProcessLists activeProcess '	classVariableNames: 'AbsolutelyTheHighestPriority BackgroundProcess HighIOPriority LowIOPriority SystemBackgroundPriority SystemRockBottomPriority TimingPriority UserBackgroundPriority UserInterruptPriority UserSchedulingPriority '	poolDictionaries: ''	category: 'Kernel-Processes'!!ProcessorScheduler reorganize!('accessing' activePriority activeProcess highestPriority highestPriority:)('removing' remove:ifAbsent:)('process state change' resetPriorities suspendFirstAt: suspendFirstAt:ifNone: terminateActive yield)('timing' signal:atTime:)('critical execution' executeWithoutPreemption:)('priority names' absolutelyTheHighestPriority highIOPriority lowIOPriority systemBackgroundPriority timingPriority userBackgroundPriority userInterruptPriority userSchedulingPriority)('private' anyProcessesAbove: signal:atMilliseconds:)!!ProcessorScheduler methodsFor: 'accessing'!highestPriority: aPriority 	| newList eachList |	(quiescentProcessLists size > aPriority and: [self anyProcessesAbove: aPriority])		ifTrue: [self error: 'There are processes with priority higher than ' , aPriority printString].	newList _ Array new: aPriority.	1 to: (quiescentProcessLists size min: newList size)		do: [:eachList | newList at: eachList put: (quiescentProcessLists at: eachList)].	quiescentProcessLists size to: newList size do: [:eachList | newList at: eachList put: LinkedList new].	newList become: quiescentProcessLists! !!ProcessorScheduler methodsFor: 'process state change'!resetPriorities	"If the active process is running away at the absolutely highest priority,	reset its priority to that of user window scheduling.  Should be used only in case	of an error in a critical section."	activeProcess priority: UserSchedulingPriority! !!ProcessorScheduler methodsFor: 'critical execution'!executeWithoutPreemption: aBlock	|oldPriority process blockValue |	process_self activeProcess.	oldPriority _ process priority.
	process priority: AbsolutelyTheHighestPriority.	self yield.	blockValue _ aBlock value.	process priority: oldPriority.	self yield.	^blockValue! !!ProcessorScheduler methodsFor: 'priority names'!absolutelyTheHighestPriority	"Answer the priority at which the critical blocks should run.	This should only be used to provide nonpreemption."	^AbsolutelyTheHighestPriority! !!ProcessorScheduler class methodsFor: 'class initialization'!initialize        	SystemRockBottomPriority _ 1.	SystemBackgroundPriority _ 2.	UserBackgroundPriority _ 3.	UserSchedulingPriority _ 4.	UserInterruptPriority _ 5.	LowIOPriority _ 6.	HighIOPriority _ 7.	TimingPriority _ 8.	AbsolutelyTheHighestPriority _ 9	"ProcessorScheduler initialize."! !ProcessorScheduler initialize!Processor highestPriority: (Processor absolutelyTheHighestPriority)!!NotifierView class methodsFor: 'instance creation'! openContext: haltContext label: aString contents: contentsString	"Create and schedule an instance of me viewing a Debugger on haltContext.	The view will be labeled with aString, and shows a short sender stack."	| displayPoint cont |	ErrorRecursion		ifTrue: 			[ErrorRecursion _ false.			self primitiveError: aString].	ErrorRecursion _ true.	Processor resetPriorities.	cont _ ScheduledControllers activeController.	(cont notNil and: [cont class ~= ScreenController]) 		ifTrue: 			[cont view repaintScrollBar.			(Smalltalk saveSpace == false and: [cont view isKindOf: StandardSystemView])				ifTrue: [cont view saveDisplayForm]].	displayPoint _ 		ScheduledControllers activeController == nil			ifTrue: [Display boundingBox center]			ifFalse: [ScheduledControllers activeController view displayBox center].	self openDebugger: (Debugger context: haltContext)		contents: contentsString		label: aString		displayAt: displayPoint.	ErrorRecursion _ false.	Processor activeProcess suspend! !!Behavior methodsFor: 'private'!removeSelectorSimply: selector 	"Remove the message selector from the receiver's method dictionary.	Internal access from compiler."	methodDict _ methodDict copy removeKey: selector ifAbsent: [^self].	self flushCache! !!DisplayScreen class methodsFor: 'current display'!currentDisplay: form 	"Make the argument, form, be the template for modifying the current 	display screen.  Create an error if form is not an instance of me."	form class == self		ifTrue: [form bits class == DisplayBitmap				ifTrue: 					[Display						resetFrom: form bits						extent: form extent						offset: form offset.					Display beDisplay]				ifFalse: [self error: 'bitmap should be DisplayBitmap']]		ifFalse: [self error: 'form should be DisplayForm']!displayExtent: extent 	"Make the width and height of the current display screen form be extent."	| w h |	w _ extent x truncateTo: 32.	h _ extent y truncateTo: 2.	"shrink to 16 to release old bitmap"	Display resetFrom: (DisplayBitmap new: w // 16 * 16) extent: w@h. 	"now grow to new size"	Display resetFrom: (DisplayBitmap new: w // 16 * h) extent: w@h. 	ScheduledControllers restore! !!DisplayScreen methodsFor: 'private'!resetFrom: aBitmap extent: extent	"Reset Display bits to aBitmap, an instance of DisplayBitmap."	bits class == DisplayBitmap		ifTrue: 			[width _ extent x.			height _ extent y.			bits _ aBitmap]		ifFalse: [self error: 'bitmap should be DisplayBitmap']!resetFrom: aBitmap extent: extent offset: anOffset	"Reset Display bits to aBitmap, an instance of DisplayBitmap."	bits class == DisplayBitmap		ifTrue: 			[width _ extent x.			height _ extent y.			offset _ anOffset.			bits _ aBitmap]		ifFalse: [self error: 'bitmap should be DisplayBitmap']! !!FormHolderView methodsFor: 'menu messages'!cancel	| aForm |	aForm _ model deepCopy.	displayedForm		extent: aForm extent		offset: aForm offset		bits: aForm bits.	displayedForm changed: self.	self display! !!SystemDictionary methodsFor: 'initialize-release'!install	CompiledMethod initialize.	SmallInteger initialize.	LargePositiveInteger initialize.	LargeNegativeInteger initialize.	Display beDisplay.	Cursor currentCursor: Cursor currentCursor.	InputSensor install.	LowSpaceProcess == nil ifFalse: [LowSpaceProcess terminate].	LowSpaceSemaphore _ Semaphore new.	LowSpaceProcess _ [self lowSpaceNotificationLoop] newProcess.	LowSpaceProcess priority: Processor lowIOPriority.	LowSpaceProcess resume.	self resetSpaceLimits! !!ControlManager methodsFor: 'displaying'!restore	| activeView | 	"Clear the screen to gray and then redisplay all the scheduled views."	self unschedule: screenController.	self scheduleOnBottom: screenController.	screenController view window: Display boundingBox.	self discardCachedDisplayForms.	scheduledControllers reverseDo: [:aController | aController view display; deEmphasize].	Cursor normal show.	ScheduledControllers activeController  notNil ifTrue:		[activeView _ ScheduledControllers activeController view topView.		(activeView notNil and: [activeView isKindOf: StandardSystemView])			ifTrue: [activeView deEmphasize; resetLabelFlag]].! !!ControlManager methodsFor: 'initialize-release'!discardCachedDisplayForms	scheduledControllers do: 			[:aController | (aController isKindOf: StandardSystemController )					ifTrue: [aController view deleteDisplayForm; setSelection: false]].! !!SystemDictionary methodsFor: 'system backup-out'!shutdown	"Shut off the low space signal so that the Vmem writer can be sure the 	system is stable while it is tracing."	self coreLeftLimit: 0.	self oopsLeftLimit: 0.	ScheduledControllers discardCachedDisplayForms.	Subtask terminateAll.!snapshotAs: imageFileName thenQuit: quitIfTrue	"Write the OT and Data of this Smalltalk image out on an external file.  Answer true if the snapshot was just created."	| justSnapped logEntry|	Cursor execute show.	self at: #ImageName put: imageFileName.	self releaseExternalViews.	Transcript cr; show: 'Snapshot at: ', Time dateAndTimeNow printString.	Delay preSnapshot.	Cursor wait show.	ScheduledControllers discardCachedDisplayForms.				justSnapped _ (self snapshotPrimitive: ImageName) isNil.	justSnapped 		ifTrue: 			[logEntry _ '''----SNAPSHOT---- to ',ImageName,': ',Time dateAndTimeNow printString,''''.			self logChange: logEntry].	justSnapped & quitIfTrue		ifTrue:			[Subtask terminateAll.   self quitPrimitive]		ifFalse:			[Delay postSnapshot.			self install.			justSnapped  				ifFalse: [Subtask markAndSignalAll; install.					Sensor cursorPoint: (Display viewportCenter).					ScheduledControllers restore.]].				Cursor normal show.	^justSnapped! !!Project methodsFor: 'controlling'!enter	"The user has chosen to change the context of the workspace to be that of	the receiver.  Change the ChangeSet, Transcript, and collection of scheduled	views accordingly."	ScheduledControllers discardCachedDisplayForms.	Smalltalk newChanges: projectChangeSet.	CurrentProject _ self.	TextCollector newTranscript: projectTranscript.	ControlManager newScheduler: projectWindows! !!ContextPart methodsFor: 'copying'!copy	"Answer a copy of the receiver, copy the instance variables and if 	the stack pointer is not nil, copy the indexable part."	| newContextPart |	newContextPart _ self species new: self size.	newContextPart method: sender pc: pc.	newContextPart stackp: stackp.	4 to: self class instSize do: [:index | newContextPart instVarAt: index put: (self instVarAt: index)].	stackp notNil ifTrue: [1 to: stackp do: [:index | newContextPart at: index put: (self at: index)]].	^newContextPart! !!MethodContext methodsFor: 'private'!setSender: aSender receiver: aReceiver method: aMethod arguments: args 	| eachArg |	sender _ aSender.	receiver _ aReceiver.	method _ aMethod.	pc _ method initialPC.	self stackp: method numTemps.	1 to: args size do: [:eachArg | self at: eachArg put: (args at: eachArg)]! !!ContextPart methodsFor: 'implementation dependent accessing'!at: index put: aValue 	"Put aValue at the specified location in the receiver unless the stack 	pointer is nil or the index is larger than the stack pointer."	stackp == nil ifTrue: [^aValue].	index <= stackp ifTrue: [^super at: index put: aValue].	^aValue!instVarAt: index put: aValue 	index = 3 ifTrue: [^self stackp: aValue]. "3 is the stack pointer"	^super instVarAt: index put: aValue!stackp: aValue 	"Set the stack pointer to the argument by primitively incrementing or 	decrementing the stack pointer."	| limitedValue |	stackp == nil ifTrue: [stackp _ 0].	aValue < stackp		ifTrue: 			[limitedValue _ 0 max: aValue.			[limitedValue < stackp]				whileTrue: [self primDecrementStackp]]		ifFalse: 			[limitedValue _ aValue min: self size.			[limitedValue > stackp]				whileTrue: [self primIncrementStackp]].	^aValue! !!MethodContext methodsFor: 'implementation dependent accessing'!at: anIndex put: aValue 	stackp == nil ifTrue: [self stackp: anIndex].	anIndex > stackp ifTrue: [self stackp: anIndex].	^super at: anIndex put: aValue!basicAt: anIndex put: aValue 	stackp == nil ifTrue: [self stackp: anIndex].	anIndex > stackp ifTrue: [self stackp: anIndex].	^super basicAt: anIndex put: aValue! !!ContextPart methodsFor: 'private'!tryPrimitiveFor: method receiver: receiver args: arguments 	"Simulate a primitive method, method for the receiver and arguments given	as arguments to this message.  Answer resuming the context if successful, else	answer the symbol, #primitiveFail."	| flag primIndex |	(flag _ method flags) < 5 ifTrue: [^#primitiveFail].	flag = 5 ifTrue: [^self push: receiver].	flag = 6 ifTrue: [^self push: (receiver instVarAt: method returnField + 1)].	flag = 7		ifTrue: 			[(primIndex _ method primitive) = 0 ifTrue: [^#primitiveFail].			^self doPrimitive: primIndex receiver: receiver args: arguments]! !!ContextPart class methodsFor: 'instance creation'!basicNew: anInteger 	"Answer a new instance of the receiver with the number of 	indexable variables specified by the argument, anInteger."	<primitive: 141>	^super basicNew: anInteger!new: anInteger 	"Answer a new instance of the receiver with the number of 	indexable variables specified by the argument, anInteger."	<primitive: 141>	^super new: anInteger! !!DisplayBitmap class methodsFor: 'instance creation'!basicNew: anInteger 	"Answer a new instance of the DisplayBitmap with the number of 	indexable variables specified by the argument, anInteger."	<primitive: 140>	^super basicNew: anInteger!new: anInteger 	"Answer a new instance of the DisplayBitmap with the number of 	indexable variables specified by the argument, anInteger."	<primitive: 140>	^super new: anInteger! !!SystemTracer methodsFor: 'initialize-release'!initClampedClasses: classSet	| x |	classSet isEmpty		ifTrue: [^self].	classSet do: 		[:class |		self clamp: class].	Smalltalk allBehaviorsDo: 		[:class | 		class superclass == nil &			((writeDict at: class) ~= #writeClamped:)		ifTrue: [class == Object 					ifFalse: [self error: class name , 'superclass is clamped!!!!!!!!']]].	SystemOrganization removeEmptyCategories.	Smalltalk newClassNames; noChanges.	Browser allInstancesDo: [:x | x updateCategories]! !Dictionary variableSubclass: #StrikeFontManager	instanceVariableNames: ''	classVariableNames: 'Emphases FontDirectory '	poolDictionaries: 'TextConstants '	category: 'Graphics-Support'!StrikeFontManager comment:'This class manages the central repository of all strike fonts. The Dictionary maps String names to StrikeFonts.'!!StrikeFontManager methodsFor: 'accessing'!at: aString ifAbsent: aBlock	"Answer the StrikeFont named aString else answer aBlock value. Check the name format."	self checkName: aString.	^super at: aString ifAbsent: aBlock!at: aString put: aStrikeFont	"Install aStrikeFont named aString; force the font name to correspond. Check the name format."	self checkName: aString.	aStrikeFont name: aString.	^super at: aString put: aStrikeFont!fontNames: anArray	"Answer an Array of StrikeFonts corresponding to anArray of String names. Load or synthesize the fonts if necessary."	| newArray |	newArray _ Array new: anArray size.	1 to: newArray size do: [:i |		newArray			at: i			put: (self install: (anArray at: i))].	^newArray!install: aString	"Install the font named aString if necessary. Load or synthesize the font if necessary. Complain if the font is missing."	^self install: aString ifAbsent: [self errorFontMissing: aString]!install: aString ifAbsent: aBlock	"Install the font named aString if necessary. Load or synthesize the font if necessary. Answer the result of evaluating aBlock if the font is missing."	| baseName emphasis font lastDigit |	"is it already installed or can it be loaded directly?"	(font _ self virtuallyAt: aString) notNil ifTrue: [^font].	"take name apart"	lastDigit _ aString findLast: [:char | char isDigit].	baseName _ aString copyFrom: 1 to: lastDigit.	emphasis _ aString copyFrom: lastDigit + 1 to: aString size.	(Emphases includesKey: emphasis) ifTrue: [		"try to synthesize Underline from Bold, Italic, or BoldItalic"		emphasis size = 2 ifTrue: [			(font _ self virtuallyAt: (baseName, (String with: emphasis first))) notNil ifTrue: [				^self copy: font name: aString emphasis: Underlined]].		"try to synthesize emphasis from Basal"		(font _ self virtuallyAt: baseName) notNil ifTrue: [			^self copy: font name: aString emphasis: (Emphases at: emphasis)]].	^aBlock value! !!StrikeFontManager methodsFor: 'private'!checkName: aString	(aString findLast: [:char | char isDigit]) = 0 ifTrue: [		self errorNameFormat: aString]!copy: aFont name: aString emphasis: anInteger	| newFont |	newFont _ aFont shallowCopy.	newFont emphasis: (newFont emphasis bitOr: anInteger).	^self at: aString put: newFont!errorFontMissing: aString	self error: 'font (', aString, ') missing'!errorNameFormat: aString	self error: 'font name (', aString, ') badly formatted'!virtuallyAt: aString	| aStrikeFont |	"is it already installed?"	^self at: aString ifAbsent: [		"can it be loaded?"		((FileDirectory directoryNamed: FontDirectory)			includesKey: aString, '.font')				ifTrue: [					Transcript cr; show: 'loading font ', aString.					aStrikeFont _ StrikeFont readFrom:						(FileStream oldFileNamed:							FontDirectory, aString, '.font').					aStrikeFont notNil ifTrue: [						self at: aString put: aStrikeFont].					aStrikeFont]				ifFalse: [nil]]! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!StrikeFontManager class	instanceVariableNames: ''!!StrikeFontManager class methodsFor: 'class initialization'!initialize	(Smalltalk includesKey: #FontManager) ifFalse: [		Smalltalk at: #FontManager put: self new].	Emphases _ Dictionary new.	Emphases		at: 'B' put: Bold;		at: 'I' put: Italic;		at: 'X' put: BoldItalic;		at: 'U' put: Underlined;		at: 'BU' put: (Bold bitOr: Underlined);		at: 'IU' put: (Italic bitOr: Underlined);		at: 'XU' put: (BoldItalic bitOr: Underlined).	FontDirectory _ '/fonts/'	"StrikeFontManager initialize"! !StrikeFontManager initialize!Dictionary variableSubclass: #TextStyleManager	instanceVariableNames: ''	classVariableNames: 'TextStyleMenu TextStyleNames '	poolDictionaries: ''	category: 'Graphics-Support'!TextStyleManager comment:'This class manages the central repository of all text styles. The Dictionary maps String names to TextStyles.'!!TextStyleManager methodsFor: 'accessing'!at: aString put: aTextStyle	"Install aTextStyle named aString."	| answer |	answer _ super at: aString put: aTextStyle.	self class flushMenus.	^answer!removeAssociation: anAssociation ifAbsent: aBlock	| answer |	answer _ super removeAssociation: anAssociation ifAbsent: [^aBlock value].	self class flushMenus.	^answer!removeKey: aString ifAbsent: aBlock	"Remove the TextStyle named aString else answer aBlock value."	| answer |	answer _ super removeKey: aString ifAbsent: [^aBlock value].	self class flushMenus.	^answer! !!TextStyleManager methodsFor: 'user interface'!fromUser	"Present a menu of TextStyles. Answer with the selected textStyle else nil."	| i aStream |	TextStyleMenu isNil ifTrue: [		(TextStyleNames _ self keys asSortedCollection) size = 0 ifTrue: [			Transcript cr; show: 'no text styles'.			^nil].		aStream _ WriteStream on: (String new: 128).		TextStyleNames do: [:aString | aStream nextPutAll: aString; cr].		aStream skip: -1.		TextStyleMenu _ PopUpMenu			labels: aStream contents			lines: nil			alignment: 0].	TextStyleMenu reset.	(i _ TextStyleMenu startUp) > 0		ifTrue: [^self at: (TextStyleNames at: i)]		ifFalse: [^nil]!fromUser: aBlock	"Present a menu of TextStyles. If one is selected, evaluate aBlock with the selected textStyle. Answer with the selected textStyle else nil."	| aTextStyle |	aTextStyle _ self fromUser.	aTextStyle notNil ifTrue: [aBlock value: aTextStyle].	^aTextStyle! !!TextStyleManager methodsFor: 'default text style'!changeDefaultTextStyle	"Present a menu of TextStyles. If one is selected, change the default TextStyle."	self fromUser: [:aTextStyle | self changeDefaultTextStyle: aTextStyle]!changeDefaultTextStyle: aTextStyle 	"Change the default TextStyle."	Cursor execute showWhile: [		"Change constants"		TextStyle default: aTextStyle.		TextList initialize.		"Initialize all of the system menus"		self initializeMenus.		"Tickle top views"		ScheduledControllers scheduledControllers do: [:aController |			aController view textStyle: aTextStyle].				"Restore display"		ScheduledControllers restore]! !!TextStyleManager methodsFor: 'menu initialization'!initializeMenus	"Initialize all of the system menus. New classes caching menus or other dependencies upon TextStyle should be added to the lists below."	"Flush menus"	#(		Browser		Debugger		DictionaryInspector		FileList		FileModel		Inspector		SyntaxError		TextStyleManager		) do: [:aSymbol | (Smalltalk at: aSymbol)			flushMenus].	"Initialize class variable menus"	#(		BitEditor		ChangeListController		FileList		FormEditor		NotifierController		ParagraphEditor		ProjectController		ScreenController		StandardSystemController		StringHolderController		) do: [:aSymbol | (Smalltalk at: aSymbol)			initialize].	"Initialize instance variable yellow button menus"	#(		BitEditor		ChangeController		ChangeListController		CRFillInTheBlankController		FillInTheBlankController		FormEditor		NotifierController		ParagraphEditor		ProjectController		ScreenController		StringHolderController		TextCollectorController		) do: [:aSymbol | (Smalltalk at: aSymbol)			allInstancesDo: [:anInstance |				anInstance initializeYellowButtonMenu]].	"Initialize instance variable blue button menus"	#(		NotifierController		StandardSystemController		) do: [:aSymbol | (Smalltalk at: aSymbol)			allInstancesDo: [:anInstance |				anInstance initializeBlueButtonMenu]]	"StyleManager initializeMenus"! !!TextStyleManager methodsFor: 'text style instance creation'!styleName: aStringbaseNames: anArray	"Create and install a TextStyle named aString with fonts specified by anArray of base String names. Each name represents a set of eight fonts (Basal, Bold, Italic, BoldItalic, Basal Underlined, Bold Underlined, Italic Underlined, and BoldItalic Underlined). The font order within the new TextStyle is best explained by the following example:		StyleManager		styleName: 'Pellucida Sans-Serif 10/12'		baseNames: #('PellucidaSans-Serif10' 'PellucidaSans-Serif12')generates a TextStyle with font order:	'PellucidaSans-Serif10'	'PellucidaSans-Serif10B'	'PellucidaSans-Serif10I'	'PellucidaSans-Serif10X'	'PellucidaSans-Serif12'	'PellucidaSans-Serif12B'	'PellucidaSans-Serif12I'	'PellucidaSans-Serif12X'	'PellucidaSans-Serif10U'	'PellucidaSans-Serif10BU'	'PellucidaSans-Serif10IU'	'PellucidaSans-Serif10XU'	'PellucidaSans-Serif12U'	'PellucidaSans-Serif12BU'	'PellucidaSans-Serif12IU'	'PellucidaSans-Serif12XU'Load or synthesize the fonts if necessary. Set the leading to zero. Answer the TextStyle."	^self		styleName: aString		fontNames: (self fontNamesFromBaseNames: anArray)!styleName: aStringbaseNames: anArraylead: leadInteger	"Similar to styleName:baseNames: but divide the leading equally between upper and lower leading (odd pixel on top)."	^self		styleName: aString		fontNames: (self fontNamesFromBaseNames: anArray)		lead: leadInteger!styleName: aStringbaseNames: anArrayupperLead: upperLeadIntegerlowerLead: lowerLeadInteger	"Similar to styleName:baseNames: but set the upper and lower leading."	^self		styleName: aString		fontNames: (self fontNamesFromBaseNames: anArray)		upperLead: upperLeadInteger		lowerLead: lowerLeadInteger!styleName: aStringfontNames: anArray	"Create and install a TextStyle named aString with fonts specified by anArray of explicit String names. Load or synthesize the fonts if necessary. Set the leading to zero. Answer the TextStyle."	^self		at: aString		put: (TextStyle fontArray: (FontManager fontNames: anArray))!styleName: aStringfontNames: anArraylead: leadInteger	"Similar to styleName:fontNames: but divide the leading equally between upper and lower leading (odd pixel on top)."	^self		styleName: aString		fontNames: anArray		upperLead: leadInteger - (leadInteger // 2)		lowerLead: leadInteger // 2!styleName: aStringfontNames: anArrayupperLead: upperLeadIntegerlowerLead: lowerLeadInteger	"Similar to styleName:fontNames: but set the upper and lower leading."	^(self		styleName: aString		fontNames: anArray)			upperLead: upperLeadInteger			lowerLead: lowerLeadInteger! !!TextStyleManager methodsFor: 'private'!fontNamesFromBaseNames: anArray	"See styleName:baseNames:"	| aStream |	aStream _ WriteStream on: (Array new: anArray size * 8).	anArray do: [:baseName | aStream		nextPut: baseName;		nextPut: baseName, 'B';		nextPut: baseName, 'I';		nextPut: baseName, 'X'].	anArray do: [:baseName | aStream		nextPut: baseName, 'U';		nextPut: baseName, 'BU';		nextPut: baseName, 'IU';		nextPut: baseName, 'XU'].	^aStream contents! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!TextStyleManager class	instanceVariableNames: ''!!TextStyleManager class methodsFor: 'class initialization'!flushMenus	TextStyleMenu _ nil	"TextStyleManager flushMenus"!initialize	(Smalltalk includesKey: #StyleManager) ifFalse: [		Smalltalk at: #StyleManager put: self new]	"TextStyleManager initialize"! !!TextStyleManager class methodsFor: 'instance creation'!new: anInteger	"Flush the style menu because the new instance will probably be installed as StyleManager."	self flushMenus.	^super new: anInteger! !TextStyleManager initialize!!TextStyle methodsFor: 'converting'!asListStyle	"Answer a copy of the receiver with lineGrid and baseline set for lists.	Temporary until later in this fileIn."	| newTextStyle |	newTextStyle _ self copy.	newTextStyle gridForFont: 1 withLead: 0.	^newTextStyle!asMenuStyle	"Answer a copy of the receiver with lineGrid and baseline set for menus.	Temporary until later in this fileIn."	| newTextStyle |	newTextStyle _ self copy.	newTextStyle gridForFont: 1 withLead: 0.	^newTextStyle! !!ProjectController class methodsFor: 'class initialization'!initialize	"Initialize the menu for the yellow mouse button."	ProjectYellowButtonMenu _ 		PopUpMenu			labels: 'againundocopycutpasteacceptcancelenter'			lines: #(2 5 7 ).	ProjectYellowButtonMessages _ 			#(again undo copySelection cut paste accept cancel enter )	"ProjectController initialize"! !ProjectController initialize!!DisplayText class methodsFor: 'instance creation'!text: aText 	"Answer an instance of me such that the text displayed is aText	according to the system's default textstyle."	^self new		setText: aText		textStyle: TextStyle default		offset: 0@0! !!TextList class methodsFor: 'instance creation'!onList: aList	^self onList: aList style: ListStyle!onList: aList style: aTextStyle	^self basicNew		compositionRectangle: DefaultCompositionRectangle		list: aList		style: aTextStyle asListStyle		offset: 0@0		outputMedium: #Display! !!TextList class methodsFor: 'class initialization'!initialize	ListStyle _ DefaultTextStyle asListStyle	"TextList initialize."! !TextList initialize!!TextStyle class methodsFor: 'constants'!default	"Answer the system default text style."	^DefaultTextStyle copy!default: aTextStyle	"Change the system default text style."	DefaultTextStyle _ aTextStyle! !!DisplayText methodsFor: 'accessing'!textStyle 	"Answer the style by which the receiver displays its text."	^textStyle! !!Paragraph methodsFor: 'composition'!recomposeWithTextStyle: aTextStyle	self compositionRectangle: DefaultCompositionRectangle		text: text		style: aTextStyle		offset: 0@0		outputMedium: #Display		fitWidth: true! !!TextList methodsFor: 'composition'!recomposeWithTextStyle: aTextStyle	self		compositionRectangle: DefaultCompositionRectangle		list: list		style: aTextStyle asListStyle		offset: 0@0		outputMedium: #Display! !!FileList methodsFor: 'file list'!fileListMenu 	fileName == nil ifTrue: [^nil].	fileMenu == nil ifTrue: [fileMenu _ #FileMenu].	fileMenu = #DirectoryMenu ifTrue: [^DirectoryMenu].	fileMenu = #FileMenu ifTrue: [^FileMenu].	fileMenu = #NewFileMenu ifTrue: [^NewFileMenu].	self error: 'File List menu error'!fileName: selection	"If selection is not nil, it is the name of a file to be viewed"	fileMenu _ nil.  "the pattern changed, so start over with the menu"	self setFileName: selection.	isReading _ false.	self changed: #text!resetFileMenu	fileMenu _ nil.	self fileListMenu! !!FileList methodsFor: 'new file list'!createDirectory	Cursor execute		showWhile: 			[fileMenu _ #DirectoryMenu.			Disk newDirectory: fileName.			isReading _ false.			self changed: #text]!createFile	Cursor execute		showWhile: 			[fileMenu _ #FileMenu.			Disk addKey: fileName.			isReading _ false.			self changed: #text]!newFileMenu	"The selected file name does not refer to an existing file.  	Reset the menu appropriately."	fileMenu _ #NewFileMenu! !!FileList methodsFor: 'directory list'!directoryMenu 	"Reset the fileMenu so that it contains items appropriate for directories."	fileMenu _ #DirectoryMenu! !Transcript cr; nextPutAll: 'collecting PopUpMenus and ActionMenus'; cr; endEntry.Smalltalk at: #PopUpMenuAllInstances put: PopUpMenu allInstances.Smalltalk at: #ActionMenuAllInstances put: ActionMenu allInstances!Object subclass: #PopUpMenu	instanceVariableNames: 'labelString textStyle lineArray frame form marker selection '	classVariableNames: ''	poolDictionaries: ''	category: 'Interface-Menus'!PopUpMenu comment:'I represent a list of items.  My instances are presented on the display screen in a rectangular area.  The user points to an item, pressing a mouse button;  the item is highlighted.  When the button is released, the highlighted item indicates the selection.Instance Variables:labelString	<String> or <Text> of menu itemstextStyle		<TextStyle> for displaying the characterslineArray		<Array> of integers indicating where lines should be drawn in the menuframe			<Quadrangle>form			<Form> containing the composed paragraphmarker		<Rectangle> used to highlight selectionselection		<Integer> index into menu items;  if 0, no selection'!!PopUpMenu methodsFor: 'accessing'!reset	marker _ frame inside topLeft		extent: frame inside width @ textStyle lineGrid.	selection _ 0! !!PopUpMenu methodsFor: 'marker adjustment'!markerTop: aPoint 	"Answer aPoint, gridded to lines in the receiver."	^(aPoint y - frame inside top truncateTo: textStyle lineGrid) + frame inside top! !!PopUpMenu methodsFor: 'private'!labels: aString textStyle: aTextStyle lines: anArray	| aParagraph |	labelString _ aString.	textStyle _ aTextStyle.	aParagraph _ Paragraph withText: aString asText style: textStyle.	lineArray _ anArray.	form _ aParagraph asForm.	frame _ Quadrangle new.	frame region: (aParagraph compositionRectangle expandBy: 2).	frame borderWidth: (1@1 corner: 3@3).	lineArray == nil ifFalse: [lineArray do: [:line |		form			fill: (0 @ (line * textStyle lineGrid) extent: (frame width @ 1)) 			mask: Form black]].	self reset!rescan	"cause me to be recreated for system changes"	labelString == nil 		ifFalse: [self labels: labelString textStyle: textStyle lines: lineArray]	"PopUpMenu allInstancesDo: [:x | x rescan]."! !!PopUpMenu class methodsFor: 'instance creation'!labels: aString	"Answer an instance of me whose items are in aString."	^self labels: aString lines: nil!labels: aString lines: anArray	"Answer an instance of me whose items are in aString, with lines drawn	after each item indexed by anArray."	^self labels: aString lines: anArray alignment: 2 "centered"!labels: aString lines: anArray alignment: anInteger	"Answer an instance of me whose items are in aString, with lines drawn	after each item indexed by anArray, with text style alignment specified	by anInteger."	| aTextStyle |	aTextStyle _ TextStyle default asMenuStyle.	aTextStyle alignment: anInteger.	^self new labels: aString textStyle: aTextStyle lines: anArray! !PopUpMenu removeSelector: #labels:font:lines:!Transcript cr; show: 'mutating PopUpMenus and ActionMenus'.PopUpMenuAllInstances do: [:aPopUpMenu |	aPopUpMenu instVarAt: 2 put: TextStyle default; rescan].Smalltalk removeKey: #PopUpMenuAllInstances.ActionMenuAllInstances do: [:anActionMenu |	anActionMenu instVarAt: 2 put: TextStyle default; rescan].Smalltalk removeKey: #ActionMenuAllInstances.Transcript cr; show: 'done'!Transcript cr; nextPutAll: 'collecting TextStyles'; cr; endEntry.Smalltalk at: #TextStyleAllInstances put: TextStyle allInstances!Object subclass: #TextStyle	instanceVariableNames: 'fontArray lineGrid baseline alignment firstIndent restIndent rightIndent tabsArray marginTabsArray outputMedium lineGridForLists baselineForLists lineGridForMenus baselineForMenus '	classVariableNames: ''	poolDictionaries: 'TextConstants '	category: 'Graphics-Support'!TextStyle comment:'TextStyle is the repository of information which may be shared by a number of paragraphs.  What values it contains are still the subject of some experimentation and experience.  Presently it is used only for display operations.Instance Variables:	fontArray<Array>  A collection of fonts available to the paragraph.  These may be either StrikeFonts or PressFonts.  The emphasis portion of a Text returns a value for indexing the font.	lineGrid	<Integer>  The amount to be added to the top of a line to find the top of the next line.  Will frequently be the greatest height in the fonts in fontArray.	baseline	<Integer>  The amount to be added to the top of a line to find the baseline of the line.  The baseline is the point from which the ascent of a font should rise.	alignment<Integer>  Indicates the mode for first level placement from the margins	-- 0=left flush, 1=centered, 2=right flush, 3=justified.	firstIndent<Integer>  Amount to inset from the left margin for the first line of a paragraph.  Initial value for paragraph associated with this TextStyle.	restIndent<Integer>  Amount to inset from the left margin for all but the first line of a paragraph.  Initial value for paragraph associated with this TextStyle.	rightIndent<Integer>  Amount to inset from the right margin for all the lines of the paragraph.  Initial value for paragraph associated with this TextStyle.	tabsArray<Array>  Tab stops.  Values are relative to the left margin of the paragraph.	marginTabsArray<Array>  Each value in the array is a tuple indicating an inset from the left and right margin of this paragraph.  Allows for inset paragraphs.	outputMedium<Symbol>  Currently only #Display.  Allows for use of TextStyle in both display and printing mode.	lineGridForLists<Integer>  Copied into <lineGrid> while constructing a list style.	baselineForLists<Integer>  Copied into <baseline> while constructing a list style.	lineGridForMenus<Integer>  Copied into <lineGrid> while constructing a menu style.	baselineForMenus<Integer>  Copied into <baseline> while constructing a menu style.'!!TextStyle reorganize!('accessing' alignment alignment: baseline baseline: baselineForLists baselineForLists: baselineForMenus baselineForMenus: defaultFont descent firstIndent firstIndent: fontArray fontArray: fontAt: fontAt:put: fontNamed: lineGrid lineGrid: lineGridForLists lineGridForLists: lineGridForMenus lineGridForMenus: nestingDepth outputMedium outputMedium: restIndent restIndent: rightIndent rightIndent: upperLead:lowerLead:)('converting' asListStyle asMenuStyle)('tabs and margins' clearIndents leftMarginTabAt: nextTabXFrom:leftMargin:rightMargin: rightMarginTabAt: tabWidth)('fonts and font indexes' flushFonts)('private' basalFontFor: boldFontFor: boldItalicFontFor: fontFor:face: gridForFont:withLead: isFontBold: isFontBoldItalic: isFontItalic: isFontSubscripted: isFontSuperscripted: isFontUnderlined: italicFontFor: marginTabAt:side: newFontArray: subscriptedFontFor: superscriptedFontFor: underlinedFontFor: unSubscriptedFontFor: unSuperscriptedFontFor: unUnderlinedFontFor:)!!TextStyle methodsFor: 'accessing'!alignment	"Answer the code for the current setting of the alignment."	^alignment!alignment: anInteger 	"Set the current setting of the alignment to be anInteger--	0=left flush, 1=centered, 2=right flush, 3=justified."	alignment _ anInteger \\ (Justified + 1)!baseline	"Answer the distance from the top of the line to the bottom of most of the characters (by convention, bottom of A)."	^baseline!baseline: anInteger 	"Set the distance from the top of the line to the bottom of most of the characters."	baseline _ anInteger!baselineForLists	^baselineForLists!baselineForLists: anInteger 	baselineForLists _ anInteger!baselineForMenus	^baselineForMenus!baselineForMenus: anInteger 	baselineForMenus _ anInteger!defaultFont	"Answer the first font in the font family."	^self fontAt: 1!descent	"Answer the distance from the bottom of the line to the bottom of most of the characters (by convention, bottom of A)."	^self lineGrid - self baseline!firstIndent	"Answer the horizontal indenting of the first line of a paragraph in the style of the receiver."	^firstIndent!firstIndent: anInteger 	"Set the horizontal indenting of the first line of a paragraph in the style of the receiver to be anInteger."	firstIndent _ anInteger!fontArray	^fontArray!fontArray: anArray	"Install anArray of fonts; recompute baseline and lineGrid."	fontArray _ anArray.	self upperLead: 0 lowerLead: 0!fontAt: index 	| fontIndex |	fontIndex _ index.	fontIndex > fontArray size		ifTrue:	[fontIndex _ fontArray size].	fontIndex < 0		ifTrue:	[fontIndex _ 1].	((fontArray at: fontIndex) isMemberOf: StrikeFont)		ifTrue: [^fontArray at: fontIndex].	((fontArray at: 1)		isMemberOf: StrikeFont)			ifTrue: [^fontArray at: 1].	self error: 'No valid fonts in font array'.!fontAt: index put: font 	fontArray at: index put: font!fontNamed: aString	(1 to: fontArray size)		do:	[:faceFontIndex |			aString = (fontArray at: faceFontIndex) name			ifTrue:	[^faceFontIndex]].	^ self basalFontFor: 1!lineGrid	"Answer the relative space between lines of a paragraph in the style of the receiver."	^lineGrid!lineGrid: anInteger 	"Set the relative space between lines of a paragraph in the style of the receiver to be anInteger."	lineGrid _ anInteger!lineGridForLists	^lineGridForLists!lineGridForLists: anInteger 	lineGridForLists _ anInteger!lineGridForMenus	^lineGridForMenus!lineGridForMenus: anInteger 	lineGridForMenus _ anInteger!nestingDepth	"Number of entries in the marginTabsArray"	^marginTabsArray size!outputMedium	"Answer the outputMedium for this style"	^outputMedium!outputMedium: aSymbol	"Set the outputMedium for this style  (currently only Display)"	aSymbol ~= #Display ifTrue: [self error: 'only Display']!restIndent	"Answer the indent for all but the first line of a paragraph in the style of the receiver."	^restIndent!restIndent: anInteger 	"Set the indent for all but the first line of a paragraph in the style of the receiver to be anInteger."	restIndent _ anInteger!rightIndent	"Answer the right margin indent for the lines of a paragraph in the style of the receiver."	^rightIndent!rightIndent: anInteger 	"Answer the right margin indent for the lines of a paragraph in the style of the receiver to be anInteger."	rightIndent _ anInteger!upperLead: upperLeadInteger lowerLead: lowerLeadInteger	"Force style to suit entire font array."	| maxAscent maxDescent |	maxAscent _ 0.	maxDescent _ 0.	fontArray do: [:font |		maxAscent _ maxAscent max: font ascent.		maxDescent _ maxDescent max: font descent].	self baseline: upperLeadInteger + maxAscent.	self lineGrid: upperLeadInteger + maxAscent + maxDescent + lowerLeadInteger! !!TextStyle methodsFor: 'converting'!asListStyle	"Answer a copy of the receiver with lineGrid and baseline set for lists."	| newTextStyle |	newTextStyle _ self copy.	newTextStyle		lineGrid: self lineGridForLists;		baseline: self baselineForLists.	^newTextStyle!asMenuStyle	"Answer a copy of the receiver with lineGrid and baseline set for menus."	| newTextStyle |	newTextStyle _ self copy.	newTextStyle		lineGrid: self lineGridForMenus;		baseline: self baselineForMenus.	^newTextStyle! !!TextStyle methodsFor: 'tabs and margins'!clearIndents	"Reset all the margin (index) settings to be 0."	self firstIndent: 0.	self restIndent: 0.	self rightIndent: 0!leftMarginTabAt: marginIndex 	"Set the 'nesting' level of left margin indents of the paragraph in the style of the receiver to be marginIndex."	^self marginTabAt: marginIndex side: 1		"1= leftSide, 2 = rightSide" 	"The marginTabsArray is an Array of tuples.  The Array is indexed according 	to the marginIndex, the 'nesting' level of the requestor."!nextTabXFrom: anX leftMargin: leftMargin rightMargin: rightMargin	"Tab stops are distances from the leftMargin.  Set the distance into anX normalized for the paragraph's left margin.  Scale makes the routine usable for printing.  On the display the scale is 1."	| normalizedX tabX scale |	scale _ 1.	normalizedX _ anX - leftMargin.	1 to: tabsArray size do: 					[:i | (tabX _ ((tabsArray at: i) * scale) asInteger) > normalizedX 						ifTrue: [^leftMargin + tabX min: rightMargin]].	^rightMargin!rightMarginTabAt: marginIndex 	"Set the 'nesting' level of right margin indents of the paragraph in the style of the receiver to be marginIndex."	^self marginTabAt: marginIndex side: 2		"1= leftSide, 2 = rightSide" 	"The marginTabsArray is an Array of tuples.  The Array is indexed according 	to the marginIndex, the 'nesting' level of the requestor."!tabWidth	"Answer the width of standard tab."	^DefaultTab! !!TextStyle methodsFor: 'fonts and font indexes'!flushFonts	"Clean out the fonts, an aid when snapshoting claims too many are holding onto Display."	BinaryChoice		message: 'This is very dangerous and should only be used if you know whatyou are doing and understand the system integrity issue.' 		displayAt: Display boundingBox center		ifTrue: [1 to: fontArray size do: [:index | fontArray at: index put: nil]]		ifFalse: [Transcript cr; show: 'flushFonts cancelled']		"TextStyle default flushFonts."! !!TextStyle methodsFor: 'private'!basalFontFor: fontIndex	^self fontFor: fontIndex face: Basal!boldFontFor: fontIndex	^self fontFor: fontIndex face: Bold!boldItalicFontFor: fontIndex	^self fontFor: fontIndex face: BoldItalic!fontFor: fontIndex face: face	| currentFont currentFamilySizeFace family size emphasis newFamilySizeFace |	currentFamilySizeFace _ (currentFont _ fontArray at: fontIndex) familySizeFace.	family _ currentFamilySizeFace at: FamilyName.	size _ currentFamilySizeFace at: PointSize.	emphasis _ currentFont emphasis.	(1 to: fontArray size)		do: [:faceFontIndex |			newFamilySizeFace _ (currentFont _ fontArray at: faceFontIndex) familySizeFace.			((((family = (newFamilySizeFace at: FamilyName))				and: [size = (newFamilySizeFace at: PointSize)])					and: [face = (newFamilySizeFace at: Face)])						and: [(emphasis bitAnd: NonFaceEmphasisMask) =								(currentFont emphasis bitAnd: NonFaceEmphasisMask)])				ifTrue:	[^faceFontIndex]].	^fontIndex!isFontBold: fontIndex		 ^((fontArray at: fontIndex) familySizeFace at: Face) = Bold!isFontBoldItalic: fontIndex		 ^((fontArray at: fontIndex) familySizeFace at: Face) = BoldItalic!isFontItalic: fontIndex		 ^((fontArray at: fontIndex) familySizeFace at: Face) = Italic!isFontSubscripted: fontIndex	^(((self fontAt: fontIndex) emphasis) bitAt: SubscriptedBit) = 1!isFontSuperscripted: fontIndex	^(((self fontAt: fontIndex) emphasis) bitAt: SuperscriptedBit) = 1!isFontUnderlined: fontIndex	^(((self fontAt: fontIndex) emphasis) bitAt: UnderlinedBit) = 1!italicFontFor: fontIndex	^self fontFor: fontIndex face: Italic!newFontArray: anArray	self fontArray: anArray.	alignment _ 0.	firstIndent _ 0.	restIndent _ 0.	rightIndent _ 0.	tabsArray _ DefaultTabsArray.	marginTabsArray _ DefaultMarginTabsArray.	outputMedium _ #Display.	lineGridForLists _ lineGrid.	baselineForLists _ baseline.	lineGridForMenus _ lineGrid.	baselineForMenus _ baseline!subscriptedFontFor: fontIndex	| name thisFont subscriptedFontIndex subscriptedFont |	name _ (thisFont _ fontArray at: fontIndex) name.	(1 to: fontArray size)		do: [:subscriptedFontIndex |			(subscriptedFont _				fontArray at: subscriptedFontIndex) name = name				ifTrue:	[(((subscriptedFont emphasis bitAt: SubscriptedBit) = 1)							and: [(thisFont emphasis bitAt: Underlined) =									(subscriptedFont emphasis bitAt: Underlined)])							ifTrue:	[^subscriptedFontIndex]]].	^fontIndex!superscriptedFontFor: fontIndex	| name thisFont superscriptedFontIndex superscriptedFont |	name _ (thisFont _ fontArray at: fontIndex) name.	(1 to: fontArray size)		do: [:superscriptedFontIndex |			(superscriptedFont _				fontArray at: superscriptedFontIndex) name = name				ifTrue:	[(((superscriptedFont emphasis bitAt: SuperscriptedBit) = 1)							and: [(thisFont emphasis bitAt: Underlined) =									(superscriptedFont emphasis bitAt: Underlined)])							ifTrue:	[^superscriptedFontIndex]]].	^fontIndex!underlinedFontFor: fontIndex	| name thisFont underlinedFontIndex underlinedFont |	name _ (thisFont _ fontArray at: fontIndex) name.	(1 to: fontArray size)		do: [:underlinedFontIndex |			(underlinedFont _				fontArray at: underlinedFontIndex) name = name				ifTrue:	[(((underlinedFont emphasis bitAt: UnderlinedBit) = 1)							and: [(thisFont emphasis bitAnd: SubSuperscriptMask) =									(underlinedFont emphasis bitAnd: SubSuperscriptMask)])							ifTrue:	[^underlinedFontIndex]]].	^fontIndex!unSubscriptedFontFor: fontIndex	| name thisFont unSubscriptedFontIndex unSubscriptedFont |	name _ (thisFont _ fontArray at: fontIndex) name.	(1 to: fontArray size)		do: [:unSubscriptedFontIndex |			(unSubscriptedFont _				fontArray at: unSubscriptedFontIndex) name = name				ifTrue:	[(((unSubscriptedFont emphasis bitAt: SubscriptedBit) = 0)							and: [(thisFont emphasis bitAt: Underlined) =									(unSubscriptedFont emphasis bitAt: Underlined)])							ifTrue:	[^unSubscriptedFontIndex]]].	^fontIndex!unSuperscriptedFontFor: fontIndex	| name thisFont unSuperscriptedFontIndex unSuperscriptedFont |	name _ (thisFont _ fontArray at: fontIndex) name.	(1 to: fontArray size)		do: [:unSuperscriptedFontIndex |			(unSuperscriptedFont _				fontArray at: unSuperscriptedFontIndex) name = name				ifTrue:	[(((unSuperscriptedFont emphasis bitAt: SuperscriptedBit) = 0)							and: [(thisFont emphasis bitAt: Underlined) =									(unSuperscriptedFont emphasis bitAt: Underlined)])							ifTrue:	[^unSuperscriptedFontIndex]]].	^fontIndex!unUnderlinedFontFor: fontIndex	| name thisFont unUnderlinedFontIndex unUnderlinedFont |	name _ (thisFont _ fontArray at: fontIndex) name.	(1 to: fontArray size)		do: [:unUnderlinedFontIndex |			(unUnderlinedFont _				fontArray at: unUnderlinedFontIndex) name = name				ifTrue:	[(((unUnderlinedFont emphasis bitAt: UnderlinedBit) = 0)							and: [(thisFont emphasis bitAnd: SubSuperscriptMask) =									(unUnderlinedFont emphasis bitAnd: SubSuperscriptMask)])							ifTrue:	[^unUnderlinedFontIndex]]].	^fontIndex! !Transcript cr; show: 'mutating TextStyles'.TextStyleAllInstances do: [:aTextStyle |	aTextStyle lineGridForLists: aTextStyle lineGrid.	aTextStyle baselineForLists: aTextStyle baseline.	aTextStyle lineGridForMenus: aTextStyle lineGrid.	aTextStyle baselineForMenus: aTextStyle baseline].Smalltalk removeKey: #TextStyleAllInstances.Transcript cr; nextPutAll: 'done'; cr; endEntry!!View methodsFor: 'text style'!textStyle: aTextStyle	subViews do: [:aSubView | aSubView textStyle: aTextStyle]! !View subclass: #DisplayTextView	instanceVariableNames: 'rule mask editParagraph centered textStyle '	classVariableNames: ''	poolDictionaries: ''	category: 'Graphics-Views'!DisplayTextView comment:'I represent a view of an instance of DisplayText.Instance Variables:	rule <Integer> according to which character display behaves:  equal over, under, 		and reverse.	mask <Form> with which each character is combined by the display scanner		before applying the rule.	editParagraph <Paragraph> the composed text ready for display	textStyle <TextStyle> the style for all text in this view'!!DisplayTextView reorganize!('initialize-release' initialize)('accessing' centered isCentered mask mask: rule rule:)('controller access' defaultController defaultControllerClass)('window access' defaultWindow window:)('model access' model:)('displaying' display displayView)('deEmphasizing' deEmphasizeView deEmphasizeView:andClip:)('text style' textStyle textStyle:)('private' centerText defaultMask defaultRule paragraphInset positionText)!!DisplayTextView methodsFor: 'initialize-release'!initialize	super initialize.	centered _ false.	textStyle _ TextStyle default! !!DisplayTextView methodsFor: 'text style'!textStyle	^textStyle!textStyle: aTextStyle	textStyle _ aTextStyle.	self unlock.	editParagraph recomposeWithTextStyle: aTextStyle.	self centerText! !View subclass: #ListView	instanceVariableNames: 'list selection topDelimiter bottomDelimiter lineSpacing isEmpty textStyle '	classVariableNames: ''	poolDictionaries: ''	category: 'Interface-Lists'!ListView comment:'I am an abstract View of a list of items.  I provide support for storing a selection of one item, as well as formatting the list for presentation on the screen.  My default controller is ListController.Instance Variables:	list				<Array> of Strings, each one an item	selection		<Integer> index into the array, list	topDelimiter	<String>, usually  ------------, indicating the top of the list	bottomDelimiter	<String>, usually  ------------, indicating the bottom of the list	lineSpacing		<Integer> the amount of extra space between line items	isEmpty			<Boolean> true if the list is empty	textStyle		<TextStyle> the style for all text in this view'!!ListView reorganize!('initialize-release' initialize)('list access' list list: reset resetAndDisplayView)('delimiters' bottomDelimiter bottomDelimiter: noBottomDelimiter noTopDelimiter topDelimiter topDelimiter:)('displaying' display displayView displayView:)('deEmphasizing' deEmphasizeView deEmphasizeView:andClip: emphasizeView)('controller access' defaultControllerClass)('display box access' boundingBox)('clipping box access' clippingBox)('selecting' deselect deselectAndClip: displaySelectionBox findSelection: isSelectionBoxClipped maximumSelection minimumSelection moveSelectionBox: selection selectionBox selectionBoxOffset)('updating' update:)('text style' textStyle textStyle:)('private' positionList wrappingBox)!!ListView methodsFor: 'initialize-release'!initialize	super initialize.	insideColor _ Form white.	topDelimiter _ '------------'.	bottomDelimiter _ '------------'.	lineSpacing _ 0.	isEmpty _ true.	textStyle _ TextStyle default! !!ListView methodsFor: 'list access'!list: itemCollection 	"Create the textList corresponding to the items in itemCollection."	isEmpty _ itemCollection isNil.	list _ TextList		onList:	 (topDelimiter == nil			ifTrue: [itemCollection]			ifFalse: [(Array with: topDelimiter) ,				itemCollection ,				(Array with: bottomDelimiter)])		style: textStyle.	selection _ 0.	self positionList! !!ListView methodsFor: 'selecting'!selectionBox	"Answer the rectangle in which the current selection is displayed."	^(self insetDisplayBox left @ (list compositionRectangle top + self selectionBoxOffset) 		extent: self insetDisplayBox width @ list lineGrid)		insetBy: (Rectangle left: 1 right: 1 top: 0 bottom: 0)! !!ListView methodsFor: 'text style'!textStyle	^textStyle!textStyle: aTextStyle	textStyle _ aTextStyle.	self unlock.	list recomposeWithTextStyle: aTextStyle! !View subclass: #StandardSystemView	instanceVariableNames: 'labelFrame labelText isLabelComplemented savedSubViews minimumSize maximumSize windowForm windowFormFlag textStyle '	classVariableNames: ''	poolDictionaries: ''	category: 'Interface-Support'!StandardSystemView comment:'I represent a view that has a label above its top left corner.  The text in the label identifies the kind of view.  In addition to a label, I add control over the maximum and minimum size of the display box of my instance.  My default controller is StandardSystemController.  The elements of ScheduledControllers, the sole instance of ControlManager, usually contain controllers for instances of me.Instance Variables:	labelFrame				<Quadrangle>	labelText				<Paragraph>	isLabelComplemented	<Boolean> true if the label is complemented	savedSubViews			<Array> of Views	minimumSize				<Point> representing minimum width and height	maximumSize			<Point> representing maximum width and height	windowForm 			<Form> representing a picture of the view.	windowFormFlag 		<Symbol> indicating the status of the windowForm, as follows:								#unused if the window form not to be used								#updated if a change has occurred													#saved if form is up to date	textStyle				<TextStyle> the style for all text in this view'!!StandardSystemView reorganize!('initialize-release' initialize release)('testing' containsPoint: isCollapsed)('label access' deEmphasizeLabel emphasizeLabel label label: label:style: labelDisplayBox labelFrame labelFrame: resetLabel: resetLabel:style: resetLabelFlag)('size' maximumSize maximumSize: minimumSize minimumSize:)('framing' collapse erase expand getFrame resize resizeMinimumCenteredAt:)('controller access' defaultControllerClass)('saved window form' deleteDisplayForm displayForm saveDisplayForm setStatusDisplayForm: validDisplayForm)('displaying' displayBorder displayClippedTitle: displayClippedView: displayEmphasized displayEmphasizedForm displayView displayView: restore:)('deEmphasizing' deEmphasize deEmphasizeView)('clipping box access' clippingBox)('text style' textStyle textStyle:)('private' reverseLabel)!!StandardSystemView methodsFor: 'initialize-release'!initialize	super initialize.	self insideColor: Form lightGray.	labelFrame _ Quadrangle new.	labelFrame region: (Rectangle origin: 0 @ 0 extent: 50 @ 20).	labelFrame insideColor: Form white.	labelFrame		borderWidthLeft: 2		right: 2		top: 2		bottom: 0.	self label: nil.	isLabelComplemented _ false.	minimumSize _ 50 @ 50.	maximumSize _ Display extent.	textStyle _ TextStyle default! !!StandardSystemView methodsFor: 'label access'!label: aString	"Set aString to be the receiver's label in the receiver's style."	self label: aString style: textStyle!label: aString style: aTextStyle	"Set aString to be the receiver's label in a specified style."	aString == nil 		ifTrue: 			[labelText _ nil.			labelFrame region: (0 @ 0 extent: 0 @ 0)]		ifFalse:			[labelText _ Paragraph withText: aString asText style: aTextStyle.			labelFrame region:				(0 @ 0 extent: labelText boundingBox width + 8 @ (labelText lineGrid + 4))]!resetLabel: aString	"Display the title tab in the receiver's style."	self resetLabel: aString style: textStyle!resetLabel: aString style: aTextStyle	"Display the title tab in a specified style."	Display gray: self labelDisplayBox region.	ScheduledControllers restoreWithin: (OrderedCollection with: self labelDisplayBox).	self label: aString style: aTextStyle.	self isCollapsed ifTrue:		[self window: (self inverseDisplayTransform: self labelDisplayBox region)].	self displayView.	isLabelComplemented		ifTrue: 			[self reverseLabel]! !!StandardSystemView methodsFor: 'text style'!textStyle	^textStyle!textStyle: aTextStyle	textStyle _ aTextStyle.	self unlock.	self label: self label.	self isCollapsed		ifTrue: [			self window: (self inverseDisplayTransform: self labelDisplayBox region).			savedSubViews do: [:aSubView | aSubView textStyle: aTextStyle]]		ifFalse: [super textStyle: aTextStyle]! !!NotifierView methodsFor: 'text style'!textStyle: aTextStyle	super textStyle: aTextStyle.	contents textStyle: aTextStyle! !View subclass: #StringHolderView	instanceVariableNames: 'displayContents textStyle '	classVariableNames: ''	poolDictionaries: ''	category: 'Interface-Text'!StringHolderView comment:'I am a View of a String that is an aspect of a more structured object.  This String should not be changed by any editing unless the user issues the accept command.  Thus my instances provide a working copy of the String.  This copy is edited.  When the user issues the accept command, the String is copied from the working version;  or if the user issues the cancel command, the working version is restored from the String.  StringHolderController is my default controller.  It is initialized specially by passing the string viewed which is then converted to a Paragraph for editing.Instance Variables:	displayContents	<String> the working copy	textStyle			<TextStyle> the style for all text in this view'!!StringHolderView reorganize!('initialize-release' initialize)('updating' update: updateDisplayContents updateRequest)('controller access' defaultController defaultControllerClass displayContents)('displaying' display displayView displayView: positionDisplayContents)('model access' editString: model:)('deEmphasizing' deEmphasizeView deEmphasizeView:andClip:)('text style' textStyle textStyle:)('private' getContents paragraphInset)!!StringHolderView methodsFor: 'initialize-release'!initialize	super initialize.	displayContents _ '' asParagraph.	self insideColor: Form white.	textStyle _ TextStyle default! !!StringHolderView methodsFor: 'model access'!editString: aString 	"The paragraph to be displayed is created from the characters in aString."	displayContents _ Paragraph				withText: aString asText				style: textStyle				compositionRectangle: (self insetDisplayBox insetBy: self paragraphInset)				clippingRectangle: self insetDisplayBox.	(self controller isKindOf: ParagraphEditor)		ifTrue: [controller changeParagraph: displayContents]! !!StringHolderView methodsFor: 'text style'!textStyle	^textStyle!textStyle: aTextStyle	textStyle _ aTextStyle.	self unlock.	displayContents textStyle: aTextStyle! !View subclass: #SwitchView	instanceVariableNames: 'complemented label selector keyCharacter highlightForm arguments textStyle '	classVariableNames: ''	poolDictionaries: ''	category: 'Interface-Menus'!SwitchView comment:'I am a view of a Switch.  My instances have labels and display modes (set to "normal" or "complemented").  When one of my instances is displayed in complemented mode, its inside color is reversed.  The value of the display mode corresponds to the value of the model so that, for example, when a Switch is off, its SwitchView is displayed with black text (for the label) on a white background, and when the Switch is off, its SwitchView is displayed with white text on a black background.  My instances have a key character that can be used for switching on or off.  Highlighting can be done specially using a stored form, rather than simply changing all black bits to white and vice versa.  My default controller is SwitchController.Instance Variables:		complemented		<Boolean> true if the model is on		label				<DisplayObject>, for example, a DisplayText or a Form		selector				<Symbol>		keyCharacter		<Character>		highlightForm		<Form>		arguments			<Array>		textStyle			<TextStyle> the style for all text in this view'!!SwitchView reorganize!('initialize-release' initialize release)('accessing' arguments arguments: highlightForm: key:)('testing' containsKey:)('controller access' defaultControllerClass)('window access' defaultWindow window:)('displaying' display displayComplemented displayNormal displaySpecial displaySpecialComplemented displayView)('updating' update:)('label access' centerLabel label label:)('indicating' indicatorOnDuring: indicatorReverse)('selector' interrogateModel selector selector:)('deEmphasizing' deEmphasizeView deEmphasizeView:andClip:)('text style' textStyle textStyle:)!!SwitchView methodsFor: 'initialize-release'!initialize	super initialize.	insideColor _ Form white.	complemented _ false.	label _ nil.	selector _ #isOn.	arguments _ #().	textStyle _ TextStyle default! !!SwitchView methodsFor: 'displaying'!displayView	"Does the standard View actions and, in addition, displays the receiver's 	label based on the current display transformation and inset display box."	self clearInside.	label == nil		ifFalse: 			[label				displayOn: Display				transformation: self displayTransformation				clippingBox: self insetDisplayBox				fixedPoint: label boundingBox center]! !!SwitchView methodsFor: 'text style'!textStyle	^textStyle!textStyle: aTextStyle	textStyle _ aTextStyle.	self unlock.	(label isKindOf: Paragraph)		ifTrue: [			label recomposeWithTextStyle: aTextStyle.			self centerLabel]		ifFalse: [(label class canUnderstand: #textStyle:) ifTrue: [			label textStyle: aTextStyle.			self centerLabel]]! !View subclass: #TextView	instanceVariableNames: 'partMsg acceptMsg menuMsg textStyle '	classVariableNames: ''	poolDictionaries: ''	category: 'Interface-Text'!!TextView reorganize!('initialize-release' initialize newText:)('controller access' defaultControllerClass)('displaying' display displayView displayView:)('updating' update: updateRequest)('deEmphasizing' deEmphasizeView deEmphasizeView:andClip:)('emphasizing' emphasizeView)('adaptor' accept:from: getText yellowButtonMenu)('text style' textStyle textStyle:)('private' on:aspect:change:menu:)!!TextView methodsFor: 'initialize-release'!initialize	super initialize.	self insideColor: Form white.	textStyle _ TextStyle default! !!TextView methodsFor: 'text style'!textStyle	^textStyle!textStyle: aTextStyle	textStyle _ aTextStyle.	self unlock.	self controller paragraph textStyle: aTextStyle! !Transcript cr; show: 'changing default text style'.StyleManager changeDefaultTextStyle: TextStyle default!Transcript cr; nextPutAll: 'collecting StrikeFonts'; cr; endEntry.Smalltalk at: #StrikeFontAllInstances put: StrikeFont allInstances!Object subclass: #StrikeFont	instanceVariableNames: 'xTable glyphs name stopConditions type minAscii maxAscii maxWidth strikeLength ascent descent xOffset raster subscript superscript emphasis ascentForStdAsciiChars descentForStdAsciiChars '	classVariableNames: ''	poolDictionaries: 'TextConstants '	category: 'Graphics-Support'!StrikeFont comment:'Instance Variables:	xTable	<Array>  Of left x-coordinate of character in glyphs.	glyphs	<Form>  Containing bits representing the characters.	name	<String>  Name of this font.	stopConditions	<Array>  Of selectors to be performed in scanning text.	type	<Integer>  Code for strike fonts files.	minAscii, maxAscii	<Integer>  Giving range supported by this font.	maxWidth	<Integer>  Width of widest char. Not presently used, but may be for font modification.	strikeLength	<Integer>  Not used.	ascent, descent	<Integer>  Max extent of chars above and below the baseline	xOffset	<Integer>  For kerning (not presently used)	raster	<Integer>  Specifies layout of the glyphs form	subscript, superscript	<Integer>  Further vertical offset relative to baseline	emphasis	<Integer>  code for synthetic bold, italic, underline, strike-out	ascentForStdAsciiChars, descentForStdAsciiChars <Integer>  Max extent of chars above and below the baseline for ADE 32 through 126.StrikeFonts are a compact encoding of a set of Forms corresponding to characters in the ASCII character set.  All the forms are placed side by side in a large form whose height is the font height, and whose width is the sum of all the character widths.  The xTable gives the left-x coordinates of the subForms corresponding to the characters.'!!StrikeFont reorganize!('accessing' ascent ascentForStdAsciiChars characterForm: descent descentForStdAsciiChars familySizeFace glyphs height maxAscii maxWidth minAscii name name: raster stopConditions subscript subscript: superscript superscript: widthOf: xTable)('converting' asTextStyle)('testing' checkCharacter:)('displaying' characters:in:displayAt:clippedBy:rule:mask: composeWord:in:beginningAt: displayLine:at:)('emphasis' emphasis emphasis: emphasized: emphasized:named:)('printing' printOn:)('private' ascent: computeAscentDescentForStdAsciiChars glyphs:)!!StrikeFont methodsFor: 'accessing'!ascentForStdAsciiChars	"Answer the font's maximum extent of characters above the baseline for ADE 32 through 126."	ascentForStdAsciiChars isNil ifTrue: [		self computeAscentDescentForStdAsciiChars].	^ascentForStdAsciiChars!descentForStdAsciiChars	"Answer the font's maximum extent of characters below the baseline for ADE 32 through 126."	descentForStdAsciiChars isNil ifTrue: [		self computeAscentDescentForStdAsciiChars].	^descentForStdAsciiChars!familySizeFace	"Return an array with familyName <String> pointSize <Integer> faceCode <Integer>"	| firstDigit lastDigit |	firstDigit _ name findFirst: [:char | char isDigit].	lastDigit _ name findLast: [:char | char isDigit].	^Array with: (name copyFrom: 1 to: firstDigit-1)		with: (Integer readFromString: (name copyFrom: firstDigit to: lastDigit))		with: (#('B' 'I' 'X') indexOf:					(name copyFrom: lastDigit+1 to: name size))" (1 to: 12) collect: [:x | (TextStyle default fontAt: x) familySizeFace] "! !!StrikeFont methodsFor: 'converting'!asTextStyle	^TextStyle fontArray: (Array with: self)! !!StrikeFont methodsFor: 'private'!computeAscentDescentForStdAsciiChars	"Compute {ascent,descent}ForStdAsciiChars."	| aBitBlt glyphForm height maxStdAscii minStdAscii scanLineForm width y |	minStdAscii _ (32 min: maxAscii + 1) max: minAscii.	maxStdAscii _ (126 min: maxAscii + 1) max: minAscii.	width _ (xTable at: maxStdAscii + 2) - (xTable at: minStdAscii + 1).	height _ glyphs height.	glyphForm _ Form extent: width @ height.	glyphForm		copyBits: (((xTable at: minStdAscii + 1) @ 0) extent: width @ height)		from: glyphs		at: 0@0		clippingBox: glyphForm boundingBox		rule: Form over		mask: Form black.	scanLineForm _ Form extent: width @ 1.	aBitBlt _ BitBlt		destForm: scanLineForm		sourceForm: glyphForm		halftoneForm: nil		combinationRule: Form over		destOrigin: 0@0		sourceOrigin: 0 @ (y _ 0)		extent: scanLineForm extent		clipRect: scanLineForm boundingBox.	[aBitBlt copyBits.	scanLineForm isAllWhite and: [y < height]]		whileTrue: [aBitBlt sourceY: (y _ y + 1)].	ascentForStdAsciiChars _ self ascent - y.	aBitBlt sourceY: (y _ height - 1).	[aBitBlt copyBits.	scanLineForm isAllWhite and: [y > 0]]		whileTrue: [aBitBlt sourceY: (y _ y - 1)].	descentForStdAsciiChars _ self descent - (height - 1 - y)! !Transcript cr; show: 'mutating StrikeFonts'.StrikeFontAllInstances do: [:aFont |	aFont computeAscentDescentForStdAsciiChars].Smalltalk removeKey: #StrikeFontAllInstances.Transcript cr; nextPutAll: 'done'; cr; endEntry!!TextStyle methodsFor: 'accessing'!fontArray: anArray	"Install anArray of fonts; recompute lineGrids and baselines."	fontArray _ anArray.	self upperLead: 0 lowerLead: 0.	self listStyleForFont: 1 upperLead: 1 lowerLead: 1.	self menuStyleForFont: 1 upperLead: 2 lowerLead: 1! !!TextStyle methodsFor: 'converting'!listStyleForFont: fontIndexupperLead: upperLeadIntegerlowerLead: lowerLeadInteger	"Force list style to suit one font."	| font |	font _ self fontAt: fontIndex.	self baselineForLists: upperLeadInteger +		font ascentForStdAsciiChars.	self lineGridForLists: self baselineForLists +		font descentForStdAsciiChars +		lowerLeadInteger!menuStyleForFont: fontIndexupperLead: upperLeadIntegerlowerLead: lowerLeadInteger	"Force menu style to suit one font."	| font |	font _ self fontAt: fontIndex.	self baselineForMenus: upperLeadInteger +		font ascentForStdAsciiChars.	self lineGridForMenus: self baselineForMenus +		font descentForStdAsciiChars +		lowerLeadInteger! !!TextStyle methodsFor: 'private'!newFontArray: anArray	self fontArray: anArray.	alignment _ 0.	firstIndent _ 0.	restIndent _ 0.	rightIndent _ 0.	tabsArray _ DefaultTabsArray.	marginTabsArray _ DefaultMarginTabsArray.	outputMedium _ #Display! !!Text class methodsFor: 'class initialization'!initTextConstants	"Text initTextConstants"	"Initialize constants shared by classes associated with text display."	| tempArray  | 	TextConstants		at: #Space			put:	(32 asCharacter). 	TextConstants		at: #Tab				put:	(9 asCharacter).	TextConstants		at: #CR				put:	(13 asCharacter).	TextConstants		at: #BS				put:	(8 asCharacter).	TextConstants		at: #BS2	"F1"		put:	(151 asCharacter).	TextConstants		at: #Ctrlw				put:	(23 asCharacter).	TextConstants		at: #ESC				put:	(27 asCharacter).	TextConstants		at: #Cut	"Rubout"	put:	(127 asCharacter).	TextConstants		at: #Paste	"Ctrl^"		put:	(30 asCharacter).	TextConstants		at: #Ctrlt				put:	(20 asCharacter).	TextConstants		at: #Ctrlf				put:	(6 asCharacter).	TextConstants		at: #Ctrlz				put:	(26 asCharacter).	TextConstants		at: #DefaultSpace	put:	4.	TextConstants		at: #DefaultTab		put:	24.	TextConstants		at: #DefaultRule		put:	Form over.	TextConstants		at: #DefaultMask	put:	Form black.	tempArray _ Array new: Display width // DefaultTab.	1 to: tempArray size do: [:i | tempArray 		at: i 		put: DefaultTab * i].	TextConstants at: #DefaultTabsArray put: tempArray.	tempArray _ Array new: (Display width // DefaultTab) // 2.	1 to: tempArray size do: [:i | tempArray 		at: i 		put: (Array with: (DefaultTab*i) with: (DefaultTab*i))].	TextConstants at: #DefaultMarginTabsArray put: tempArray.	self initTextConstants2.!initTextConstants2	"Text initTextConstants"	"Initialize constants shared by classes associated with text display."	TextConstants		at: #Ctrlh				put:	(8 asCharacter).	TextConstants		at: #CtrlH				put:	(243 asCharacter).	TextConstants		at: #Ctrls				put:	(19 asCharacter).	TextConstants		at: #CtrlS				put:	(211 asCharacter).	TextConstants		at: #Ctrln				put:	(14 asCharacter).	TextConstants		at: #CtrlN				put:	(245 asCharacter).	TextConstants		at: #Ctrlp				put:	(16 asCharacter).	TextConstants		at: #CtrlTopBlank	"CtrlF1"	put:	(145 asCharacter).	TextConstants		at: #CtrlMiddleBlank "CtrlF2"	put:	(146 asCharacter).	TextConstants		at: #CtrlBottomBlank "CtrlF3"	put:	(147 asCharacter).		"location of non-character stop conditions"	TextConstants		at: #EndOfRun		put:	257.			TextConstants		at: #CrossedX		put:	258.		"values for alignment"	TextConstants		at: #LeftFlush			put:	0.			TextConstants		at: #RightFlush		put:	1.	TextConstants		at: #Centered		put:	2.	TextConstants		at: #Justified			put:	3.		"subscripts for a marginTabsArray tuple"	TextConstants		at: #LeftMarginTab		put:	1.			TextConstants		at: #RightMarginTab		put:	2.		"font faces"	TextConstants		at: #Basal				put:	0.			TextConstants		at: #Bold				put:	1.	TextConstants		at: #Italic				put:	2.	TextConstants		at: #BoldItalic		put:	3.	TextConstants		at: #Underlined		put:	4.	TextConstants		at: #OverStruck		put:	8.	TextConstants		at: #Subscripted		put:	16.	TextConstants		at: #Superscripted	put:	32.	TextConstants		at: #SubscriptedUnderlined	put:	20.	TextConstants		at: #SuperscriptedUnderlined	put:	36.	TextConstants		at: #UnderlinedBit	put:	3.	TextConstants		at: #OverStruckBit	put:	4.	TextConstants		at: #SubscriptedBit	put:	5.	TextConstants		at: #SuperscriptedBit	put:	6.	TextConstants		at: #SubSuperscriptMask	put:	48.	TextConstants		at: #NonFaceEmphasisMask	put:	52. "overstrike not supported"	TextConstants		at: #FamilyName	put:	1.	TextConstants		at: #PointSize		put:	2.	TextConstants		at: #Face				put:	3.	self initTextConstants3!initTextConstants3	"Text initTextConstants"	"Initialize constants shared by classes associated with text display."	TextConstants		at: #CtrlMinus		put:	(137 asCharacter).	TextConstants		at: #CtrlShiftMinus	put:	(31 asCharacter).	TextConstants		at: #Ctrlb				put:	(2 asCharacter).	TextConstants		at: #CtrlB				put:	(230 asCharacter).	TextConstants		at: #Ctrli				put:	(150 asCharacter).	TextConstants		at: #CtrlI				put:	(214 asCharacter).	TextConstants		at: #Ctrlx				put:	(24 asCharacter).	TextConstants		at: #CtrlX				put:	(215 asCharacter).	TextConstants		at: #Ctrle				put:	(5 asCharacter).! !InputSensor initialize; install. Sensor initMap.Text initTextConstants.ParagraphEditor initialize!!ParagraphEditor class methodsFor: 'class initialization'!initialize	"Initialize the yellow button menu information, the keyboard map for special	control characters, and the shared buffers for copying text across views and	managing undo."	CurrentSelection _ UndoSelection _ Text new.	TextEditorYellowButtonMenu _ PopUpMenu labels: 'againundocopycutpasteacceptcancelalignfit'	lines: #(2 5 7).	TextEditorYellowButtonMessages _ 		#(again undo copySelection cut paste accept cancel align fit).	Keyboard _ Array new: 256.	Keyboard atAllPut: #normalCharacter:.	Keyboard at: Cut asciiValue + 1 put: #cut:.	Keyboard at: Paste asciiValue + 1 put: #paste:.	Keyboard at: ESC asciiValue + 1 put: #selectCurrentTypeIn:.	Keyboard at: BS asciiValue + 1 put: #backspace:.	Keyboard at: Ctrlw asciiValue + 1 put: #backWord:.	Keyboard at: Ctrlt asciiValue + 1 put: #displayIfTrue:.	Keyboard at: Ctrlf asciiValue + 1 put: #displayIfFalse:.	Keyboard at: CR asciiValue + 1 put: #cr:.	Keyboard at: Tab asciiValue + 1 put: #tab:.	Keyboard at: 4 + 1 put: #displayDate:.	"ctrl-d"	#(136 144 143 128 130 129 131 180 149 135 223 208			"fonts 1 - 12 (ctl 1 2 3 4 5 6 7 8 9 0 !! @)"		137 31			"Underline (ctl -), unUnderline (ctl _)"		2 230			"Bold (ctl b), unBold (ctl B)"		150 214			"Italic (ctl i), unItalic (ctl I)"		24 215			"BoldItalic (ctl x), unBoldItalic (ctl X)"		5			"clear emphasis (ctl e)")	do: [:i | Keyboard at: i + 1 put: #changeEmphasis:].	#(213 132 218 249 219 138			"delimiter (ctl leftParen leftBracket lessThan leftBrace doubleQuote singleQuote)")	do: [:i | Keyboard at: i + 1 put: #enclose:].	Keyboard at: BS2 asciiValue + 1 put: #leaveBrackets:.	"ParagraphEditor initialize."! !ParagraphEditor initialize!!ParagraphEditor methodsFor: 'editing'!changeEmphasis: characterStream	"Change the emphasis of the current selection or prepare to accept characters with the change in emphasis.  Emphasis change amounts to a font change."	| oldCode newCode keyboard |	oldCode _ paragraph text emphasisAt: startBlock stringIndex.	((newCode _ #(136 144 143 128 130 129 131 180 149 135 223 208)		"CTL 1-9, 0, CTLSHIFT 1-2 (fonts)"		indexOf:  ((keyboard _ sensor keyboard) asciiValue)) = 0)		ifTrue:	[newCode _ self emphasisDefault: oldCode keyedTo: keyboard].	(((paragraph textStyle isFontUnderlined: oldCode)		and: [keyboard ~= CtrlShiftMinus "unUnderline"])			and: [keyboard ~= Ctrle "clear emphasis"])		ifTrue:	["If font being replaced was underlined, use underlined version					of new font, unless unUnderline has just been struck"				newCode _ paragraph textStyle underlinedFontFor: newCode].	startBlock stringIndex = stopBlock stringIndex	  ifTrue:  "only change emphasisHere while typing"		[emphasisHere _ newCode.		^nil].	self replaceSelectionWith:		(Text string: self selection asString emphasis: (newCode max: 1)).	self closeTypeIn.	self select.	^true! !!ParagraphEditor methodsFor: 'private'!emphasisDefault: oldEmphasisCode keyedTo: keyboardCharacter	"Some default ways to get common forms of emphasis -- returns a new emphasis code.  Subroutine for changeEmphasis.  If anyone else uses, please note here."	keyboardCharacter = CtrlMinus					"Underline"		ifTrue:	[^ paragraph textStyle underlinedFontFor: oldEmphasisCode].	keyboardCharacter = CtrlShiftMinus				"unUnderline"		ifTrue:	[^ paragraph textStyle unUnderlinedFontFor: oldEmphasisCode].	keyboardCharacter = Ctrlb						"Bold"		ifTrue:	[^ paragraph textStyle boldFontFor: oldEmphasisCode].	keyboardCharacter = CtrlB						"unBold"		ifTrue:	[^ paragraph textStyle basalFontFor: oldEmphasisCode].	keyboardCharacter = Ctrli						"Italic"		ifTrue:	[^ paragraph textStyle italicFontFor: oldEmphasisCode].	keyboardCharacter = CtrlI						"unItalic"		ifTrue:	[^ paragraph textStyle basalFontFor: oldEmphasisCode].	keyboardCharacter = Ctrlx						"BoldItalic"		ifTrue:	[^ paragraph textStyle boldItalicFontFor: oldEmphasisCode].	keyboardCharacter = CtrlX						"unBoldItalic"		ifTrue:	[^ paragraph textStyle basalFontFor: oldEmphasisCode].	keyboardCharacter = Ctrle						"clear emphasis, go to basal font"		ifTrue:	[^ paragraph textStyle basalFontFor: oldEmphasisCode].	"If this point is reached, there has been an error:  Perhaps the internal codes for changing font 	emphasis are out of sync in ParagraphEditor initialize and changeEmphasis:" 	self error: 'unrecognized keyboardCharacter'! !!StrikeFont methodsFor: 'accessing'!familySizeFace	"Return an array with familyName <String> pointSize <Integer> faceCode <Integer>"	| firstDigit lastDigit |	firstDigit _ name findFirst: [:char | char isDigit].	lastDigit _ name findLast: [:char | char isDigit].	^Array		with: (name copyFrom: 1 to: firstDigit - 1)		with: (Integer readFromString: (name copyFrom: firstDigit to: lastDigit))		with: (#($B $I $X) indexOf:			(lastDigit = name size ifTrue: [$ ] ifFalse: [name at: lastDigit + 1]))"(1 to: 12) collect: [:i | (TextStyle default fontAt: i) familySizeFace]"! !StrikeFont removeSelector: #ascent:!!TextStyle methodsFor: 'private'!fontFor: fontIndex emphasis: emphasisBlock	| font newFamilySizeFace oldEmphasis oldFace oldFamily oldFamilySizeFace oldSize |	oldFamilySizeFace _ (font _ fontArray at: fontIndex) familySizeFace.	oldFamily _ oldFamilySizeFace at: FamilyName.	oldSize _ oldFamilySizeFace at: PointSize.	oldFace _ oldFamilySizeFace at: Face.	oldEmphasis _ font emphasis.	(1 to: fontArray size) do: [:i |		newFamilySizeFace _ (font _ fontArray at: i) familySizeFace.			((((oldFamily = (newFamilySizeFace at: FamilyName))				and: [oldSize = (newFamilySizeFace at: PointSize)])					and: [oldFace = (newFamilySizeFace at: Face)])						and: [emphasisBlock							value: oldEmphasis							value: font emphasis])				ifTrue:	[^i]].	^fontIndex!fontFor: fontIndex face: face	| font newFamilySizeFace oldEmphasis oldFamily oldFamilySizeFace oldSize |	oldFamilySizeFace _ (font _ fontArray at: fontIndex) familySizeFace.	oldFamily _ oldFamilySizeFace at: FamilyName.	oldSize _ oldFamilySizeFace at: PointSize.	oldEmphasis _ font emphasis.	(1 to: fontArray size) do: [:i |		newFamilySizeFace _ (font _ fontArray at: i) familySizeFace.			((((oldFamily = (newFamilySizeFace at: FamilyName))				and: [oldSize = (newFamilySizeFace at: PointSize)])					and: [face = (newFamilySizeFace at: Face)])						and: [(oldEmphasis bitAnd: NonFaceEmphasisMask) =							(font emphasis bitAnd: NonFaceEmphasisMask)])				ifTrue:	[^i]].	^fontIndex!subscriptedFontFor: fontIndex	^self		fontFor: fontIndex		emphasis: [:oldEmphasis :newEmphasis |			((newEmphasis bitAt: SubscriptedBit) = 1)				and: [(oldEmphasis bitAt: Underlined) =					(newEmphasis bitAt: Underlined)]]!superscriptedFontFor: fontIndex	^self		fontFor: fontIndex		emphasis: [:oldEmphasis :newEmphasis |			((newEmphasis bitAt: SuperscriptedBit) = 1)				and: [(oldEmphasis bitAt: Underlined) =					(newEmphasis bitAt: Underlined)]]!underlinedFontFor: fontIndex	^self		fontFor: fontIndex		emphasis: [:oldEmphasis :newEmphasis |			((newEmphasis bitAt: UnderlinedBit) = 1)				and: [(oldEmphasis bitAnd: SubSuperscriptMask) =					(newEmphasis bitAnd: SubSuperscriptMask)]]!unSubscriptedFontFor: fontIndex	^self		fontFor: fontIndex		emphasis: [:oldEmphasis :newEmphasis |			((newEmphasis bitAt: SubscriptedBit) = 0)				and: [(oldEmphasis bitAt: Underlined) =					(newEmphasis bitAt: Underlined)]]!unSuperscriptedFontFor: fontIndex	^self		fontFor: fontIndex		emphasis: [:oldEmphasis :newEmphasis |			((newEmphasis bitAt: SuperscriptedBit) = 0)				and: [(oldEmphasis bitAt: Underlined) =					(newEmphasis bitAt: Underlined)]]!unUnderlinedFontFor: fontIndex	^self		fontFor: fontIndex		emphasis: [:oldEmphasis :newEmphasis |			((newEmphasis bitAt: UnderlinedBit) = 0)				and: [(oldEmphasis bitAnd: SubSuperscriptMask) =					(newEmphasis bitAnd: SubSuperscriptMask)]]!fontFor: fontIndex emphasis: emphasisBlock	| font newFamilySizeFace oldEmphasis oldFace oldFamily oldFamilySizeFace oldSize |	fontIndex > fontArray size ifTrue: [^fontIndex].	oldFamilySizeFace _ (font _ fontArray at: fontIndex) familySizeFace.	oldFamily _ oldFamilySizeFace at: FamilyName.	oldSize _ oldFamilySizeFace at: PointSize.	oldFace _ oldFamilySizeFace at: Face.	oldEmphasis _ font emphasis.	(1 to: fontArray size) do: [:i |		newFamilySizeFace _ (font _ fontArray at: i) familySizeFace.			((((oldFamily = (newFamilySizeFace at: FamilyName))				and: [oldSize = (newFamilySizeFace at: PointSize)])					and: [oldFace = (newFamilySizeFace at: Face)])						and: [emphasisBlock							value: oldEmphasis							value: font emphasis])				ifTrue:	[^i]].	^fontIndex!fontFor: fontIndex face: face	| font newFamilySizeFace oldEmphasis oldFamily oldFamilySizeFace oldSize |	fontIndex > fontArray size ifTrue: [^fontIndex].	oldFamilySizeFace _ (font _ fontArray at: fontIndex) familySizeFace.	oldFamily _ oldFamilySizeFace at: FamilyName.	oldSize _ oldFamilySizeFace at: PointSize.	oldEmphasis _ font emphasis.	(1 to: fontArray size) do: [:i |		newFamilySizeFace _ (font _ fontArray at: i) familySizeFace.			((((oldFamily = (newFamilySizeFace at: FamilyName))				and: [oldSize = (newFamilySizeFace at: PointSize)])					and: [face = (newFamilySizeFace at: Face)])						and: [(oldEmphasis bitAnd: NonFaceEmphasisMask) =							(font emphasis bitAnd: NonFaceEmphasisMask)])				ifTrue:	[^i]].	^fontIndex! !!TextStyle reorganize!('accessing' alignment alignment: baseline baseline: baselineForLists baselineForLists: baselineForMenus baselineForMenus: defaultFont descent firstIndent firstIndent: fontArray fontArray: fontAt: fontAt:put: fontNamed: lineGrid lineGrid: lineGridForLists lineGridForLists: lineGridForMenus lineGridForMenus: nestingDepth outputMedium outputMedium: restIndent restIndent: rightIndent rightIndent: upperLead:lowerLead:)('converting' asListStyle asMenuStyle listStyleForFont:upperLead:lowerLead: menuStyleForFont:upperLead:lowerLead:)('tabs and margins' clearIndents leftMarginTabAt: nextTabXFrom:leftMargin:rightMargin: rightMarginTabAt: tabWidth)('private' basalFontFor: boldFontFor: boldItalicFontFor: fontFor:emphasis: fontFor:face: gridForFont:withLead: isFontBold: isFontBoldItalic: isFontItalic: isFontSubscripted: isFontSuperscripted: isFontUnderlined: italicFontFor: marginTabAt:side: newFontArray: subscriptedFontFor: superscriptedFontFor: underlinedFontFor: unSubscriptedFontFor: unSuperscriptedFontFor: unUnderlinedFontFor:)!!TextStyle methodsFor: 'accessing'!fontAt: index 	^fontArray at: ((index min: fontArray size) max: 1)!fontNamed: aString	(1 to: fontArray size) do: [:faceFontIndex |		aString = (fontArray at: faceFontIndex) name ifTrue: [^faceFontIndex]].	^self basalFontFor: 1! !!TextStyle methodsFor: 'tabs and margins'!clearIndents	"Reset all the margin (index) settings to be 0."	self		firstIndent: 0;		restIndent: 0;		rightIndent: 0!nextTabXFrom: anX leftMargin: leftMargin rightMargin: rightMargin	"Tab stops are distances from the leftMargin.  Set the distance into anX normalized for the paragraph's left margin.  Scale makes the routine usable for printing.  On the display the scale is 1."	| normalizedX tabX scale |	scale _ 1.	normalizedX _ anX - leftMargin.	1 to: tabsArray size do: [:i |		(tabX _ ((tabsArray at: i) * scale) asInteger) > normalizedX ifTrue: [			^leftMargin + tabX min: rightMargin]].	^rightMargin! !TextStyle removeSelector: #flushFonts!Object subclass: #StrikeFont	instanceVariableNames: 'xTable glyphs name stopConditions type minAscii maxAscii maxWidth strikeLength ascent descent xOffset raster subscript superscript emphasis ascentForStdAsciiChars descentForStdAsciiChars '	classVariableNames: 'DefaultStopConditions FaceNames '	poolDictionaries: 'TextConstants '	category: 'Graphics-Support'!!StrikeFont reorganize!('initialize-release' initializeFrom:)('accessing' ascent ascentForStdAsciiChars characterForm: descent descentForStdAsciiChars familySizeFace glyphs height maxAscii maxWidth minAscii name name: raster stopConditions subscript subscript: superscript superscript: widthOf: xTable)('converting' asTextStyle)('testing' checkCharacter:)('displaying' characters:in:displayAt:clippedBy:rule:mask: composeWord:in:beginningAt: displayLine:at:)('emphasis' emphasis emphasis: emphasized: emphasized:named:)('printing' printOn:)('private' computeAscentDescentForStdAsciiChars glyphs: glyphsSwitchCharacters xTableSwitchCharacters)!!StrikeFont class methodsFor: 'fileIn-Out'!readAll: aFontDirectoryName 	"I read in all the fonts in aFontDirectoryName.  These fonts are assumed to be in Tektronix format.  I skip over files with illegal names, and files that return 'nil' when read."	| aStream aStrikeFont skip |	aStream _ WriteStream on: (Array new: 128).
	skip _ false.	Transcript cr; cr; show: 'Reading font from:'.	(FileDirectory directoryNamed: aFontDirectoryName) do: [:aFontFile | 		aFontFile name			indexOfSubCollection: '.font'			startingAt: 2			ifAbsent: [skip _ true].		skip			ifTrue: [skip _ false]			ifFalse: [				Transcript crtab; show: aFontFile name.				aStrikeFont _ StrikeFont readFrom: aFontFile.				aStrikeFont notNil					ifTrue: [aStream nextPut: aStrikeFont]					ifFalse: [Transcript show: ' not read.']]].	^aStream contents!readFrom: aFontFileStream
	"I read in a font from aFontFileStream.  This font is assumed to be in Tektronix format."

	^self new initializeFrom: aFontFileStream! !!StrikeFont methodsFor: 'private'!glyphsSwitchCharacters

	| final aBitBlt upperDelta lowerDelta | 
	"I answer the bits of my glyph's form after switching the position of the up arrow and left arrow with the caret and underscore characters."

	final _ glyphs deepCopy.
	"Copy left arrow and uparrow to their correct places" 
	upperDelta _ (xTable at: $^ asciiValue + 3)-(xTable at: $^ asciiValue + 1).
	lowerDelta _ (xTable at: 30)-(xTable at: 28).
	aBitBlt _ BitBlt
		destForm: final
		sourceForm: glyphs
		halftoneForm: Form black
		combinationRule: Form over
		destOrigin: ((xTable at: 28) @ 0)	 "caret"
		sourceOrigin: ((xTable at: $^ asciiValue + 1) @ 0)
		extent: (upperDelta @ glyphs height)
		clipRect: final computeBoundingBox.
	aBitBlt copyBits.
	"Copy all characters from . through ]"
	aBitBlt _ BitBlt
		destForm: final
		sourceForm: glyphs
		halftoneForm: Form black
		combinationRule: Form over
		destOrigin: (((xTable at: 30) + lowerDelta - upperDelta) @ 0)	 "."
		sourceOrigin: ((xTable at:30) @ 0)
		extent: (((xTable at: 94)-(xTable at:30)) @ glyphs height)
		clipRect: final computeBoundingBox.
	aBitBlt copyBits.
	"Copy uparrow and caret from original font"
	aBitBlt _ BitBlt
		destForm: final
		sourceForm: glyphs
		halftoneForm: Form black
		combinationRule: Form over
		destOrigin: ((xTable at: 95) @ 0) 
		sourceOrigin: ((xTable at:28) @ 0)
		extent: (lowerDelta @ glyphs height)
		clipRect: final computeBoundingBox.
	aBitBlt copyBits. 
	"Copy `  through rubout from original font - not needed if clipped correctly"
	"aBitBlt _ BitBlt
		destForm: final
		sourceForm: glyphs
		halftoneForm: Form black
		combinationRule: Form over
		destOrigin: ((xTable at: 97) @ 0) 
		sourceOrigin: ((xTable at:97) @ 0)
		extent: (((xTable at: xTable size)-(xTable at: $` asciiValue + 1)) @ glyphs height)
		clipRect: final computeBoundingBox.
	aBitBlt copyBits."
	^final!xTableSwitchCharacters
	"I return an xTable where the entries for caret and 
	underscore entries are replaced by up arrow and left arrow"

	| adjustedxTable delta |
	adjustedxTable _ self xTable copy.
	adjustedxTable at: 29 put: (xTable at: 28)
			+ (xTable at: $^ asciiValue + 2) - (xTable at: $^ asciiValue + 1).
	adjustedxTable at: 30 put: (adjustedxTable at: 29)
			+ (xTable at: $_ asciiValue + 2 ) - (xTable at: $_ asciiValue  + 1).
	delta _ (xTable at: 30) - (adjustedxTable at: 30).
	31 to: $^ asciiValue  do: [:tmp | adjustedxTable at: tmp put: (xTable at: tmp) - delta].
	adjustedxTable at: $^ asciiValue + 1 put: (xTable at: $^ asciiValue + 1)
			+ delta.
	adjustedxTable at: $_ asciiValue + 1 put: (xTable at: $_ asciiValue +1)
			+ delta.
	^adjustedxTable! !!StrikeFont class reorganize!('class initialization' initialize)('fileIn-Out' readAll: readFrom:)!!StrikeFont class methodsFor: 'class initialization'!initialize
	FaceNames isNil
		ifTrue: 
			[FaceNames _ Dictionary new: 8.
			FaceNames at: 'Bold' put: 'B'.
			FaceNames at: 'Demi Bold' put: 'D'.
			FaceNames at: 'Italic' put: 'I'.
			FaceNames at: 'Block' put: 'K'.
			FaceNames at: 'Oblique' put: 'O'.
			FaceNames at: 'Regular' put: ''.
			FaceNames at: 'Symbol' put: 'S'.
			FaceNames at: 'Bold Italic' put: 'X'].
	DefaultStopConditions _ Array new: 258.
	DefaultStopConditions
		at: 10 put: #tab;
		at: 11 put: #cr;
		at: 14 put: #cr;
		at: 20 put: #onePixelSpace;
		at: 212 put: #onePixelBackspace;
		at: EndOfRun put: #endOfRun;
		at: 258 put: #crossedX	"StrikeFont initialize"! !StrikeFont initialize!!StrikeFont methodsFor: 'private'!glyphsSwitchCharacters	" I return the bits of my glyph's form after switching the  	position of the uparrow and left arrow with the caret and  	underscore characters."	| final aBitBlt upperDelta lowerDelta |	final _ glyphs deepCopy.	"Copy left arrow and uparrow to their correct places"	upperDelta _ (xTable at: $^ asciiValue + 3)				- (xTable at: $^ asciiValue + 1).	lowerDelta _ (xTable at: 30)				- (xTable at: 28).	aBitBlt _ BitBlt				destForm: final				sourceForm: glyphs				halftoneForm: Form black				combinationRule: Form over				destOrigin: (xTable at: 28)						@ 0				sourceOrigin: (xTable at: $^ asciiValue + 1)						@ 0				extent: upperDelta @ glyphs height				clipRect: final computeBoundingBox.	aBitBlt copyBits.	"Copy all characters from . through ]"	aBitBlt _ BitBlt				destForm: final				sourceForm: glyphs				halftoneForm: Form black				combinationRule: Form over				destOrigin: (xTable at: 28)						+ upperDelta @ 0				sourceOrigin: (xTable at: 30)						@ 0				extent: (xTable at: 94)						- (xTable at: 30) @ glyphs height				clipRect: final computeBoundingBox.	aBitBlt copyBits.	"Copy uparrow and caret from original font"	aBitBlt _ BitBlt				destForm: final				sourceForm: glyphs				halftoneForm: Form black				combinationRule: Form over				destOrigin: (xTable at: 95)						+ upperDelta - lowerDelta @ 0				sourceOrigin: (xTable at: 28)						@ 0				extent: lowerDelta @ glyphs height				clipRect: final computeBoundingBox.	aBitBlt copyBits.	^final!glyphsWrite: aStream 	" I write out the bits of my glyph's form after switching the position of the uparrow and left arrow with the caret and underscore characters."	| final |	type = 1 | (type = 2)		ifTrue: [final _ self glyphsSwitchCharacters]		ifFalse: [final _ glyphs deepCopy].	final bits do: [:w | aStream nextWordPut: w]!underlineInfo: aStream 	"I write out the necessary underlining  representation of 	myself as a Tektronix Font File."	| characterForm thick lineStart clear endline tomovetobottom notAtUnderline |	characterForm _ self characterForm: (Character value: 28).	thick _ 0. notAtUnderline _ true.	lineStart _ characterForm height.	1 to: characterForm height do: 		[:sl | 		clear _ false.		(characterForm scanLineStringAt: sl - 1)			detect: [:tmp | tmp asciiValue ~= 0]			ifNone: [clear _ true].		clear 			ifTrue: [ notAtUnderline ifTrue:[lineStart _ sl] ]			ifFalse: [thick _ thick + 1. notAtUnderline _ false.] ].	"Bias to offset from baseline"	endline _ lineStart + thick - 1.	tomovetobottom _ characterForm height - endline.	aStream nextWordPut: lineStart + tomovetobottom - self ascent.	aStream nextWordPut: thick.! !!StrikeFont methodsFor: 'accessing'!leadinfo	" I return the recommended leading information for my  	font. If I am a fixed pitched font there should be no extra  	leading added except that already embedded within the 	font. If I am a proportional font, my leading is  	adjusted according to the height of my font. If my size  	isn't one that I know about, then a nominal leading of 3 is  	returned."	| leadDictionary |	leadDictionary _ Dictionary new: 7.	leadDictionary at: 8 put: 5.	leadDictionary at: 10 put: 7.	leadDictionary at: 12 put: 7.	leadDictionary at: 14 put: 6.	leadDictionary at: 18 put: 6.	leadDictionary at: 24 put: 7.	leadDictionary at: 36 put: 7.	self isFixedPitch		ifTrue: [^(self topLead: $l) + (self bottomLead: $g)]		ifFalse: [^leadDictionary at: (self familySizeFace at: 2)				ifAbsent: [3]]!tightLeadinfo	" I return the minimun recommended leading information 	for my  font. If I am a fixed pitched font there should be no extra  	leading added other thank that already designed into the 	font. If I am a proportional font, then a nominal leading of 	4 is returned."	self isFixedPitch		ifTrue: [^ (self topLead: $l) + (self bottomLead: $g)]		ifFalse: [^4]! !!StrikeFont methodsFor: 'printing'!writeOnFile: aString"I create a Tektronix font format file of myself to a file named aString. If my type is one that I recognized (1 for monospaced, 2 for proportional, 3 for Xerox Smalltalk, I take care to generate a file that can be reread."	| f |	f _ Disk newFile: aString.	f binary.	self writeOn: f.	f close! !StrikeFont comment:'Instance Variables:	xTable	<Array>  Of left x-coordinate of character in glyphs.	glyphs	<Form>  Containing bits representing the characters.	name	<String>  Name of this font.	stopConditions	<Array>  Of selectors to be performed in scanning text.	type	<Integer>  Compatibility code:		1			- Tektronix monospaced		2			- Tektronix proportional		3			- Xerox		other values designate a font from other sources	minAscii, maxAscii	<Integer>  Giving range supported by this font.	maxWidth	<Integer>  Width of widest char. Not presently used, but may be for font modification.	strikeLength	<Integer>  Width of glyphs.	ascent, descent	<Integer>  Max extent of chars above and below the baseline	xOffset	<Integer>  For kerning (not presently used)	raster	<Integer>  (strikeLength + 15 \\ 16)	subscript, superscript	<Integer>  Further vertical offset relative to baseline	emphasis	<Integer>  code for synthetic bold, italic, underline, strike-out	ascentForStdAsciiChars, descentForStdAsciiChars <Integer>  Max extent of chars above and below the baseline for ADE 32 through 126.StrikeFonts are a compact encoding of a set of Forms corresponding to characters in the ASCII character set.  All the forms are placed side by side in a large form whose height is the font height, and whose width is the sum of all the character widths.  The xTable gives the left-x coordinates of the subForms corresponding to the characters.'!!StrikeFont methodsFor: 'accessing'!type	"Answer the receiver's compatibility mode."	^type!type: anInteger	"Set the receiver's compatibility mode."	type _ anInteger! !!StrikeFont methodsFor: 'private'!fontInfoWrite: aStream 	"Write the Tektronix font info information to aStream."	aStream nextWordPut: self maxWidth.	self isFixedPitch		ifTrue: [aStream nextWordPut: self height]		ifFalse: [aStream nextWordPut: self height + self tightLeadinfo].	aStream nextWordPut: self ascent.	"Distance from baseline to top of Cap Height (H)."	aStream nextWordPut: self ascent - (self topLead: $H).	"Distance from baseline to top of smallest non cap (x)"	aStream nextWordPut: self ascent - (self topLead: $x).	"Distance from baseline to top of  highest ascending non cap (l)."	aStream nextWordPut: self ascent - (self topLead: $l).	"Distance from basline to bottom of largest descending character. "	aStream nextWordPut: self descent - (self bottomLead: $g).	"Write out underlining position and thickness"	self underlineInfo: aStream.	aStream nextWordPut: self tightLeadinfo.	"minimum leading"	aStream nextWordPut: self leadinfo! !!StrikeFont methodsFor: 'initialize-release'!initializeFrom: aFontFile 	"I read a font from aFontFile.  This must be in Tektronix 	format.  I return aStrikefont unless I discover something 	wrong, in which case I return nil."	| nameField face bitmapPos height mapPos bitmap xTablePos |	aFontFile text.	(aFontFile next: 4) = 'Font'		"check for magic"		ifFalse: 			[self error: aFontFile fullName , ' is not a font file'.			^nil].	nameField _ (aFontFile next: 32) copyUpTo: 0 asCharacter.		"name is 32 bytes"	face _ (aFontFile next: 32) copyUpTo: 0 asCharacter.		"face is 32 bytes"	aFontFile binary.	aFontFile nextWord = 1		"2 bytes designating type"		ifFalse: 			[self error: aFontFile fullName , ' is not of the proper font type'.			^nil].	type _ aFontFile nextWord.		"2 bytes designating compatibility"	(type < 1 or: [type > 3])		ifTrue: [self notify: aFontFile fullName , ' type (' , type printString , ') is not compatible with Smalltalk.Proceed to continue loading this font.'].	name _ nameField , aFontFile nextWord printString , (FaceNames at: face).		"point size"	aFontFile skip: 3 * 2 + 4.		" skip resolution, mul, div, and pointer to comment"	mapPos _ aFontFile nextNumber: 4.	aFontFile skip: 4.	xTablePos _ aFontFile nextNumber: 4.	aFontFile skip: 4 * 4.	"skip spares"	bitmapPos _ aFontFile nextNumber: 4.	strikeLength _ aFontFile nextWord.	"width"	raster _ strikeLength + 15 // 16.	height _ aFontFile nextWord.	aFontFile skip: 2.		"skip offsetw"	ascent _ aFontFile nextWord.		"offseth"	descent _ height - ascent.	aFontFile position: mapPos.	aFontFile skip: 2.		"skip white"	maxWidth _ aFontFile nextWord.	aFontFile skip: 2 * 3.	minAscii _ aFontFile nextWord.		"first"	maxAscii _ aFontFile nextWord.		"last"	xTable _ Array new: maxAscii - minAscii + 2.	1 to: xTable size do: [:i | xTable at: i put: aFontFile nextWord].	"Smalltalk's use of maxAscii assumes that the last value in the 	xTable is non-printing."	maxAscii _ 126.	"Build the glyphs from the bitmap area. "	aFontFile position: bitmapPos.	bitmap _ WordArray new: raster * height.	1 to: raster * height do: [:i | bitmap at: i put: aFontFile nextWord].	glyphs _ Form				extent: strikeLength @ height				fromArray: bitmap				offset: 0 @ 0.	"If this is a Tektronix font,  switch the  	caret and underscore with the upArrow and rightArrow in  	both the xTable and the bitmap."	(type = 2 or: [type = 1]) ifTrue: [		glyphs _ self glyphsSwitchCharacters.		xTable _ self xTableSwitchCharacters].	"Fill in various information not provided in the file."	stopConditions _ DefaultStopConditions.	emphasis _ 0! !!StrikeFont methodsFor: 'printing'!writeOn: aStream 	"I write out the representation of myself on aStream using the Tektronix Font File format."	| buf mapspot commentPos firstDigit lastDigit na fontStyle fontMaps infoPos bitMapPos  xTablePos |	aStream binary.	"Write out the file type code (magic number)"	aStream nextPut: 70; nextPut: 111; nextPut: 110; nextPut: 116. 	"FontHeader.magic"	"Write font Family name."	aStream text.	buf _ String new: 32.	firstDigit _ name findFirst: [:char | char isDigit].	lastDigit _ name findLast: [:char | char isDigit].	na _ name copyFrom: 1 to: firstDigit - 1.	buf		replaceFrom: 1		to: na size		with: na.	na size + 1 to: 32 do: [:i | buf at: i put: (Character value: 0)].	"Pad out the buffer with NULL."	aStream nextPutAll: buf.	"FontHeader.name"	fontStyle _ Array new: 5.	fontStyle at: 1 put: 'Bold'.	fontStyle at: 2 put: 'Italic'.	fontStyle at: 3 put: 'Bold Italic'.	fontStyle at: 4 put: 'Bold Italic'.	fontStyle at: 5 put: 'Regular'.	"Write font style string"	buf _ String new: 32.	" determine a style name"	na _ fontStyle at: (#('B' 'I' 'BI' 'X' '' ) indexOf: (name asUppercase copyFrom: lastDigit + 1 to: name size)).	buf		replaceFrom: 1		to: na size		with: na.	na size + 1 to: 32 do: [:i | buf at: i put: (Character value: 0)].	"Pad out the buffer with NULL."	aStream nextPutAll: buf.	"FontHeader.face"	aStream binary.	"Type ASCII font: FontHeader.type - ASCII"	aStream nextWordPut: 1.	"Compatability is eqivalent to StrikeFont type"		aStream nextWordPut: type.	aStream nextWordPut: (Integer readFromString:		(name copyFrom: firstDigit to: lastDigit)).	"Point size: FontHeader.ptsize"	aStream nextWordPut: 100.	"Resolution for which fonts were designed for: FontHeader.resolution"	aStream nextWordPut: 0.	"Scaling to pixel screen - multiplier: FontHeader.mul"	aStream nextWordPut: 0.	"Scaling from pixel screen to font - divisor: FontHeader.div"	mapspot _ aStream position.	aStream skip: 4 * 9.		"Skip over font header pointers for now."	aStream nextWordPut: self glyphs width.	" Width of font bitmap: FontHeader.width"	aStream nextWordPut: self glyphs height.	"Height of the bitmap: FontHeader.height"	aStream nextWordPut: 0.	"Horizontal offset: FontHeader.offsetw"	aStream nextWordPut: self ascent.	"Baseline: FontHeader.offseth"	aStream nextWordPut: self glyphs width + 15 // 16 * 2.	"Number of bytes per strike font line: FontHeader.inc"	aStream nextWordPut: 1.	"Bits per pixel: FontHeader.depth"	aStream nextWordPut: 0.	"Rotation: FontHeader.rotation"	aStream nextWordPut: 127.	"Code to use for undefined characters-- Rubout: 	FontHeader.undef_char "	aStream nextWordPut: 0.	"Not Boldable: FontHeader.boldinfo"	aStream nextWordPut: 0.	"Not Italicable: FontHeader.italicinfo"	aStream nextWordPut: 0.	"Intercharacter procedure call entry: FontHeader.proc"	aStream nextWordPut: 0.	"Intercharacter procedure call entry"	aStream nextPutAll: (ByteArray new: 3 * 4).	"Spare bytes at the end: FontHeader.spare"	"Except  for the pointer fields, this is the end of the structure FontHeader.  Following is the font comment."	commentPos _ aStream position.	aStream text.	(type = 1) | (type = 2) 	ifTrue:[buf _ 'PELLUCIDA (registered trademark)  typeface font (c) Copyright 1986 by Bigelow & Holmes']	ifFalse:[buf _ String new: 32].	aStream nextPutAll: buf.	"Actual text of comment: *FontHeader.comment"	buf size even ifFalse: [aStream nextPut: (Character value: 0)].	aStream binary.	fontMaps _ aStream position.	aStream position: mapspot.	aStream nextWordPut: 0.	aStream nextWordPut: commentPos.	"Comment pointer: FontHeader.comment"	aStream nextWordPut: 0.	aStream nextWordPut: fontMaps.	"FontMaps structure pointer: FontHeader.maps"	"Index into the font map."	aStream position: fontMaps.	aStream nextWordPut: 0.	"White space to pad to right of character: FontMap.white"	aStream nextWordPut:maxWidth.	"Width of widest char: FontMap.maxw"	self isFixedPitch	ifTrue:[aStream nextWordPut: self height ]	ifFalse:[aStream nextWordPut: self height + self tightLeadinfo].	aStream nextWordPut:ascent.	"Character baseline"	"Width of the character if this is a fixed pitch font"	aStream nextWordPut: (self isFixedPitch			ifTrue: [self widthOf: 33 asCharacter]			ifFalse: [0]).	aStream nextWordPut:  minAscii.	" Code of the minimum character"	aStream nextWordPut:(xTable size) - 2.	" Code of the maximum character"	"Index to Xtable"	xTablePos _ aStream position.	aStream position: mapspot + (4 * 3).	aStream nextWordPut: 0.	aStream nextWordPut: xTablePos.	aStream position: xTablePos.	"write the table of starting character positions"	"Be sure to fixup so that left arrow and uparrow are swizzled with caret and underscore if I am a known type"	(type = 1) | (type = 2)	ifTrue:[	self xTableSwitchCharacters do: [:elem | elem notNil ifTrue: [aStream nextWordPut: elem]]]	ifFalse:[self xTable size do:[:elem | elem notNil ifTrue: [aStream nextWordPut: elem]]].	infoPos _ aStream position.	aStream position: mapspot + (4 * 2).	aStream nextWordPut: 0.	aStream nextWordPut: infoPos.	aStream position: infoPos.	"Write font info fields"	self fontInfoWrite:aStream.	bitMapPos _ aStream position.	aStream position: mapspot + 32.	aStream nextWordPut: 0.	aStream nextWordPut: bitMapPos.	"Index to FontMap"	aStream position: bitMapPos.		self glyphsWrite:aStream! !!StrikeFont methodsFor: 'private'!xTableSwitchCharacters	"Answer an xTable where the entries for caret and  	underscore entries are replaced by uparrow and leftarrow"	| adjustedxTable lowerDelta upperDelta |	adjustedxTable _ self xTable copy.	adjustedxTable at: 29 put: (xTable at: 28)			+ (xTable at: 96) - (xTable at: 95).	adjustedxTable at: 30 put: (adjustedxTable at: 29)			+ (xTable at: 97) - (xTable at:96).	lowerDelta _ (xTable at: 30)				- (xTable at: 28).	upperDelta _ (xTable at:  97)				- (xTable at:  95).	31 to: 95 do: [:tmp | adjustedxTable at: tmp put: (xTable at: tmp)				+ upperDelta - lowerDelta].	adjustedxTable at:96 put:(adjustedxTable at: 95) + (xTable at:29) - (xTable at:28).	^adjustedxTable! !!StrikeFont class methodsFor: 'class initialization'!initialize	"Set up FaceNames dictionary and the default stop conditions."	FaceNames isNil		ifTrue: 			[FaceNames _ Dictionary new: 8.			FaceNames at: 'Bold' put: 'B'.			FaceNames at: 'Demi Bold' put: 'D'.			FaceNames at: 'Italic' put: 'I'.			FaceNames at: 'Block' put: 'K'.			FaceNames at: 'Oblique' put: 'O'.			FaceNames at: 'Regular' put: ''.			FaceNames at: 'Symbol' put: 'S'.			FaceNames at: 'Bold Italic' put: 'X'].	DefaultStopConditions _ Array new: 258.	129 to: DefaultStopConditions size do: [: i | DefaultStopConditions at: i put: #characterNotInFont].	DefaultStopConditions		at: 10 put: #tab;		at: 11 put: #cr;		at: 14 put: #cr;		at: 20 put: #onePixelSpace;		at: 212 put: #onePixelBackspace;		at: EndOfRun put: #endOfRun;		at: 258 put: #crossedX	"StrikeFont initialize"! !StrikeFont initialize!!StrikeFont methodsFor: 'accessing'!bottomLead: character 	"Answer the amount of white space or leading imbedded in the character form at the bottom. "	| bottomLead charForm clear |	charForm _ self characterForm: character.	bottomLead _ 0.	1 to: charForm height do: 		[:sl | 		clear _ false.		(charForm scanLineStringAt: (charForm height) - sl)			detect: [:tmp | tmp asciiValue ~= 0]			ifNone: [clear _ true].		clear			ifTrue: [bottomLead _ bottomLead + 1]			ifFalse: [^bottomLead]].	^bottomLead! !!StrikeFont methodsFor: 'testing'!isFixedPitch	"Answer true if all  legal characters of the font are the same width."	| spaceWidth mywidth |	spaceWidth _ self widthOf: 32 asCharacter.	self minAscii  to: self maxAscii  do: [:char | 		mywidth _ self widthOf: char asCharacter. 		(mywidth ~= 0) ifTrue: [mywidth = spaceWidth ifFalse:[^false]]].	^true! !!StrikeFont methodsFor: 'accessing'!topLead: character 	"Answer the amount of white space or leading imbedded in at the top of the character form. "	| topLead charForm clear |	charForm _ self characterForm: character.	topLead _ 0.	1 to: charForm height do: 		[:sl | 		clear _ false.		(charForm scanLineStringAt: sl - 1)			detect: [:tmp | tmp asciiValue ~= 0]			ifNone: [clear _ true].		clear			ifTrue: [topLead _ topLead + 1]			ifFalse: [^topLead]].	^topLead! !'Add "style" to blue button menus. Clicking this and selecting a text style changes the text style for the StandardSystemView, its title tab, and all of its subviews.'!!StandardSystemController class methodsFor: 'class initialization'!initialize	"Initialization of StandardSystemView menus"	ScheduledBlueButtonMenu _ PopUpMenu labels: 'titlestyleundermoveframecollapserepaintclose' lines: #(2 7).	ScheduledBlueButtonMessages _ #(title textStyle under move expand collapse viewDisplayUpdate close)"StandardSystemController initialize.StandardSystemController allInstancesDo: [:c | c initializeBlueButtonMenu]"! !StandardSystemController initialize.StandardSystemController allInstancesDo: [:c | c initializeBlueButtonMenu]!!StandardSystemController reorganize!('initialize-release' initialize initializeBlueButtonMenu)('control defaults' isControlActive)('basic control sequence' controlInitialize controlTerminate)('menu messages' close collapse expand menuMessageReceiver move move: title under viewDisplayUpdate)('scheduling' closeAndUnschedule closeAndUnscheduleNoErase open openDisplayAt: openNoTerminate openNoTerminateDisplayAt: realOpen)('text style' textStyle textStyle:)!!StandardSystemController methodsFor: 'text style'!textStyle	"Present a menu of text styles; accept one, recompose, and redisplay."	StyleManager fromUser: [:aTextStyle | self textStyle: aTextStyle]!textStyle: aTextStyle	Cursor execute showWhile: [		view			resetLabel: view label style: aTextStyle;			textStyle: aTextStyle;			display.		self controlTerminate; controlInitialize]! !StyleManager initializeMenus!"install text styles"Compiler evaluate: ((Disk file: '/smalltalk/textStyles/PellucidaDefault10and12.ws') contentsOfEntireFile)!"change default text style"StyleManager changeDefaultTextStyle: (StyleManager at: 'Pellucida Default 10 and 12')!Number variableWordSubclass: #Float	instanceVariableNames: ''	classVariableNames: 'ExpPCoefficients ExpQCoefficients Fourthpi Halfpi Ln2 LnCoefficients NegativeInfinity NotANumber Pi PositiveInfinity RadiansPerDegree SinCoefficients Sqrt2 TanCoefficients Twopi '	poolDictionaries: ''	category: 'Numeric-Numbers'!!Float class methodsFor: 'class initialization'!initialize	"constants from Computer Approximations, pp. 182-183 	Pi = 3.14159265358979323846264338327950288 	Pi/2 = 1.57079632679489661923132169163975144 	Pi/4 = 0.78539816339744830961566084581987572 	Pi*2 = 6.28318530717958647692528676655900576 	Pi/180 = 0.01745329251994329576923690768488612 	2.0 ln = 0.69314718055994530941723212145817657 	2.0 sqrt = 1.41421356237309504880168872420969808"	Pi _ 3.14159.	Halfpi _ Pi / 2.0.	Fourthpi _ Pi / 4.0.	Twopi _ Pi * 2.0.	RadiansPerDegree _ Pi / 180.0.	Ln2 _ 0.693147.	Sqrt2 _ 1.41421.	SinCoefficients _ #(-0.166667 0.00833333 -1.98409e-4 2.7526e-6 -2.39e-8 ).	TanCoefficients _ #(0.333331 0.133392 0.0533741 0.0245651 0.00290052 0.00951681 ).	ExpPCoefficients _ #(28.8756 2525.04 ).	ExpQCoefficients _ #(1.0 375.022 7285.73 ).	LnCoefficients _ #(0.237625 0.285254 0.400006 0.666667 2.0 ).	NegativeInfinity _ self new: 2.	NegativeInfinity at: 1 put:  16rFF80.	NegativeInfinity at: 2 put: 16r0000.	PositiveInfinity _ self new: 2.	PositiveInfinity at: 1 put:  16r7F80.	PositiveInfinity at: 2 put: 16r0000.	NotANumber _ self new: 2.	NotANumber at: 1 put: 16rFFFF.	NotANumber at: 2 put: 16rFFFF.	"Float initialize."! !!Float class methodsFor: 'instance creation'!negativeInfinity	"Answer floating point number representing negative infinity."	^NegativeInfinity copy!notANumber	"Answer Not-A-Number of the type created by the interpreter."	^NotANumber copy!notANumber: mantissa	"Answer a Not-A-Number with the lower 23 bits taken from the argument mantissa."	| newFloat | 	newFloat _ self new: 2.	newFloat at: 1 put: ((mantissa bitAnd: 16r7F0000) bitShift: -16) + 16rFF80.	newFloat at: 2 put: (mantissa bitAnd: 16rFFFF).	^newFloat!positiveInfinity	"Answer floating point number representing positive infinity."	^PositiveInfinity copy! !Float initialize!!Float methodsFor: 'mathematical functions'!arcCos	"Answers with the angle in radians."	<primitive: 155>	^Halfpi - self arcSin! !!Float methodsFor: 'mathematical functions'!arcSin	"Answers with the angle in radians"	<primitive: 154>	self abs > 1.0 ifTrue: [self error: 'Value out of range'].	self abs = 1.0		ifTrue: [^Halfpi]		ifFalse: [^(self / (1 - (self * self)) sqrt) arcTan]! !!Float methodsFor: 'mathematical functions'!arcTan	"Answers with the angle in radians"	| theta term y eps i |	<primitive: 156>	self = 1.0 ifTrue: [^Fourthpi].	self = -1.0 ifTrue: [^Fourthpi negated].	self * self > 1.0		ifTrue: 			[theta _ Halfpi.			y _ -1.0 / (self * self).			term _ -1.0 / self abs]		ifFalse: 			[theta _ 0.0.			y _ 0.0 - (self * self).			term _ self abs].	i _ 1.	eps _ 1.0e-4.	[term abs > eps]		whileTrue: 			[theta _ theta + term.			term _ term * y * i asFloat / (i + 2) asFloat.			i _ i + 2].	^self sign asFloat * theta! !!Float methodsFor: 'mathematical functions'!exp	"see Computer Approximations, pp. 96-104, p. 205 (EXPB 1065)"	| a n1 x x2 P Q |	<primitive: 157>	self abs > 9212.0		ifTrue: ["Float maxVal ln"			"1.0 exp"			self error: 'exp overflow']		ifFalse: 			[x _ self / Ln2.			n1 _ 2.0 raisedTo: x truncated.			(x _ x - x truncated) >= 0.5				ifTrue: 					[n1 _ n1 * Sqrt2.					x _ x - 0.5].			x2 _ x * x.			"compute 2.0 power: x"			P _ Q _ 0.0.			ExpPCoefficients do: [:a | P _ P * x2 + a].			ExpQCoefficients do: [:a | Q _ Q * x2 + a].			^n1 * (Q + (x * P) / (Q - (x * P)))]! !!Float methodsFor: 'mathematical functions'!ln	"see Computer Approximations, pp. 105-111, p. 227 (LOGE 2663)"	| expt x x2 n P |	<primitive: 158>	self <= 0.0		ifTrue: [self error: 'ln not valid for ' , self printString]		ifFalse: 			[expt _ self exponent.			n _ Ln2 * (expt - 0.5).			"mantissa between 0.5 and 1.0"			x _ self timesTwoPower: 0 - expt.			x _ x * Sqrt2.			x _ x - 1.0 / (x + 1.0).			x2 _ x * x.			P _ 0.0.			LnCoefficients do: [:a | P _ P * x2 + a].			^n + (x * P)]"2.718284 ln 1.0"! !!Float methodsFor: 'mathematical functions'!log	"Base 10 logarithm"	<primitive: 159>	^self ln / 10.0 ln! !!Float methodsFor: 'mathematical functions'!floorLog: radix 	"quick computation of (self log: radix) floor"	| x |	self isNormal ifFalse: [^self error: 'Cannot compute floorLog: for ' , self printString].	self < radix ifTrue: [^0]. 	"self assumed positive"	self < radix squared ifTrue: [^1].	x _ 2 * (self floorLog: radix squared).	"binary recursion like ipow"	^x + (self / (radix raisedTo: x) floorLog: radix)! !!Float methodsFor: 'truncation and round off'!truncated	"Answer with a SmallInteger equal to the value of the receiver without 	its fractional part. The primitive fails if the truncated value cannot be 	represented as a SmallInteger. In that case, the code below will compute 	a LargeInteger truncated value. Essential. See Object documentation 	whatIsAPrimitive. "	<primitive: 51>	self isNormal ifFalse: [^self error: 'Cannot truncate Not-A-Numbers or infinities'].	^(self quo: 16383.0) * 16383 + (self rem: 16383.0) truncated! !!Float methodsFor: 'printing'!printOn: aStream 	"Check for non printing numbers like NAN's and infinities."	self isNAN		ifTrue: [(((self at: 1) = (Float notANumber at: 1)) and: [(self at: 2) = (Float notANumber at: 2)])				ifTrue: [aStream nextPutAll: 'Float notANumber '] 				ifFalse: [aStream nextPutAll: 'Float notANumber: ' , ((((self at: 1)						bitAnd: 16r7F)						bitShift: 16)						+ (self at: 2)) printString]]		ifFalse: [self isPositiveInfinity				ifTrue: [aStream nextPutAll: 'Float positiveInfinity']				ifFalse: [self isNegativeInfinity						ifTrue: [aStream nextPutAll: 'Float negativeInfinity']						ifFalse: [self printOn: aStream digits: 6]]]! !!Float methodsFor: 'testing'!isInfinity	"Answer true if I an IEEE infinity representation."		^self isPositiveInfinity | self isNegativeInfinity!isNAN	"answer true if I an a IEEE NAN (Not a Number)" 	^((self at: 1) allMask: 16r7F80) and: [((self at: 1) anyMask: 16r7F) or: [(self at:2) ~= 0]]!isNegativeInfinity	"Answer true if I an IEEE negative infinity representation."		^((self at: 1) = 16rFF80) and: [(self at:2) = 0]!isNormal	"Answer true if I am not an IEEE infinity or NAN representation."		^(self isInfinity or: [self isNAN]) not!isPositiveInfinity	"Answer true if I an IEEE positive infinity representation."		^((self at: 1) = 16r7F80)  and: [(self at:2) = 0]! !!BitEditor class methodsFor: 'class initialization'!initialize	"The Bit Editor overrides the use of the yellow button with	a different pop-up menu.  Initialize this menu."	YellowButtonMenu _ PopUpMenu labels:'acceptcancel'.	YellowButtonMessages _ #(accept cancel )		"BitEditor initialize."! !!Debugger methodsFor: 'compiler access'!bindingOf: aName forStore: aBoolean	"The compiler cannot find a binding for aName.  Answer an association, if any,	of aName and its value.  Answer nil if none.  aBoolean is true if aName is the	object of a store (i.e. appears on the left of an assignment.)   The receiver will	be consulted for bindings when computing sourceMap and when doing DoIts.  If	the method now being debugged was compiled in name environment different from	the present, we can still find missing names in the CompiledMethod's own literal table."	^context method literals		detect: [:lit | lit class == Association and: [aName = lit key]]		ifNone: [nil]! !!FileStream class methodsFor: 'class initialization'!initialize	SystemCall _ TekSystemCall.	OpenFileStreams _ OrderedCollection new.	"FileStream initialize"! !!Object methodsFor: 'copying'!shallowCopy	"Answer a copy of the receiver which shares the receiver's instance 	variables. "	| class newObject index |	class _ self class.	class isVariable		ifTrue: 			[index _ self basicSize.			newObject _ class basicNew: index.			[index > 0]				whileTrue: 					[newObject basicAt: index put: (self basicAt: index).					index _ index - 1]]		ifFalse: [newObject _ class basicNew].	index _ class instSize.	[index > 0]		whileTrue: 			[newObject instVarAt: index put: (self instVarAt: index).			index _ index - 1].	^newObject! !!SystemDictionary methodsFor: 'system backup-out'!getImageName	"Prompt the user for a snapshot file name.  Return immediately if an empty	name is typed. If the user does supply a file name, make sure that it can 	be opened correctly (all directories in the path must be valid).  	Notify an error otherwise."	| newImageName file |	FillInTheBlank		request: 'Enter name for image file'		displayAt: Sensor cursorPoint		centered: true		action: [:newImageName | ] 		initialAnswer: (self at: #ImageName).	(newImageName isEmpty or: [Disk isNil]) 		ifTrue: [^newImageName]. 	file _ FileStream fileNamed: newImageName.	file exists		ifTrue:			[file isDirectory				ifTrue: [self error: file fullName, ' is a directory']]		ifFalse:			[(file directory exists and: [file directory isDirectory])				ifFalse: [self error: file directory fullName, ' is not a directory']].	^Disk checkName: file fullName fixErrors: false! !!SystemDictionary methodsFor: 'private'!lowSpaceNotificationLoop	[true]		whileTrue: 			[LowSpaceSemaphore wait.			(self oopsLeft < self oopsLeftLimit and: [self coreLeft < self coreLeftLimit])				ifTrue: [ScheduledControllers interruptName: 'Space is Low: coreLeft=' , self coreLeft printString , '; oopsLeft=' , self oopsLeft printString].			self oopsLeft < self oopsLeftLimit				ifTrue: [ScheduledControllers interruptName: 'Space is Low: Running out of oops']				ifFalse: [self coreLeft < self coreLeftLimit ifTrue: [ScheduledControllers interruptName: 'Space is Low: Running out of memory']].			self resetSpaceLimits]! !!TextCollector methodsFor: 'private'!defaultContents	^ '' asText! !!Stream methodsFor: 'enumerating'!do: aBlock 	"Evaluate aBlock for each of the remaining elements of the receiver."	[self atEnd]		whileFalse: [aBlock value: self next]! !Smalltalk install !!Form class methodsFor: 'instance creation'!readFormFile: file	"Answer an instance of me with bitmap initialized from the external file.  The file format is:  fileCode(1), extent, offset, bits."	| newForm newWidth newHeight theBits  offsetX offsetY size |	file readOnly; binary.	file nextWord = 1 ifFalse: [^(self new extent: 8 @ 8) black].	"reads fileCode"	newForm _ self new.	newWidth _ file nextWord.	newHeight _ file nextWord.	offsetX  _ file nextWord.	offsetY _ file nextWord.	offsetX > 32767 ifTrue: [offsetX _ offsetX - 65536]. "stored two's-complement"	offsetY > 32767 ifTrue: [offsetY _ offsetY - 65536]. "stored two's-complement"	size _ newWidth + 15 // 16 * newHeight.	newForm 		extent: newWidth @ newHeight		offset: offsetX @ offsetY		bits: (WordArray new: size).	theBits _ newForm bits.	1 to: size do: [: index | theBits at: index put: file nextWord].	file close.	^newForm! !!Rectangle class methodsFor: 'instance creation'!fromUser: gridPoint	"Answer an instance of me that is determined by having the user 	designate the top left and bottom right corners. The gridding for user 	selection is gridPoint."	| originPoint newSelf oldSelf minCorner oldCursor|	oldCursor _ Sensor currentCursor.		originPoint _ Sensor cursorPoint grid: gridPoint.	gridPoint = (1@1)			ifTrue: [			Cursor origin showWhile:[				[Sensor redButtonPressed] 					whileFalse:						[originPoint _ Sensor cursorPoint]]]		ifFalse: [			Cursor origin showGridded: gridPoint while:[				[Sensor redButtonPressed] 					whileFalse:						[originPoint _ Sensor cursorPoint grid: gridPoint]]].	oldSelf _ 0@0 corner: 0@0.	newSelf _ self new origin: originPoint.	minCorner _ originPoint + gridPoint.	Sensor cursorPoint: minCorner.	gridPoint = (1@1)			ifTrue: [			Cursor corner showWhile: [				[Sensor redButtonPressed]					whileTrue: 						[newSelf corner: ((Sensor cursorPoint) max: minCorner).						(oldSelf areasDiffering: newSelf) do:							[:each | Display reverse: each mask: Form gray].						oldSelf _ newSelf copy]]]		ifFalse: [			Cursor corner showGridded: gridPoint while: [				[Sensor redButtonPressed]					whileTrue: 						[newSelf corner: ((Sensor cursorPoint grid: gridPoint) max: minCorner).						Cursor corner showGridded: gridPoint.						(oldSelf areasDiffering: newSelf) do:							[:each | Display reverse: each mask: Form gray].						oldSelf _ newSelf copy]]].	Display reverse: oldSelf mask: Form gray.	oldCursor show.	^newSelf	"Rectangle fromUser: 100@100."! !!Inspector methodsFor: 'field list'!fieldList	"Answer an Array consisting of 'self' and the instance variable names 	of the inspected object.  Up to 40 indices are given for variable 	length objects."	| max |	max _ object basicSize.	^(Array with: 'self'), object class allInstVarNames, (object class isVariable 			ifTrue: [(max <= 40						ifTrue: [1 to: max]						ifFalse: [(1 to: 30), (max - 10 to: max)]) 					collect: [:i | i printString]])! !Smalltalk at: #OSEnvironmentVariables put: nil !!Subtask class methodsFor: 'environments'!copyEnvironment	"Answer the environment with which smalltalk was invoked, in dictionary format."	^OSEnvironmentVariables deepCopy!currentEnvironment	"Answer the environment with which smalltalk was invoke, in a format 	 readable by the OS"	| env |	env _ OrderedCollection new: 20.	OSEnvironmentVariables keys do: [:eachKey | env add: eachKey asString , '=' , (OSEnvironmentVariables at: eachKey)].	^env!initializeEnvironment	"Initialize the internal record of the environment with which this image 	was invoked."	Smalltalk at: #OSEnvironmentVariables put: (TekSystemCall originalEnvironment)	"Subtask initializeEnvironment"! !Subtask initializeEnvironment!Smalltalk removeKey: #Environment !PipeStream removeSelector: #contentsOfEntireFile!DisplayScreen removeSelector: #writeBitmapOn:!!Debugger class methodsFor: 'instance creation'!context: aContext 	"Answer an instance of me that models the current state of the system.  The active	process has determined that a debugger should be set up."	| aDebugger |	aDebugger _ self new.	aDebugger		process: Processor activeProcess		context: aContext		interrupted: false.	^aDebugger! !!FileDirectory methodsFor: 'accessing'!fullName	"Answer the full path name of the receiver.  A trailing '/' is considered 	part of a directory name even if not explicitly stored."	 	 name = '.' 		ifTrue: [^'']		ifFalse: [name last = $/				ifTrue: [^name]				ifFalse: [^name, '/']]! !!FillInTheBlank class methodsFor: 'examples'!example1	"Example waits for you to click red button somewhere on the screen. 	Terminate by choosing menu command accept."	FillInTheBlank		message: 'What is your name?' 		displayAt: Sensor waitButton 		centered: true		action: [:answer | Transcript cr; show: answer] 		initialAnswer: ''	"FillInTheBlank example1."! !!FillInTheBlank class methodsFor: 'examples'!example2	"Example waits for you to click red button somewhere on the screen.  	Terminate by choosing menu command accept or typing carriage return."	FillInTheBlank		request: 'What is your name?' 		displayAt: Sensor waitButton 		centered: true		action: [:answer | Transcript cr; show: answer] 		initialAnswer: ''	"FillInTheBlank example2."! !!ParagraphEditor methodsFor: 'editing'!readKeyboard	"Key struck on the keyboard. Find out which one and, if special, carry 	  out the associated special action. Otherwise, add the character to 	 the stream of characters.  	  	This version has been modified to do immediate character echoing."	| typeAhead currentCharacter rightLimit delayNotExpired delay action undoEchoing startEchoLocation stopLineIndex stopStringIndex lastChar |	undoEchoing _ false.	self deselect.	typeAhead _ WriteStream on: (String new: 128).	beginTypeInBlock == nil		ifTrue: 			[UndoSelection _ self selection.			beginTypeInBlock _ startBlock copy].	"cache information for immediate character echoing"	currentFont _ paragraph textStyle fontAt: emphasisHere.	stopStringIndex _ stopBlock stringIndex.	stopLineIndex _ paragraph lineIndexOfCharacterIndex: stopStringIndex.	echoLocation _ stopBlock left @ ((paragraph topAtLineIndex: stopLineIndex)					+ paragraph textStyle baseline - currentFont ascent).	stopBlock character == nil		ifTrue: [((stopStringIndex > 1 					and: [(lastChar _ paragraph text at: stopStringIndex - 1) == Character cr])						or: [stopStringIndex = 1])				ifTrue: [echoLocation _ echoLocation + (0 @ paragraph textStyle lineGrid)]]		ifFalse: [undoEchoing _ stopStringIndex > 1 					and: [lastChar == Character cr 						or: [stopLineIndex ~= (paragraph lineIndexOfCharacterIndex: stopStringIndex - 1)]]].	startEchoLocation _ echoLocation copy.	rightLimit _ paragraph compositionRectangle right.	echoForm _ Form fromDisplay: (echoLocation corner: rightLimit @ (echoLocation y + currentFont height)).	delayNotExpired _ true.	sensor keyboardPressed ifTrue: [[echoLocation x <= rightLimit and: [delayNotExpired]]			whileTrue: [sensor keyboardPressed					ifTrue: 						[delayNotExpired _ startBlock ~= beginTypeInBlock | (startBlock = stopBlock).						currentCharacter _ sensor keyboardPeek.						action _ self perform: (Keyboard at: currentCharacter asciiValue + 1)									with: typeAhead.						"true indicates a special function operation is required, so stop reading"						action == true ifTrue: [^self].						"nil indicates that a character which requires immediate  						recomposition of the paragraph has been encountered. "						action == nil ifTrue: [delayNotExpired _ false]]					ifFalse: 						["wait a while to see if the user's fingers are still in motion"						delay _ 100.						[sensor keyboardPressed == false and: [delay > 0]]							whileTrue: [delay _ delay - 1].						delay = 0 ifTrue: [delayNotExpired _ false]]]].	undoEchoing ifTrue: [echoForm displayOn: Display at: startEchoLocation].	self replaceSelectionWith: (Text string: typeAhead contents emphasis: emphasisHere).	startBlock _ stopBlock copy.	self selectAndScroll! !!Number class methodsFor: 'instance creation'!readFrom: aStream 	"Answer an instance of me as described on the stream, aStream"	| value radix fraction fracpos sign |	radix _ 10.	sign _ (aStream peekFor: $-) ifTrue: [-1] ifFalse: [1].	value _ Integer readFrom: aStream.	(aStream peekFor: $r)		ifTrue: 			["<radix>r<integer>"			(radix _ value) < 2 ifTrue: [^self error: 'Invalid Radix'].			value _ Integer readFrom: aStream radix: radix].	(aStream peekFor: $.)		ifTrue: 			["<integer>.<fraction>"			(aStream atEnd not and: [aStream peek digitValue between: 0 and: radix - 1])				ifTrue: 					[fracpos _ aStream position.					fraction _ Integer readFrom: aStream radix: radix.					radix _ radix asFloat.					fraction _ 						fraction asFloat / (radix raisedTo: aStream position - fracpos).					value _ value asFloat + (value < 0									ifTrue: [fraction negated]									ifFalse: [fraction])]				ifFalse: 					["oops - just <integer>."					aStream skip: -1.		"un-gobble the period"					^value * sign									"Number readFrom: (ReadStream on: '3r-22.2')"]].	(aStream peekFor: $e)		ifTrue: 			["<integer>e<exponent>"			^value * sign * (radix raisedTo: (Integer readFrom: aStream))].	^value * sign! !!Scanner methodsFor: 'public access'!scanFieldNames: stringOrArray	"Answer with an Array of strings which are the identifiers in the input string.	If passed an Array, just answer with that Array (it has already been scanned)."	| strm |	(stringOrArray isMemberOf: Array)		ifTrue: [^stringOrArray].	self scan: (ReadStream on: stringOrArray asString).	strm _ WriteStream on: (Array new: 10).	[tokenType = #doIt]		whileFalse: 			[tokenType = #word ifTrue: [strm nextPut: token].			self scanToken].	^strm contents	"Scanner new scanFieldNames: 'abc def ghi'	 Scanner new scanFieldNames: #('abc' 'def' 'ghi' )	Scanner new scanFieldNames: 'abc def ghi (abc def ghi )'"! !!TekSystemCall class methodsFor: 'system dependent operations'!vfork	"Create a new child task.  The new task does not receive a copy of	the entire address space, instead the parent and child processes	share memory.  Return the child task id in D0."	^(self new) operation: 56;		D0In: nil		D0Out: true		A0In: nil		A0Out: false;		systemOperation! !!ChangeScanner methodsFor: 'expression scanning'!scanClassExpression: class do: aBlock	"Scan an expression beginning with a class name.  This might be a class   	definition, a class removal, a class comment change, a class initialization,	a method removal, or a doIt."	| firstToken selector newName |	firstToken _ token.	self scanToken.	firstToken = 'removeSelector:'		ifTrue: 			[(tokenType == #literal and: [token isKindOf: Symbol]) ifTrue:				[selector _ token.				self scanToken.				^aBlock value: (MethodOtherChange new className: class; selector: selector; type: #remove)]].	firstToken = 'rename:'		ifTrue: 			[(tokenType == #literal and: [token isKindOf: Symbol]) ifTrue:				[newName _ token.				self scanToken.				aBlock value: (ClassOtherChange new className: class; type: #rename).				^aBlock value: (ClassOtherChange new className: newName; type: 'rename to' asSymbol)]].	firstToken = 'comment:'		ifTrue:			[tokenType == #string				ifTrue:					[self scanToken.					^aBlock value: (ClassCommentChange new className: class)]].	(#('subclass:' 'variableSubclass:' 'variableByteSubclass:' 'variableWordSubclass:') includes: firstToken)		ifTrue:			[^self scanClassDefinition: firstToken className: class do: aBlock].	(firstToken = 'initialize' and: [tokenType == #doIt])		ifTrue:			[^aBlock value: (ClassOtherChange new className: class; type: #initialize)].	firstToken = 'removeFromSystem'		ifTrue:			[^aBlock value: (ClassOtherChange new className: class; type: #remove)].	firstToken = 'instanceVariableNames:'		ifTrue:			[tokenType == #string				ifTrue:					[self scanToken.					^aBlock value: (ClassOtherChange new className: class; type: 'inst vars for' asSymbol)]].	^nil! !!Cursor class methodsFor: 'current cursor'!currentCursor: aCursor 	"Make the instance of cursor, aCursor, be the current cursor.  Display	it.  Create an error if the argument is not a Cursor."	CurrentCursor == aCursor ifTrue: [^self].	aCursor class == self		ifTrue: 			[CurrentCursor _ aCursor.			aCursor beCursor]		ifFalse: [self error: 'The new cursor must be an instance of class Cursor']! !!InputSensor methodsFor: 'current cursor'!currentCursor: newCursor 	"Set newCursor to be the displayed Cursor form."	CurrentCursor offset = newCursor offset		ifFalse: [self primCursorLocPut: self cursorPoint + newCursor offset].	CurrentCursor _ newCursor.	Cursor currentCursor: CurrentCursor! !!StringHolderView methodsFor: 'displaying'!displayView: difference 	"Reposition text after a move operation."	(self controller isKindOf: ParagraphEditor)		ifTrue: [controller paragraph moveBy: difference with: self insetDisplayBox]! !!View methodsFor: 'private'!computeInsetDisplayBox	"Compute the View's inset display box by intersecting the superView's inset 	display box with the View's window transformed to display coordinates and 	then inseting the result by the border width. It is sent by 	View|insetDisplayBox if the inset display box is nil."	self isTopView		ifTrue:			[^(self displayTransform: self getWindow) insetBy: borderWidth]		ifFalse:			[^(superView insetDisplayBox				intersect: (self displayTransform: self getWindow))						insetBy: borderWidth]! !PipeStream removeSelector: #binary!PipeStream removeSelector: #text!StandardSystemView removeSelector: #displayBorder!!Checker class methodsFor: 'static checks'!classVariablesNotReferenced	"Return a list of classes and class variables defined in, but not used in that class	Checker classVariablesNotReferenced"	| aStream |	aStream _ WriteStream on: (Array new: 50).	Smalltalk allBehaviorsDo:		[:class |		class classVarNames do:			[:classVarName |			((class whichSelectorsReferTo: (class classPool associationAt: classVarName)) isEmpty				and: [(class class whichSelectorsReferTo: (class classPool associationAt: classVarName)) isEmpty])						ifTrue: [aStream nextPut: class name, ' ', classVarName]]].	^aStream contents! !!Checker class methodsFor: 'printing checks'!printClassVariablesNotReferencedOn: aFileStream 	"Print a list of classes and Class variables defined in, but not used in that 	class 	Checker printClassVariablesNotReferencedOn: 		(Disk file: 'smalltalk.unrefedCvars') "	self classVariablesNotReferenced do: [:cvar | aFileStream nextPutAll: cvar; cr].	aFileStream close! !!Inspector methodsFor: 'field list'!fieldList	"Answer an Array consisting of 'self' and the instance variable names of the inspected object.  A maximum of 'showing' fields are displayed."	| max showing |	showing _ 100.	max _ object basicSize.	^(Array with: 'self'), object class allInstVarNames, (object class isVariable 			ifTrue: [(max <= showing						ifTrue: [1 to: max]						ifFalse: [(1 to: showing // 3 * 2), (max - (showing // 3) to: max)]) 					collect: [:i | i printString]])! !!StandardSystemView methodsFor: 'framing'!getFrame	"Ask the user to designate a rectangular area in which the receiver 	should be displayed." 	| origin frame newFrame initialExtent minSize maxSize delay nBlock toggle |	Sensor waitNoButton.	self isUnlocked		ifTrue: [initialExtent _ self minimumSize]		ifFalse: [initialExtent _ self displayBox extent.				Sensor cursorPoint: self displayBox origin + (2@2)].	frame _ 0@0 corner: 0@0.	minSize _ self minimumSize.	maxSize _ self maximumSize.	delay _ Delay forMilliseconds: 250.	nBlock _ [:j | toggle ifTrue: [j negated] ifFalse: [j]].	Cursor origin		showWhile: 			[[origin _ Sensor cursorPoint.			newFrame _ (origin _ Sensor cursorPoint) extent: initialExtent.					(newFrame areasDiffering: frame) do:						[:each | Display reverse: each mask: Form gray].					frame _ newFrame.					Sensor redButtonPressed]		 	 whileFalse].	toggle _ false.	[Sensor redButtonPressed	  	ifTrue: [true]	 	ifFalse: [delay wait.			Sensor redButtonPressed]]	  whileTrue:		[toggle _ toggle not.		frame _ frame negated.		Sensor cursorPoint: (nBlock value: frame origin).		(toggle		  ifTrue:			[Cursor corner]		  ifFalse:			[Cursor origin])		   showWhile:			[[origin _ nBlock value: Sensor cursorPoint.			Sensor redButtonPressed]			  whileTrue: 				[newFrame _					(origin extent:						(((origin corner: frame corner)						  extent max: minSize) min: maxSize)).				(newFrame areasDiffering: frame) do: [:each |					Display reverse: (nBlock value: each) mask: Form gray].				frame _ newFrame]]].	^nBlock value: frame! !!Rectangle methodsFor: 'transforming'!negated	"answers the Rectangle reflected across the origin from the receiver"	^self corner negated corner: self origin negated! !!Point methodsFor: 'arithmetic'!negated	"Answer a Point whose coordinates have been negated"	^x negated @ y negated! !!Encoder methodsFor: 'results'!tempNames	| tempNodes |	tempNodes _ (scopeTable select: [:node | node isTemp])		asSortedCollection: [:n1 :n2 | n1 code <= n2 code].	^tempNodes collect: [:node | node key]! !!Browser methodsFor: 'class functions'!removeClass	| class count refs | 	self changeRequest ifFalse: [^self].	class _ self nonMetaClass.	(self confirm: 'Are you certain that youwant to remove the class ', class name, '?')		ifTrue: 		[Transcript show: 'checking for subclasses'; cr.		class subclasses size > 0			ifTrue: [self notify: class name , ' has subclasses'].		Transcript show: 'checking for instances'; cr.		(count _ class instanceCount) > 0			ifTrue: [self notify: class name , ' has ', count printString , ' instances'].		Transcript show: 'checking for references'; cr.		(refs _ Smalltalk allCallsOn: (Smalltalk associationAt: class name)) isEmpty			ifFalse: [self notify: 'Other methods still reference this class.See ''class refs'' menu item.'].		class removeFromSystem.		self newClassList: nil]! !!TekSystemCall class methodsFor: 'portable operations'!execSystemUtility: aCommand withArgs: anOrderedCollection 	"Execute a binary program and read the entire results through a pipe.	No mechanism for input to the executable program is provided.	Create an error if the program cannot be exec'ed or if the program	terminates abnormally."	| pipe task inputSide resultOfProgram |	pipe _ Pipe new.	task _ Subtask				fork: aCommand				withArgs: anOrderedCollection				then: 					[pipe mapWriteTo: 1.					pipe mapWriteTo: 2.					pipe closeWrite.					pipe closeRead].	task start isNil		ifTrue: 			[pipe closeWrite.			pipe closeRead.			self error: 'Cannot execute ' , aCommand].	pipe closeWrite.	Cursor execute		showWhile: 			[inputSide _ PipeReadStream openOn: pipe.			resultOfProgram _ inputSide contentsOfEntireFile].	task waitOn.	inputSide close.	task abnormalTermination ifTrue: [self error: 'Error from system utility: ' , (resultOfProgram copyUpTo: Character cr)].	task release.	^resultOfProgram! !!TekSystemCall class methodsFor: 'system dependent operations'!controlPty: fileDescriptor command: cmd mode: modeByte 	"Control via the master end the slave side of a pty. 	The fileDescriptor is a master mode pseudo-terminal file 	descriptor. The state of the channel is returned in D0. The 	argument cmd is a subfunction and modeByte is the 	argument to the subfunction."	^(self new: 2)		operation: 65		with: cmd		with: modeByte;		D0In: fileDescriptor		D0Out: true		A0In: nil		A0Out: false; systemOperation!createPty	"Create a pseudo terminal master/slave device pair, known as a channel.	The file descriptor for slave access is returned in D0 and the file descriptor	for master access is returned in A0.  Once the channel has been created,	additional slave accesses may be created using TekSystemCall open:mode: . 	TekSystemCall ofstat:buffer: may be used to get information about the status	of master and slave sides."	^(self new)		operation: 62;		D0In:nil D0Out:true A0In:nil A0Out:true;		systemOperation! fcntl: fileDescriptor function: controlFunction 	"Change or interrogate the behavior of a file.	The state of the modifiable behaviors is returned in D0."	^(self new: 1)		operation: 69		with: controlFunction;		D0In: fileDescriptor  D0Out:true A0In:nil A0Out:false;		systemOperation!rump: resourceName operation: resourceOperation	"Create, destroy, enque or dequeue a named resource.  Used to provide a mechanism for controlling access to physical resources.  The resourceName must be no larger than 15 characters.  ResourceOperation should be a SmallInteger , 1 representing enqueue, 2 representing dequeue, 3 representing create and 4 representing destroy."	^(self new: 1)		operation: 66		with: resourceOperation;		D0In: nil  D0Out:false A0In:resourceName, StringTerminator A0Out:false;		systemOperation! !!TekSystemCall class methodsFor: 'general inquiries'!maxNameSize	"Answer the maximum number of characters permissible for file names."	^54! !!TekSystemCall class methodsFor: 'machine type'!getMachineType	"Get the machine type as a long word.  The machine type 	is returned in the upper half of the register D0 as a hex number	, e.g. 4406 = 16r44060000.  The number must be coerced to	a LargePositiveInteger and bit shifted:	((TekSystemCall getMachineType value; D0Out)  + 16r80000000 bitShift: -16) printStringRadix: 16	The returned type is from a previous setMachineType or by the original 	reading of the boot ROMS at startup."	^(self new) operation: 75;		D0In: nil		D0Out: true		A0In: nil		A0Out: false; displayOperation!getRealMachineType	"Get the machine type as a long word.  The machine type 	is from the original reading of the boot ROMS at startup.  	The machine type is returned in the upper half of register 	D0 as a hex number, e.g. 4406 = 16r44060000"	^(self new) operation: 77;		D0In: nil		D0Out: true		A0In: nil		A0Out: false; displayOperation!setMachineType: aType	"Set the machine type to a long word.  See TekSystemCall getMachineType	for the proper format of the long word passed in D0.  The newly	set machine type is returned in D0."	^(self new)		operation: 76;		D0In: aType  D0Out: true  A0In: nil  A0Out: false;		displayOperation! !PipeReadStream comment:'I represent a stream interface for reading from a pipe.  I buffer data from the pipe to avoid extra reads whenever possible.  I also implement protocol for reading all the data available from the pipe by using the size of the pipe to regulate how much to read.  Trying to read more data than is available can result in blocked reads.'!PipeStream comment:'I represent a stream interface to a pipe.  I am an abstract class implementing protocol common to PipeReadStream and PipeWriteStream, such as size, close and accessing methods that are inappropriate for pipes to implement. '!PipeWriteStream comment:'I represent a stream interface for writing to a pipe.  I do not buffer data written to the pipe.'!WorkspaceView comment:'I view an instance of Workspace, which contains text and a local variable dictionary.  Much of my protocol is inherited.'!InputState comment:'I represent the state of the user input devices.Instance Variables:		x  <Integer> mouse X location 		y  <Integer> mouse Y location 		bitState  <Integer> mouse button and keyset state 		lshiftState  <1 or 0> state of left shift key 		rshiftState  <1 or 0> state of right shift key 		ctrlState  <2 or 0> state of ctrl key 		lockState  <4 or 0> state of shift-lock key 		metaState  <Integer> combined state of the meta keys 		keyboardQueue  <SharedQueue> of keyboard characters 		deltaTime  <Integer> sampling ticks since last setting of baseTime 		baseTime  <Integer> millisecond timer at last resync 		timeProtect	<Semaphore> provides mutual exclusion for updating baseTime		'!!ScrollController methodsFor: 'basic control sequence'!controlInitialize	super controlInitialize.	scrollBar region: (0 @ 0 extent: 32 @ (view displayBox height + 2)).	marker region: self computeMarkerRegion.	scrollBar _ scrollBar align: scrollBar topRight with: view displayBox topLeft - (0 @ 1).	marker _ marker align: marker topCenter with: scrollBar inside topCenter.	savedArea _ Form fromDisplay: scrollBar.	scrollBar displayOn: Display.	self moveMarker! !!ScrollController methodsFor: 'scrolling'!canScroll	^marker region height < scrollBar inside height!canScrollDown	^marker region height < scrollBar inside height and: [marker region top > scrollBar inside top]!canScrollUp	| markerHeight scrollBarHeight | 	"Answer whether there is information that is not visible and can be seen	by scrolling up."	markerHeight _ marker region height.	scrollBarHeight _ scrollBar inside height.	^(markerHeight < scrollBarHeight) and: [ (scrollBar inside bottom - marker region bottom) > (2 - (scrollBarHeight//markerHeight>5 ifTrue: [2] ifFalse: [scrollBarHeight//markerHeight>2 ifTrue: [1] ifFalse:[0]]))	"fuzz"]! !!ScrollController methodsFor: 'marker adjustment'!moveMarker	self moveMarker: self markerDelta negated!moveMarker: t1 	Display fill: marker mask: scrollBar insideColor.	marker _ marker translateBy: 0 @ ((t1 min: scrollBar inside bottom - marker bottom)						max: scrollBar inside top - marker top).	marker displayOn: Display! !!ScrollController methodsFor: 'private'!scrollDown	self changeCursor: Cursor down.	self canScrollDown ifTrue: [[sensor anyButtonPressed]			whileTrue: [self canScrollDown					ifTrue: 						[self scrollViewDown.						self moveMarker]]].	sensor waitNoButton!scrollUp	self changeCursor: Cursor up.	self canScrollUp ifTrue: [[sensor anyButtonPressed]			whileTrue: [self canScrollUp					ifTrue: 						[self scrollViewUp.						self moveMarker]]].	sensor waitNoButton! !!SystemDictionary methodsFor: 'time-versions'!copyright	"The Smalltalk copyright.			Copyright (c) 1983 Xerox Corp.  All rights reserved.			Enhancements Copyright (c) 1984, 1985, 1986 Tektronix Inc. All rights reserved.	"	^'Copyright (c) 1983 Xerox Corp.  All rights reserved.Enhancements Copyright (c) 1984, 1985, 1986 Tektronix Inc. All rights reserved.'! !!SystemDictionary methodsFor: 'time-versions'!version	"Answer the version of this Smalltalk release." 	^'Smalltalk-80 version T2.1.3, of March 13, 1986'! !