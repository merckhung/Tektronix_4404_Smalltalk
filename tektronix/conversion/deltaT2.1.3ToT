!Behavior methodsFor: 'testing method dictionary'!whichSelectorsReferTo: literal special: specialFlag byte: specialByte	"Answer a collection of selectors whose methods access the argument as a literal."	| who method methodArray index arraySize |	who_ OrderedCollection new: 32.	methodArray _ methodDict methodArray.	arraySize _ methodArray size.	index _ 0.	[(index _ index + 1) <= arraySize] whileTrue:		[(method _ methodArray at: index) == nil ifFalse:			[((method refersToLiteral: literal) or:				[specialFlag and: [method scanFor: specialByte]])					ifTrue: [who add: (methodDict basicAt: index)]]].	^who	"Rectangle whichSelectorsReferTo: #+."! !!Debugger methodsFor: 'stack manipulation'!step	"Some context is selected (force top if none).  When this is so, either 	some message is about to be sent in that context, or that context is 	about to return.  Step will cause the next message to be sent or the 	return to be executed.  In either case, the debugger regains control 	so that you can step your way down through a method, and out to 	the caller when it returns.  Note that the execution invoked by step 	is actually simulated, so it will run much slower than normal"	| currentContext |	self checkContextSelection.	processHandle interrupted ifFalse: [processHandle topContext push: processHandle proceedValue].	processHandle interrupted: true.	"simulation leaves same state as interrupting"	context == processHandle topContext		ifTrue: 			[currentContext _ context.			currentContext stepToSendOrReturn.			currentContext willReturn				ifTrue: 					[currentContext _ currentContext step.					currentContext stepToSendOrReturn.					self resetContext: currentContext]				ifFalse: 					[currentContext _ currentContext completeCallee: currentContext step.					currentContext == context ifTrue:[					self changed: #pc.					self updateInspectors] ifFalse:[ self resetContext: currentContext]]]		ifFalse: 			["Have to complete any stuff called from here"			context completeCallee: processHandle topContext.			self resetContext: context]! !!ContextPart methodsFor: 'system simulation'!completeCallee: aContext	"Simulate the execution of bytecodes until a return to the receiver (or a context that called the receiver)."	| ctxt current |	self class initPrimitives.	ctxt _ aContext.	[ctxt == current or: [ctxt hasSender: self]]		whileTrue: 			[current _ ctxt.			ctxt _ ctxt step].	ctxt == self ifTrue: [self stepToSendOrReturn].	^ctxt! !ExternalStream	subclass: #FileStream	instanceVariableNames: 'name directory mode fileDescriptor filePosition fileMode '	classVariableNames: 'BufferSize OpenFileStreams SystemCall '	poolDictionaries: ''	category: 'Files-Streams'!!FileStream class methodsFor: 'class initialization'!initialize	SystemCall _ TekSystemCall.	OpenFileStreams _ OrderedCollection new.	BufferSize _ 1024	"FileStream initialize"! !FileStream initialize!!Form class methodsFor: 'instance creation'!readFormFile: file	"Answer an instance of me with bitmap initialized from the external file. 	The file format is:  fileCode(1), extent, offset, bits."	| newForm newWidth newHeight theBits  offsetX offsetY size |	file readOnly; binary.	file nextWord = 1 ifFalse: [^(self new extent: 8 @ 8) black].	"reads fileCode"	newForm _ self new.	newWidth _ file nextWord.	newHeight _ file nextWord.	offsetX  _ file nextSignedInteger.	offsetY _ file nextSignedInteger.	size _ newWidth + 15 // 16 * newHeight.	newForm 		extent: newWidth @ newHeight		offset: offsetX @ offsetY		bits: (WordArray new: size).	theBits _ newForm bits.	file nextWords: size into: theBits.	file close.	^newForm! !!ExternalStream methodsFor: 'nonhomogeneous accessing'!nextBytes: anInteger into: aCollection 	"Copy the next anInteger elements from the receiver into 	aCollection. Byte-sized-element collections are filled with 	anInteger bytes.  Word-sized-element collections are filled	with anInteger elements, but each element is filled with	only a byte-sized number.  Answer aCollection."	^self next: anInteger into: aCollection!nextWords: anInteger into: aCollection 	"Copy the next anInteger elements from the receiver into   	aCollection. Word-sized-element collections are filled   	with anInteger word-sized elements.  Byte-sized-element 	collections are filled with (anInteger * 2) byte-sized 	elements. Answer aCollection."	aCollection class isWords		ifTrue: [^self bulkRead: anInteger into: aCollection]		ifFalse: ["bytes"			anInteger * 2 > (readLimit - position)	"these are always recorded in bytes"				ifTrue: [^self bulkRead: anInteger * 2 into: aCollection]				ifFalse: [^self next: anInteger * 2 into: aCollection]]! !!ExternalStream methodsFor: 'private'!bulkRead: size into: buffer	"Read a large amount of data into the buffer."	^self subclassResponsibility! !!TekSystemCall class methodsFor: 'portable operations'!freeFileDescriptors	"Answer the number of available file descriptors."	| fdns sysCall size |	fdns _ OrderedCollection new: 32.	[true]		whileTrue: [(sysCall _ self open: '/dev/null' mode: 0) invoke				ifTrue: [fdns add: sysCall D0Out]				ifFalse: 					[size _ fdns size.					fdns do: 						[:each | 						TekSystemCall closeFile: each].					^size]]!read: fileDescriptor into: aStringOrByteArray 	"Fill aStringOrByteArray with data from the file referred to by fileDescriptor.	Answer the number of bytes read.  Answer zero if at end. "	| sysCall size|	size _ aStringOrByteArray size.	aStringOrByteArray class isWords ifTrue: [size _ size * 2].	fileDescriptor isNil ifTrue: [^self error: 'Invalid file descriptor'].	sysCall _ self				read: fileDescriptor				buffer: aStringOrByteArray				nbytes: size.	sysCall invoke 		ifTrue: [ "Successful"			(sysCall D0Out > size)				ifTrue: [self error: 'Read call returns incorrects number of bytes '] 				ifFalse: [ ^sysCall D0Out]]		ifFalse: [ "Failed"			(sysCall isInterrupted)				ifTrue: [^self read: fileDescriptor into: aStringOrByteArray ]				ifFalse: [sysCall issueError]]! !!FileStream methodsFor: 'accessing'!next: anInteger into: aCollection	"Copy the next anInteger bytes from the receiver into aCollection.	If aCollection has word-sized-elements, each element is filled	with byte-sized numbers.  Answer aCollection."	| howManyRead increment |	(anInteger > (readLimit - position) and: [aCollection class isBytes])		ifTrue: [^self bulkRead: anInteger into: aCollection].	howManyRead _ 0.	[howManyRead < anInteger] whileTrue:		[self atEnd			ifTrue:				[self pad: aCollection from: (howManyRead + 1) to: anInteger.				^aCollection]			ifFalse:				[increment _ (readLimit - position) min: (anInteger - howManyRead).				aCollection					replaceFrom: howManyRead + 1					to: (howManyRead _ howManyRead + increment)					with: collection					startingAt: position + 1.				position _ position + increment]].	^aCollection! !!FileStream methodsFor: 'private descriptor modes'!freeFileDescriptorFor: fileName	"File descriptors may be a scarce resource.  Close an open FileStream, if necessary,	to free up a file descriptor."	(OpenFileStreams		detect: [:each | each fullName = fileName]		ifNone: [^OpenFileStreams size < SystemCall freeFileDescriptors					ifFalse: [OpenFileStreams first close]]) close! !!FileStream methodsFor: 'private'!appendFileStream: aFileStream 	"Write the contents of another file stream to the receiver 	which is also a fileStream.  Use 1K buffers."	| size buffer bufferClass |	size _ aFileStream size - aFileStream position.	bufferClass _ aFileStream isBinary				ifTrue: [ByteArray]				ifFalse: [String].	size >= BufferSize ifTrue: [buffer _ bufferClass new: BufferSize].	size // BufferSize timesRepeat: 			[aFileStream next: BufferSize into: buffer.			self nextPutAll: buffer].	size _ size \\ BufferSize.	size > 0 ifTrue: 			[buffer _ bufferClass new: size.			aFileStream next: size into: buffer.			self nextPutAll: buffer].	^aFileStream!backupName	"Answer a name suitable for a backup copy of the receiver.  Use the receiver's	name suffixed with the suffix string."	| fullName prefixSize suffixOrigin |	fullName _ self fullName.	prefixSize _ fullName findLast: [:char | char = $/].	suffixOrigin _ (fullName size min: (SystemCall maxNameSize + prefixSize - SystemCall suffixString size)) + 1.	^fullName		copyReplaceFrom: suffixOrigin		to: fullName size		with: SystemCall suffixString!bulkRead: size into: buffer	"Read a large amount of data into the buffer."	| pos returnedSize |	writeLimit > 0 ifTrue: [self flush.  writeLimit _ 0].	self readAccess.	pos _ self position.	self flush.	SystemCall seek: fileDescriptor to: pos.	returnedSize _ SystemCall read: fileDescriptor into: buffer.	self position: pos + returnedSize.	^buffer!setName: aString directory: aFileDirectory	"Set the receiver's name to aString and directory to aFileDirectory."	name _ aString.	directory _ aFileDirectory.	collection _ String new: BufferSize.	position _ readLimit _ writeLimit _ 0.	filePosition _ 0.! !!ProcessHandle methodsFor: 'control'!resumeProcess	| aScheduledController |	aScheduledController _ ScheduledControllers activeController.	aScheduledController view erase.	process suspendedContext method == (Process compiledMethodAt: #terminate)		ifFalse:			[resumeContext == process suspendedContext ifFalse:				[process popTo: resumeContext]. 			controller == nil				ifTrue:					[process resume.					self release.					aScheduledController closeAndUnscheduleNoErase.					^ScheduledControllers searchForActiveController]				ifFalse:					[ScheduledControllers						activeControllerNoTerminate: controller  "NoTerminate"						andProcess: process]].	"if old process was terminated, just terminate current one"	self release.  "must precede close because it tries to terminate"	aScheduledController closeAndUnscheduleNoErase.	Processor terminateActive! !!ExternalStream methodsFor: 'nonhomogeneous accessing'!nextNumber: n 	"Answer the next n bytes as a positive Integer or LargePositiveInteger."	| s |	n <= SmallInteger maxBytes		ifTrue: 			[s _ 0.			n timesRepeat: [s _ s * 256 + self next].			^s].	s _ LargePositiveInteger new: n.	1 to: n do: [:i | s digitAt: n + 1 - i put: self next].	"reverse order of significance"	^s truncated!nextNumber: n put: v 	"Append to the receiver the argument, v, which is a positive SmallInteger or	a LargePositiveInteger, as the next n bytes.  Possibly pad with leading zeros."	| vlen i |	vlen _ v digitLength.	n < vlen		ifTrue: [self error: 'number too big']		ifFalse: [n > vlen ifTrue: [self next: n - vlen put: 0]].	"pad beginning with 0's"	1 to: vlen do: [:i | self nextPut: (v digitAt: vlen + 1 - i)]! !!Spline methodsFor: 'displaying'!displayOn: aDisplayMedium transformation: aTransformation clippingBox: clipRect rule: anInteger mask: aForm 	"Get the scaled and translated path of newKnots."	| newKnots newSpline |	newKnots _ aTransformation applyTo: self.	newSpline _ self species new.	newKnots do: [:knot | newSpline add: knot].	newSpline form: self form.	newSpline		displayOn: aDisplayMedium		at: 0 @ 0		clippingBox: clipRect		rule: anInteger		mask: aForm! !!LinearFit methodsFor: 'displaying'!displayOn: aDisplayMedium transformation: aTransformation clippingBox: clipRect rule: anInteger mask: aForm 	"Get the scaled and translated Path."	| newLinearFit transformedPath |	transformedPath _ aTransformation applyTo: self.	newLinearFit _ self species new.	transformedPath do: [:point | newLinearFit add: point].	newLinearFit form: self form.	newLinearFit		displayOn: aDisplayMedium		at: 0 @ 0		clippingBox: clipRect		rule: anInteger		mask: aForm! !!Path class methodsFor: 'examples'!example	"Creates a Path from mousePoints and displays it several ways on the display 	screen.  Each path displays using a different form.  A path 	is indicated by pressing the red mouse button in sequence;  press any other 	mouse button to terminate."	| aPath aForm p1 f1 flag |	aForm _ Form new extent: 2 @ 40.	"creates a form one inch long"	aForm black.	"turns it black"	aPath _ Path new.	aPath form: aForm.	"use the long black form for display"	flag _ true.	[flag]		whileTrue: 			[Sensor waitButton.			Sensor redButtonPressed				ifTrue: 					[aPath add: Sensor waitButton.					Sensor waitNoButton.					aForm displayOn: Display at: aPath last]				ifFalse: [flag _ false]].	Display white.	aPath displayOn: Display.			"the original path"	p1 _ aPath translateBy: 0 @ 300.	f1 _ Form new extent: 40 @ 40.	f1 gray.	p1 form: f1.	p1 displayOn: Display.		"the translated path"	Sensor waitNoButton	"Path example."! !!Path methodsFor: 'displaying'!displayOn: aDisplayMedium transformation: displayTransformation clippingBox: clipRectangle rule: ruleInteger mask: aForm 	"Displays this path, translated and scaled by aTransformation."	"get the scaled and translated Path."	| newPath transformedPath |	transformedPath _ displayTransformation applyTo: self.	newPath _ self species new.	transformedPath do: [:point | newPath add: point].	newPath form: self form.	newPath		displayOn: aDisplayMedium		at: 0 @ 0		clippingBox: clipRectangle		rule: ruleInteger		mask: aForm! !!Path methodsFor: 'transforming'!scaleBy: aPoint 	"Answers with a new Path scaled by aPoint.  Does not effect the current data in 	this Path."	| newPath |	newPath _ self species new: self size.	newPath form: self form.	collectionOfPoints do: 		[:element | 		newPath add: 				(aPoint x * element x) truncated @ (aPoint y * element y) truncated].	^newPath!translateBy: aPoint 	"Answers with a new instance of Path whose elements are translated by aPoint.  	Does not effect the elements of this Path."	| newPath |	newPath _ self species new: self size.	newPath form: self form.	collectionOfPoints do: 		[:element | 		newPath add: 			(element x + aPoint x) truncated @ (element y + aPoint y) truncated].	^newPath! !!Line methodsFor: 'displaying'!displayOn: aDisplayMedium transformation: aTransformation clippingBox: clipRect rule: anInteger mask: aForm 	| newPath newLine |	newPath _ aTransformation applyTo: self.	newLine _ self species new.	newLine beginPoint: newPath firstPoint.	newLine endPoint: newPath secondPoint.	newLine form: self form.	newLine		displayOn: aDisplayMedium		at: 0 @ 0		clippingBox: clipRect		rule: anInteger		mask: aForm! !!Curve methodsFor: 'displaying'!displayOn: aDisplayMedium transformation: aTransformation clippingBox: clipRect rule: anInteger mask: aForm 	| transformedPath newCurve |	transformedPath _ aTransformation applyTo: self.	newCurve _ self species new.	newCurve firstPoint: transformedPath firstPoint.	newCurve secondPoint: transformedPath secondPoint.	newCurve thirdPoint: transformedPath thirdPoint.	newCurve form: self form.	newCurve		displayOn: aDisplayMedium		at: 0 @ 0		clippingBox: clipRect		rule: anInteger		mask: aForm! !!Circle methodsFor: 'displaying'!displayOn: aDisplayMedium transformation: aTransformation clippingBox: clipRect rule: anInteger mask: aForm 	1 to: 4 do: 		[:i | 		super quadrant: i.		super			displayOn: aDisplayMedium			transformation: aTransformation			clippingBox: clipRect			rule: anInteger			mask: aForm]! !!Arc methodsFor: 'displaying'!displayOn: aDisplayMedium transformation: aTransformation clippingBox: clipRect rule: anInteger mask: aForm 	| newArc tempCenter |	newArc _ self species new.	tempCenter _ aTransformation applyTo: self center.	newArc center: tempCenter x truncated @ tempCenter y truncated.	newArc quadrant: self quadrant.	newArc radius: (self radius * aTransformation scale x) truncated.	newArc form: self form.	newArc		displayOn: aDisplayMedium		at: 0 @ 0		clippingBox: clipRect		rule: anInteger		mask: aForm! !!PipeStream class methodsFor: 'instance creation'!openOnFdn: aFileDescriptor	^(self basicNew) initializeOnFdn: aFileDescriptor! !Object	subclass: #Pipe	instanceVariableNames: 'readFdn writeFdn fileDescriptor '	classVariableNames: ''	poolDictionaries: ''	category: 'OS-Interface'!!Pipe methodsFor: 'accessing'!fileDescriptor	"Answer the descriptor to be accessed for streaming over 	data, either the readFdn or the writeFdn."	^fileDescriptor! !!Pipe methodsFor: 'fdn management'!fileDescriptor: anFdn 	"Store the argument as the descriptor to be accessed for 	streaming over data."	anFdn = readFdn ifFalse: [anFdn = writeFdn ifFalse: [self error: 'Inappropriate file descriptor']].	fileDescriptor _ anFdn! !!PipeReadStream methodsFor: 'modes'!binary	"Set the receiver's file to be buffered in binary mode.  Copy any already	buffered data to the new buffer, a ByteArray."	self isBinary		ifFalse:			[mode _ #binary.			collection _ (ByteArray new: collection size)				replaceFrom: 1 to: collection size				withString: collection startingAt: 1]! !!PipeReadStream methodsFor: 'modes'!text	"Set the receiver's file to be buffered in text mode.  Copy any already	buffered data to the new buffer, a String."	self isBinary		ifTrue:			[mode _ #text.			collection _ (String new: collection size)				replaceFrom: 1 to: collection size				withByteArray: collection startingAt: 1]! !!Delay methodsFor: 'private'!postSnapshot	"The snapshot process invalidates a delay's resumption 	time. If a delay is still waiting in this image reset it's 	resumption time to a time relative to this machine's clock,	ie. the usual time (before preSnapshot)."	| pendingDelay |	delayInProgress ifTrue: [resumptionTime == nil			ifTrue: [self error: 'uninitialized Delay']			ifFalse: 				["convert from milliseconds since Jan. 1 1901 to 				local millisecond clock"				pendingDelay _ resumptionTime - (Time totalSeconds * 1000).				pendingDelay _ pendingDelay max: 0.				resumptionTime _ Time millisecondClockValue + pendingDelay]		"if false then this delay must be ready and waiting (on 		AccessProtect) to resume"]!preSnapshot	"The snapshot process invalidates a delay's resumption 	time. If a delay is still waiting in this image reset it's 	resumption time to an absolute time, one not relative to this machine."	| pendingDelay |	delayInProgress		ifTrue:			[resumptionTime == nil				ifTrue: [self error: 'uninitialized Delay']				ifFalse: ["convert from local millisecond clock to milliseconds since Jan. 1 1901"						pendingDelay _ resumptionTime - Time millisecondClockValue.						resumptionTime _ Time totalSeconds * 1000 + pendingDelay]]		ifFalse: 			[self error: 'This Delay is not waiting']! !!Delay class methodsFor: 'snapshots'!postSnapshot	"The snapshot process invalidates a delay's resumption  	time. For every active or suspended delay in this image, 	reset it's resumption time.  Signal the delay management 	semaphore so normal processing can resume. (The 	semaphore was waited upon in preSnapshot)."	ActiveDelay ~~ nil		ifTrue: 			[ActiveDelay postSnapshot.			SuspendedDelays do: [:delay | delay postSnapshot].			ActiveDelay reactivate].	AccessProtect signal!preSnapshot	"The snapshot process invalidates a delay's resumption    	time. For every active or suspended delay in this image,   	reset it's resumption time.  Wait on the delay management 	  semaphore to prevent normal processing. (The   	semaphore will be signaled in postSnapshot)."	AccessProtect wait.	ActiveDelay ~~ nil ifTrue: [ActiveDelay preSnapshot].	SuspendedDelays do: [:delay | delay preSnapshot]! !!SystemDictionary methodsFor: 'private'!postSnapshot	"After a snapshot prepare to continue by fixing up delays and installing Smalltalk."	Delay postSnapshot.	self install!snapshotPrimitive: fileName 	"Write the current state of the object memory on a file .   	The resulting snapshot file, when resumed, completes this 	primitive by returning self.	Answer after writing the file nil for successful write  	and false for unsuccessful write. A write can be  	unsuccessful if there is not enough room on the disk or an 	 I/O error occurs during the write. If fileName is not a  	string of length greater than 0 or the file can not be  	created, then the primitive fails.   Essential.  See  Object 	documentation  	whatIsAPrimitive."	<primitive: 129>	Delay postSnapshot.	self install.	self primitiveFailed! !!SystemDictionary methodsFor: 'system backup-out'!quit	"Close open files then exit to the operating system.  All 	state changes in the object space since the last snapshot 	are lost."	Subtask terminateAll.	self releaseExternalViews.	self quitPrimitive!snapshot	"Write this Smalltalk image out on an external file called 'snapshot'."	self snapshotAs: 'snapshot' thenQuit: false!snapshotAs: imageFileName thenQuit: quitIfTrue 	"Write this Smalltalk image out on an external file.  Answer   	true if the snapshot was just created."	| logEntry snapResult |	Cursor execute show.	self at: #ImageName put: imageFileName.	self releaseExternalViews.	Transcript cr; show: 'Snapshot at: ' , Time dateAndTimeNow printString.	Delay preSnapshot.	Cursor wait show.	ScheduledControllers discardCachedDisplayForms.	snapResult _ self snapshotPrimitive: ImageName.	snapResult isNil		ifTrue: 			["After a successful snapshot"			logEntry _ '''----SNAPSHOT---- to ' , ImageName , ': ' , Time dateAndTimeNow printString , ''''.			self logChange: logEntry.			quitIfTrue				ifTrue: [self quit]				ifFalse: [self postSnapshot]].	snapResult == self		ifTrue: 			["Continue from a snapshot image we just loaded."			self postSnapshot.			Subtask markAndSignalAll; install.			Sensor cursorPoint: Display viewport center.			ScheduledControllers restore].	Cursor normal show.	^snapResult isNil! !!SystemTracer methodsFor: 'initialize-release'!initClampedClasses: classSet	"Clamp out classes.   Check for non-clamped classes whose superclass is clamped."	| x |	classSet isEmpty		ifTrue: [^self].	classSet do: 		[:class |		self clamp: class].	Smalltalk allBehaviorsDo: 		[:class | 		class superclass == nil &			((writeDict at: class) ~= #writeClamped:)		ifTrue: [class == Object 					ifFalse: [self error: class name , 'superclass is clamped!!!!!!!!']]].	SystemOrganization removeEmptyCategories.	Smalltalk newClassNames; noChanges.	Browser allInstancesDo: [:x | x updateCategories].	Smalltalk newSourceFile: 'Smalltalk80' without: classSet! !!SystemDictionary methodsFor: 'time-versions'!version	"Answer the version of this Smalltalk release." 	^Smalltalk versionName, ' version ', Smalltalk versionNumber, ', of September 12, 1986'!versionName	"Answer the version identification, e.g. Smalltalk-80"	^'Tektronix Smalltalk-80'!versionNumber	"Answer the version number of this release of Tektronix Smalltalk-80"	^'T2.1.3b'! !Object	subclass: #Subtask	instanceVariableNames: 'taskId status program args environment initBlock accessProtect termStatus priority waitSemaphore '	classVariableNames: 'BrokenPipeProcess BrokenPipeSemaphore ChildWaitSemaphore ScheduledSubtasks ScheduledSubtasksAccesssProtect ScheduledSubtasksAccessProtect SystemCall WaitProcess '	poolDictionaries: ''	category: 'OS-Interface'!!Subtask methodsFor: 'initialize-release'!release	"Remove the receiver from the list of scheduled subtasks."	ScheduledSubtasksAccessProtect critical: 				[ScheduledSubtasks remove: self ifAbsent: []]! !!Subtask methodsFor: 'controlling'!absoluteWait	"Bypassing the dead child signal management, a wait system call is made.	The list of scheduled subtask is updated accordingly  and the status of the 	termination is recorded for each child process until the receiver's subtask is 	found.  This method replaces the use of the waitOn message.  For use with 	non-interactive tasks that require the shutting down of the Smalltalk process 	for efficiency."	| id sysCall stat thisId s |	thisId _ self taskId.	id = -1.	[id = thisId]		whileFalse:		[sysCall _ SystemCall wait.		sysCall invoke			ifTrue: 				[id _ sysCall D0Out.				stat _ sysCall A0Out.				ScheduledSubtasksAccessProtect critical: 					[ScheduledSubtasks do: [:each | each taskId = id							ifTrue: 								[each criticalSection: [each terminatedWith: stat].								each signalWaitSemaphore]]]]			ifFalse: [self isTerminated ifTrue: [^self]]]! !!Subtask class methodsFor: 'class initialization'!initialize	"Create the accessing semaphore.  Using the critical 	protection protocol create a new list of scheduled 	subtasks. "	self terminateAll.	SystemCall _ TekSystemCall.	ScheduledSubtasksAccessProtect _ Semaphore forMutualExclusion.	ScheduledSubtasksAccessProtect critical: [ScheduledSubtasks _ OrderedCollection new]	"Subtask initialize"! !!Subtask class methodsFor: 'task management'!kill: aTask 	"Kill the spawned task and remove it from the task list."	aTask kill.	ScheduledSubtasksAccessProtect critical: [ScheduledSubtasks remove: aTask ifAbsent: []]!markAndSignalAll	"Mark the status and signal the wait semaphore of each previously 	scheduled subtask.  This method is used for restoring after a snapshot."	| tasks |	ScheduledSubtasksAccessProtect critical: [tasks _ ScheduledSubtasks shallowCopy].	tasks do: 		[:eachTask | 		eachTask signalWaitSemaphore.		eachTask criticalSection: [eachTask status: #nonexistent]]!terminate: aTask 	"Terminate aTask and remove it from the task list."	aTask terminate.	ScheduledSubtasksAccessProtect critical: [ScheduledSubtasks remove: aTask ifAbsent: []]!terminateAll	"Kill all the scheduled tasks."	| tasks |	ScheduledSubtasksAccessProtect critical: [tasks _ ScheduledSubtasks shallowCopy].	tasks do: 		[:eachTask | 		Subtask kill: eachTask]!waitUpdate	"If ChildWaitSemaphore has  	received a signal indicating a child task death, a wait system call is  	made.  The scheduled subtask is updated accordingly  and the status 	 of the termination is recorded."	| id sysCall stat |	sysCall _ SystemCall wait.	sysCall invoke		ifTrue: 			[id _ sysCall D0Out.			stat _ sysCall A0Out.			ScheduledSubtasksAccessProtect critical: 				[ScheduledSubtasks do: [:each | each taskId = id							ifTrue: 								[each criticalSection: [each terminatedWith: stat].								each signalWaitSemaphore]]]]! !!Subtask methodsFor: 'accessing'!enhancedPriority	"Set the priority of the subtask to the lowest possible value,	giving the highest possible priority."	priority _ 0!environment	"Answer the environment for this subtask in an array format."	^environment!environment: env 	"Store and return the OS readable version 	(OrderedCollection format) of the environment for this 	subtask.  See environments protocol in the metaclass."	(env isKindOf: Dictionary)		ifTrue: 			["Convert from Dictionary format to OrderedCollection format."			environment _ OrderedCollection new: 10.			env keys do: [:eachKey | environment add: eachKey asString , '=' , (env at: eachKey)]]		ifFalse: [(env isKindOf: OrderedCollection) | env isNil				ifTrue: ["Format okay"					environment _ env]				ifFalse: [self error: 'Incorrect format for subtask environment']].	^environment!initBlock	"Answer the block to be evaluated between vfork and	exec system calls by the child task."	^initBlock!initBlock: aBlock	"Assign aBlock to the instance variable initBlock."	^initBlock _ aBlock!priority	"Answer the absolute priority of the subtask."	^priority!priority: aPriority 	"Set the priority of the subtask.  Acceptable values range from 0 to 	25, zero being the highest and 25 being the lowest.  The default	priority of the parent task is 10."	aPriority < 0 | (aPriority > 25) 		ifTrue: [self error: 'Unacceptable priority value'].	priority _ aPriority!program	"Answer the name of the executable program."	^program!status	"Answer the status of the receiver.  Usually this instance 	variable is accessed with the protocol criticalProtect: ."	^status!status: stat 	"Record the status of the receiver.  Usually this instance 	variable is accessed with the protocol criticalProtect: ."	^status _ stat!taskId	"Answer an identifying unique integer assigned by the 	operating sytem."	^taskId!taskId: id	"Set my task id as assigned by the operating system."	^taskId _ id! !!Subtask methodsFor: 'testing'!abnormalTermination	"Answer the status of the termination if abnormal, otherwise nil."	^status = #terminatedWithCode | (status = #terminatedWithSignal)!isTerminated	"Answer a boolean indicating if the receiver has been terminated."	^status = #terminated | (status = #terminatedWithCode | (status = #terminatedWithSignal))! !!Subtask methodsFor: 'controlling'!interrupt: anInterrupt 	"Send an interrupt to my task.  AnInterrupt is an integer indicating 	which kind of interrupt is to be sent. The usual result of an interrupt is	task termination."	(anInterrupt isKindOf: SmallInteger)		ifFalse: [self error: 'Expected integer for interrupt'].	(SystemCall spint: self taskId an: anInterrupt) invoke 		ifTrue: ["check termintation code" 			self criticalSection: [self status: #terminationSignaled]]!signalWaitSemaphore	"Signal the reciever's semaphore to indicate	terminatation of the spawned task."	waitSemaphore signal!waitOn	"Wait for the receiver to terminate."	(self criticalSection: [self status = #nonexistent]) ifTrue: [^self].	(self criticalSection: [status = #waitedOn]) ifTrue: [^self error: 'Already waiting on this task'].	self criticalSection: [self status: #waitedOn].	waitSemaphore wait.	self release! !!Subtask class methodsFor: 'instance creation'!fork: commandName then: aBlock 	"Set the task object to contain all the necessary information 	 to exec the subtask.  There are no arguments and the	initialization block is empty. "	^self		fork: commandName		withArgs: (OrderedCollection new)		then: aBlock!fork: commandName withArgs: args 	"Set the task object to contain all the necessary information 	 to exec the subtask.  Args is an OrderedCollection of  	arguments to the executable program specified by  	commandName.  The initialization block is empty. "	^self		fork: commandName		withArgs: args		then: []!fork: commandName withArgs: args standardIn: in standardOut: out standardError: err 	"Set the task object to contain all the necessary information 	  to exec the subtask.  Args is an OrderedCollection of  	arguments to the executable program specified by  	commandName.  Three pipes are specified by the 	arguments in, out and err.  Unused ends of the pipes are 	closed. "	^self		fork: commandName		withArgs: args		withEnv: self currentEnvironment		then: 			[in mapReadTo: 0.			in closeRead; closeWrite.			out mapWriteTo: 1.			out closeRead; closeWrite.			err mapWriteTo: 2.			err closeRead; closeWrite]!fork: commandName withArgs: args standardIn: in standardOutAndError: out 	"Set the task object to contain all the necessary information 	 to exec the subtask.  Args is an OrderedCollection of  	arguments to the executable program specified by  	commandName.  Two pipes are specified by the 	arguments in and out.  Unused ends of the pipes are closed. "	^self		fork: commandName		withArgs: args		withEnv: self currentEnvironment		then: 			[in mapReadTo: 0.			in closeRead; closeWrite.			out mapWriteTo: 1.			out mapWriteTo: 2.			out closeRead; closeWrite]!fork: commandName withArgs: args then: aBlock 	"Set the task object to contain all the necessary information 	to exec the subtask.  Args is an OrderedCollection of 	arguments to the executable program specified by 	commandName.  ABlock is an initialization block executed 	by the spawned task upon startup."	| task argList |	argList _ args copy.	argList addFirst: commandName.	task _ self new initialize.	task		program: commandName		args: argList		initBlock: aBlock.	^task!fork: commandName withArgs: args withEnv: anEnvironment then: aBlock 	"Set the task object to contain all the necessary information 	 to exec the subtask plus specification of a list of 	environment variables.  Args is an OrderedCollection of 	arguments to the executable program specified by 	commandName.  ABlock is an initialization block executed 	by the spawned task upon startup."	| task argList |	argList _ args copy.	argList addFirst: commandName.	task _ self new initialize.	task		program: commandName		args: argList		initBlock: aBlock.	task environment: anEnvironment.	^task! !!Subtask class methodsFor: 'task management'!initializeWaitManagement	"If ChildWaitSemaphore has received a signal indicating a child task 	death, wait management is performed in the method wait."	| sysCall id stat |	ChildWaitSemaphore _ Semaphore new.	SystemCall setInterrupt: 26 to: ChildWaitSemaphore.  "reset semaphore"	WaitProcess notNil ifTrue: [WaitProcess terminate].	WaitProcess _ [[true]		whileTrue: 			[ChildWaitSemaphore wait.			self waitUpdate]] newProcess.	WaitProcess priority: Processor lowIOPriority.	WaitProcess resume	"Subtask initializeWaitManagement"! !!Subtask class methodsFor: 'broken pipes'!initializeBrokenPipeCatch	"Initialize a semaphore to catch the broken pipe signal.  Fork	a process to wait for an instance of the signal.  If the signal	is received, fork an error."	BrokenPipeSemaphore _ Semaphore new.	(SystemCall cpint: 6 to: BrokenPipeSemaphore) value.	BrokenPipeProcess notNil ifTrue: [BrokenPipeProcess terminate].	BrokenPipeProcess _ [[true]		whileTrue: 			[BrokenPipeSemaphore wait.			(SystemCall cpint: 6 to: BrokenPipeSemaphore) value.			[self error: 'Broken Pipe'] forkAt: Processor userInterruptPriority]]  newProcess.	BrokenPipeProcess priority: Processor lowIOPriority.	BrokenPipeProcess resume	"Subtask initializeBrokenPipeCatch"! !!Subtask class methodsFor: 'installation'!install	"This method is invoked as part of SystemDictionary install.  Assume no current connections into the OS task controlling and signaling mechanisms, for instance, when resuming after a snapshot.  Establish these connections by forking processes to catch the dead child signal and the broken pipe signal.  Create the subtask list accessing semaphore.  Using the critical protection protocol, create a new list of scheduled subtasks.  Lower the priority so interactive subtasks can run more effectively."	SystemCall _ TekSystemCall.	ScheduledSubtasksAccessProtect _ Semaphore forMutualExclusion.	self initializeWaitManagement.	self terminateAll.	ScheduledSubtasksAccessProtect critical: [ScheduledSubtasks _ OrderedCollection new].	Subtask initializeEnvironment.	PipeStream releaseExternalReferences.	self initializeBrokenPipeCatch.	(SystemCall setpr: 10) value. "lower priority"! !Object	subclass: #Subtask	instanceVariableNames: 'taskId status program args environment initBlock accessProtect termStatus priority waitSemaphore '	classVariableNames: 'BrokenPipeProcess BrokenPipeSemaphore ChildWaitSemaphore ScheduledSubtasks ScheduledSubtasksAccessProtect SystemCall WaitProcess '	poolDictionaries: ''	category: 'OS-Interface'!Subtask install!!SystemDictionary methodsFor: 'memory space'!saveSpace: aBoolean	| active |  	"Repaint windows the slow way (don't save the forms for the 	windows) if saveSpace is true.  Set to false for more functionality 	on machines with enough memory space to hold the extra forms.	On machines with limited memory, you may want to set the 	saveSpace Boolean to true."	(SaveSpace _ aBoolean)		ifTrue: [ScheduledControllers discardCachedDisplayForms]		ifFalse: [ScheduledControllers restore].	^SaveSpace	"Smalltalk saveSpace: true"! !!SystemDictionary methodsFor: 'system compression'!appendChangesToSourceFileWithout: setOfClasses 	"Append source stored in the changes file to the source file, omitting references to 	any classes in the set, setOfClasses.  This method is intended for use in the creation of	multiple images with slightly differing sources.		Smalltalk appendChangesToSourceFileWithout: (Array new).	Make sure versionName is updated and make a snapshot, renaming the image similarly."	| source class |	source _ SourceFiles at: 1.	source readWrite; setToEnd.	Smalltalk allBehaviorsDo:		[:class | 		(setOfClasses includes: class)			ifFalse: 				[class moveChangesToSources: source]].	(SourceFiles at: 1) readOnly	"Check for contents of changes file still referenced in the image:		| compiledMethod |	 Smalltalk		allBehaviorsDo: 			[:class | 			class selectors do: 				[:aSelector | 				compiledMethod _ class compiledMethodAt: aSelector.				Cursor read					showWhile: [						compiledMethod fileIndex > 1 ifTrue: [						Transcript cr; show: class name; crtab; show: aSelector]]]]	"! !!SystemDictionary methodsFor: 'memory space'!coreLeftLimit: newLimit 	"Set newLimit to be the threshold at which the user is to be notified	that the system is low in core space."	WordsLeftLimit _ newLimit.	self resetLowSpaceSignal.	^newLimit! !!SystemDictionary methodsFor: 'private'!lowSpaceNotificationLoop	[true]		whileTrue: 			[LowSpaceSemaphore wait.			(self oopsLeft < self oopsLeftLimit and: [self coreLeft < self coreLeftLimit])				ifTrue: [ScheduledControllers interruptName: 'Space is Low: coreLeft=' , self coreLeft printString , '; oopsLeft=' , self oopsLeft printString].			self oopsLeft < self oopsLeftLimit				ifTrue: [ScheduledControllers interruptName: 'Space is Low: Running out of oops']				ifFalse: [^self coreLeft < self coreLeftLimit ifTrue: [ScheduledControllers interruptName: 'Space is Low: Running out of memory']].			self resetSpaceLimits]! !!TekSystemCall class methodsFor: 'system dependent operations'!fcntl: fileDescriptor function: controlFunction 	"Change or interrogate the behavior of a file.  If controlFunction is		0   get the state (1 = noblock, 2 = block).		2   answer file descriptor of last file which sent INPUT READY signal.			-1 if none.		3   subsequent reads on this descriptor do NOT block.			Error ENOINPUT is returned if no data and signal INPUT READY			sent when data becomes available.		4   subsequent reads do block.	The state of the modifiable behaviors is returned in D0."	^(self new: 1)		operation: 69		with: controlFunction;		D0In: fileDescriptor  D0Out:true A0In:nil A0Out:false;		systemOperation! !!TekSystemCall class methodsFor: 'portable operations'!validFileDescriptor: fileDescriptor	"Answer true if an open file with the specified file descriptor exists."	| status |	fileDescriptor class == SmallInteger ifFalse: [^false].	status _ self statusClass new.	(self ofstat: fileDescriptor buffer: status)		valueIfError: [^false].	^true! createDirectory: aString	"Make aString, a full path name, be a new directory."	| newName directoryName task resultString | 	aString last = $/		ifTrue: [newName _ aString copyFrom: 1 to: aString size - 1]		ifFalse: [newName _ aString].	directoryName _ OrderedCollection with: newName.	resultString _ self execSystemUtility: '/bin/crdir' withArgs: (directoryName).	resultString size = 0 ifFalse: [^self error: (resultString copyUpTo: Character cr)]! !!TekSystemCall class methodsFor: 'class initialization'!initialize	"TekSystemCall initialize"	StringTerminator _ String with: (Character value: 0).	ErrorMessages _ #(		'I/O error'		'System fault'		'Data section overflow'		'Not a directory'		'Device full - no more available space'		'Too many open files'		'Bad file descriptor or mode'		'File not found'		'Missing directory in file name'		'Permission denied'		'File already exists'		'Bad argument to a system call'		'Seek error'		'Cross-device link not permitted'		'Block special file required'		'Device busy'		'File not mounted'		'Bad device argument'		'Too many arguments'		'File is a directory'		'File not binary'		'Binary file too big'		'Stack space overflow'		'No children alive'		'Too many active tasks'		'Bad system call'		'Interrupted system call'		'No task found'		'Not a tty type device'		'Write to broken pipe attempted'		'Record lock error'		'Text segment overflow'		'Illegal operation in vforked task'		'Mounted disk is dirty - diskrepair needed'		'Can''t open device - device is write-protected'		'No FPU exception information is present'		'No input available')! !TekSystemCall initialize!Dictionary variableSubclass: #TextStyleManager	instanceVariableNames: ''	classVariableNames: 'MenuDependents TextStyleMenu TextStyleNames '	poolDictionaries: ''	category: 'Graphics-Support'!!TextStyleManager methodsFor: 'user interface'!fromUser	"Present a menu of TextStyles. Answer with the selected textStyle else nil."	| i aStream |	TextStyleMenu isNil ifTrue: [		(TextStyleNames _ self keys asSortedCollection) size = 0 ifTrue: [			Transcript cr; show: 'no text styles'.			^nil].		aStream _ WriteStream on: (String new: 128).		TextStyleNames do: [:aString | aStream nextPutAll: aString; cr].		aStream skip: -1.		TextStyleMenu _ PopUpMenu			labels: aStream contents			lines: nil			alignment: 0].	"TextStyleMenu reset."	(i _ TextStyleMenu startUp) > 0		ifTrue: [^self at: (TextStyleNames at: i)]		ifFalse: [^nil]! !!TextStyleManager methodsFor: 'menu initialization'!initializeMenus	"Initialize all of the system menus. New classes caching menus or other dependencies upon TextStyle should be added to the list of menu dependents (see TextStyleManager class >> addMenuDependents:)."	| class flag selector |	MenuDependents do: [:triple |		class _ Smalltalk at: (triple at: 1).		flag _ triple at: 2.		selector _ triple at: 3.		flag = #class ifTrue: [			class perform: selector].		flag = #instance ifTrue: [			class allInstancesDo: [:anInstance |				anInstance perform: selector]]]! !!TextStyleManager class methodsFor: 'menu initialization'!addMenuDependents: aCollection	"Extend the list of menu dependents by the list contained within <aCollection>. Each element of <aCollection> should itself be a collection of three elements:	1. The symbol name of a Smalltalk class or other entry in the system dictionary.	2. The symbol #class or #instance.	3. The symbol name of a unary message selector.	When an instance of the receiver (typically the Smalltalk global <StyleManager>) receives the message <initializeMenus>, for each menu dependent the unary message is sent either to the class (#class) or to all instances of the class (#instance)."	aCollection do: [:triple |		MenuDependents add: triple deepCopy]!menuDependents	"Answer the list of menu dependents."	^MenuDependents! !!TextStyleManager class methodsFor: 'class initialization'!initialize	"TextStyleManager initialize"	"Install a new style manager if necessary.	Build a new menu dependents list."	(Smalltalk includesKey: #StyleManager) ifFalse: [		Smalltalk at: #StyleManager put: self new].	MenuDependents _ OrderedCollection new.	self addMenuDependents: #(		(Browser class flushMenus)		(Debugger class flushMenus)		(DictionaryInspector class flushMenus)		(FileList class flushMenus)		(FileModel class flushMenus)		(Inspector class flushMenus)		(SyntaxError class flushMenus)		(TextStyleManager class flushMenus)		(BitEditor class initialize)		(ChangeListController class initialize)		(FileList class initialize)		(FormEditor class initialize)		(NotifierController class initialize)		(ParagraphEditor class initialize)		(ProjectController class initialize)		(ScreenController class initialize)		(StandardSystemController class initialize)		(StringHolderController class initialize)		(BitEditor instance initializeYellowButtonMenu)		(ChangeController instance initializeYellowButtonMenu)		(ChangeListController instance initializeYellowButtonMenu)		(CRFillInTheBlankController instance initializeYellowButtonMenu)		(FillInTheBlankController instance initializeYellowButtonMenu)		(FormEditor instance initializeYellowButtonMenu)		(NotifierController instance initializeYellowButtonMenu)		(ParagraphEditor instance initializeYellowButtonMenu)		(ProjectController instance initializeYellowButtonMenu)		(ScreenController instance initializeYellowButtonMenu)		(StringHolderController instance initializeYellowButtonMenu)		(TextCollectorController instance initializeYellowButtonMenu)		(NotifierController instance initializeBlueButtonMenu)		(StandardSystemController instance initializeBlueButtonMenu)		)! !TextStyleManager initialize!!Integer methodsFor: 'bit manipulation'!fillBySignExtendFrom: aBitPosition 	"Assume I'm a positive integer which represents a	signed integer.  Answer a positive or negative integer	based on the value at aBitPosition.  Sign extend to	fill and produce a signed integer. "	(self bitAt: aBitPosition) = 1 ifTrue: [^self - (2 bitShift: aBitPosition)]! !!TekSystemCall class methodsFor: 'general inquiries'!pack: upperInteger intoRegisterWith: lowerInteger	"Answer a 32 bit value created by packing the upper	and lower Integers together.  Truncate the upper integer	to 15 bits and truncate the lower integer to 16 bits."	^(upperInteger bitShift: 16) + (lowerInteger bitAnd: 16rFFFF)! !!ExternalStream methodsFor: 'nonhomogeneous accessing'!nextSignedInteger	"Answer the next two bytes from the receiver as a signed Integer."	| returnValue |	self atEnd ifTrue: [^false].	returnValue _ self next asInteger.	self atEnd ifTrue: [^false].	returnValue _ returnValue * 256 + self next asInteger.	^returnValue fillBySignExtendFrom: 16! !!WordArray methodsFor: 'accessing'!signedIntegerAt: index 	"Answer a signed integer from the 16-bits in element 	index.  Assume truncated notation."	^(self at: index) fillBySignExtendFrom: 16!signedIntegerAt: index put: aNumber 	"Answer aNumber as an unsigned integer in two's complement 	notation, and store in the receiver in place of index 	element. "	^self at: index put:		(aNumber bitAnd: 16rFFFF)! !!FormEditor class methodsFor: 'private'!createFullScreenForm	"Create a StandardSystemView for a FormEditor that will fill the Display."	^self createOnForm: (Form new extent: Display viewport extent - (20@140))! !!Cursor methodsFor: 'displaying'!centerCursorInViewport	"Center the current cursor in the current viewport and link it to the mouse"	| upperLeftPoint centerPoint | 	Cursor cursorLink: true.	Sensor cursorPoint: Display viewport center.! !!NotifierView class methodsFor: 'instance creation'!openInterrupt: aString onProcess: interruptedProcess 	"Create and schedule an instance of me whose model is a Debugger on	interruptedProcess.  Sent to notify the user that the system is low in space or that	the user typed ctrl c.  The label of the scheduled view is aString."	| debugger topView cont savedView |	cont _ ScheduledControllers activeController.	(cont notNil and: [cont class ~= ScreenController]) 		ifTrue: 			[cont view repaintScrollBar.			(Smalltalk saveSpace == false and: [cont view isKindOf: StandardSystemView])				ifTrue: [cont view saveDisplayForm]].	debugger _ Debugger interruptProcess: interruptedProcess.	topView _ 		self openDebugger: debugger			contents: debugger interruptedContext shortStack			label: aString			displayAt: Display viewport center.	^topView! openContext: haltContext label: aString contents: contentsString	"Create and schedule an instance of me viewing a Debugger on haltContext.	The view will be labeled with aString, and shows a short sender stack."	| displayPoint cont |	ErrorRecursion		ifTrue: 			[ErrorRecursion _ false.			self primitiveError: aString].	ErrorRecursion _ true.	Processor resetPriorities.	cont _ ScheduledControllers activeController.	(cont notNil and: [cont class ~= ScreenController]) 		ifTrue: 			[cont view repaintScrollBar.			(Smalltalk saveSpace == false and: [cont view isKindOf: StandardSystemView])				ifTrue: [cont view saveDisplayForm]].	displayPoint _ 		ScheduledControllers activeController == nil			ifTrue: [Display viewport center]			ifFalse: [ScheduledControllers activeController view displayBox center].	self openDebugger: (Debugger context: haltContext)		contents: contentsString		label: aString		displayAt: displayPoint.	ErrorRecursion _ false.	Processor activeProcess suspend! !!Pen methodsFor: 'geometric designs'!mandala: npoints diameter: d 	"On a circle of diameter d, place n points.  Draw all possible connecting 	lines directly on the display.  The circle is centered in the current viewport."	" Pen new mandala: 30 diameter: 400 "	| points radius angle |	Display white.	self place: Display viewport center;		turn: direction degreesToRadians - direction.  "Work in radians for efficiency"	radius _ Float new coerce: d / 2.         "Compute these outside of the loop"	angle _ (360 / npoints) degreesToRadians.	points _ Array new: npoints.	1 to: npoints do:                      "Compute the locations of the points"		[:i | 		points at: i put: ((direction cos @ direction sin) * radius + location) rounded.		self turn: angle].                "Increment direction by angle"	self turn: direction radiansToDegrees - direction; down.  "Switch back to degrees"	npoints // 2		to: 1		by: -1		do: 			[:i | 			self color: npoints // 2 - i * 20 \\ 250.			1 to: npoints do: 				[:j | 				self place: (points at: j).				self goto: (points at: j + i - 1 \\ npoints + 1)]] ! !!DisplayScreen methodsFor: 'display functions'!setMouseBounds: boundingRectangle 	"Set the allowable mouse bounds to a boundingRectangle."	| sysCall xyUpper xyLower |	xyUpper _ TekSystemCall pack: boundingRectangle left intoRegisterWith: boundingRectangle top.	xyLower _ TekSystemCall pack: boundingRectangle right intoRegisterWith: boundingRectangle bottom.	sysCall _ TekSystemCall setMouseBounds: xyUpper lowerRight: xyLower.	sysCall value!setMouseBoundsUpper: upperPoint lowerCorner: lowerPoint	"Set the allowable mouse bounds to an upper left coordinate and 	a lower right coordinate within the display bitmap."	| sysCall xyUpper xyLower | 	xyUpper _ TekSystemCall pack: upperPoint x left intoRegisterWith: upperPoint y.	xyLower _ TekSystemCall pack: lowerPoint x intoRegisterWith: lowerPoint y.	sysCall _ TekSystemCall setMouseBounds: xyUpper lowerRight: xyLower.	sysCall value !disableScreenSaver	"Disables automatic screen blanking if inactive for 10 minutes.  Returns true if 	screen saving was previously disabled, false otherwise."	| sysCall | 	sysCall _ TekSystemCall timeOutOff.	sysCall value.	sysCall D0Out = 0 ifTrue: [^true].	^false!viewport	"Answer a rectangle indicating the location and extent of 	the viewport."	| buffer origin |	buffer _ self getDisplayReport.	origin _ self getViewportLocation.	^origin extent: (buffer at: 29) @ (buffer at: 30)!getDisplayReport	"Return a 36 word buffer containing status information for the display system."	| sysCall buffer | 	buffer _ WordArray new: 36.	sysCall _ TekSystemCall getDisplayState: buffer.	sysCall value.	^buffer!setDisplayStateFrom: aDisplayReport 	"Set the status of the display system based on a 36 word 	buffer, previously filled by a call to getDisplayReport.	Only state, appropriate for modification from the Smalltalk	environment, is reset."	| stateBits upperLeftMouse lowerRightMouse reportStream |	stateBits _ aDisplayReport at: 2.	(stateBits allMask: 2r1)		ifTrue: [Display makeDisplayVisible]		ifFalse: [Display makeDisplayBlank].	(stateBits allMask: 2r10)		ifTrue: [Display enableScreenSaver]		ifFalse: [Display disableScreenSaver].	(stateBits allMask: 2r100)		ifTrue: [Display setNormalVideo]		ifFalse: [Display setInverseVideo].	(stateBits allMask: 16r200 )		ifTrue: [Display enableCursorPanning]		ifFalse: [Display disableCursorPanning].	(stateBits allMask: 16r400)		ifTrue: [Display enableJoydiskPanning]		ifFalse: [Display disableJoydiskPanning].	"viewport upper left - words 3 and 4"	Display setViewportLocation: 			(aDisplayReport at: 3) @ (aDisplayReport at: 4).	"mouse bounds - words 5 and 6, 7 and 8"	upperLeftMouse	_ (aDisplayReport signedIntegerAt: 5) @ (aDisplayReport signedIntegerAt: 6).	lowerRightMouse _ (aDisplayReport signedIntegerAt: 7) @ (aDisplayReport signedIntegerAt: 8).	Display setMouseBounds: 		(upperLeftMouse corner: lowerRightMouse)!setViewportLocation: aPoint	"Set the upper left coordinate of the viewport to a point within the display bitmap."	| sysCall xyCoordinate | 	(Display boundingBox containsPoint: aPoint)		ifFalse: [self error: 'Viewport cannot be set outside display bounds'].	xyCoordinate _ TekSystemCall pack: aPoint x intoRegisterWith: aPoint y.	sysCall _ TekSystemCall setViewPort: xyCoordinate.	sysCall value.! !!TekSystemCall class methodsFor: 'interrupts'!defaultInterrupt	"Answer an OS representation of the default interrupt action."	^0!ignoreInterrupt	"Answer an OS representation of the ignore interrupt action."	^1! !!ScreenController methodsFor: 'menu messages'!forkOSshell	"Fork an operating system shell with history.	Type 'exit' to the shell to return to Smalltalk."	| task aDisplayReport oldSIGHUPValue oldSIGINTValue oldSIGTERMValue error oldSIGQUITValue |	FileStream releaseExternalReferences.	Display fill: (Display boundingBox) mask: Form white.	aDisplayReport _ Display getDisplayReport.	Display setViewportLocation: 0@0.	Display disableJoydiskPanning.	TekSystemCall write: 1 from: (String with: Character esc), '[1;1H' size: 6. "home the underscore cursor"	oldSIGHUPValue _ TekSystemCall setInterrupt: 1 to: TekSystemCall ignoreInterrupt.	oldSIGINTValue _TekSystemCall setInterrupt: 2 to: TekSystemCall ignoreInterrupt.	oldSIGQUITValue _  TekSystemCall setInterrupt: 3 to: TekSystemCall ignoreInterrupt.	oldSIGTERMValue _  TekSystemCall setInterrupt: 11 to: TekSystemCall ignoreInterrupt. 	TekSystemCall clearAlarm value.		task _ Subtask fork: '/bin/shell'  withArgs: (OrderedCollection with: '+i') then: [		TekSystemCall setInterrupt: 1 to: TekSystemCall defaultInterrupt.		TekSystemCall setInterrupt: 2 to: TekSystemCall defaultInterrupt.		TekSystemCall setInterrupt: 3 to: TekSystemCall defaultInterrupt.		TekSystemCall setInterrupt: 11 to: TekSystemCall defaultInterrupt.		TekSystemCall clearAlarm value.		TekSystemCall cursorOff value.		TekSystemCall eventsDisable value.		TekSystemCall terminalOn value].	error _ task start.	error isNil 		ifFalse: [task absoluteWait.			task release].	TekSystemCall setInterrupt: 1 to: oldSIGHUPValue.	TekSystemCall setInterrupt: 2 to: oldSIGINTValue.	TekSystemCall setInterrupt: 3 to: oldSIGQUITValue.	TekSystemCall setInterrupt: 11 to: oldSIGTERMValue.	Subtask initializeBrokenPipeCatch.	Subtask initializeWaitManagement.	TekSystemCall terminalOff value.	TekSystemCall cursorOn value.	Cursor cursorLink: true.	TekSystemCall eventsEnable value.	TekSystemCall eventSignalOn value.	(TekSystemCall setKeyboardCode: 0) value.	Delay reissueTimingSignal.	Sensor resetCapsLockState. 	Display setDisplayStateFrom: aDisplayReport. 	Display gray.	Cursor currentCursor centerCursorInViewport.	ScheduledControllers restore.	error isNil ifTrue: [^self error: 'Cannot fork shell'].! !!TextStyle methodsFor: 'accessing'!alignment: anInteger 	"Set the current setting of the alignment to be anInteger--	0=left flush, 1=right flush, 2=centered, 3=justified."	alignment _ anInteger \\ (Justified + 1)! !!StringHolderView methodsFor: 'displaying'!displayView: difference 	"Reposition text after a move operation."	displayContents moveBy: difference with: self insetDisplayBox! !!TextView methodsFor: 'updating'!updateRequest	| cancel |	self controller textHasChanged ifFalse: [^true].	self topView isCollapsed		ifFalse:			[Display reverse: insetDisplayBox mask: Form gray.	Display reverse: (insetDisplayBox insetBy: 4) mask: Form gray].	cancel _ self confirm: 'The text showing has been altered.Do you wish to discard those changes?'.	self topView isCollapsed		ifFalse:			[Display reverse: insetDisplayBox mask: Form gray.	Display reverse: (insetDisplayBox insetBy: 4) mask: Form gray].	^ cancel! !!InputState methodsFor: 'private'!primInputWord	"Return the next word from the input buffer and remove the word from the 	buffer. This message should be sent just after the input semaphore 	finished a wait (was sent a signal by an I/O device). Fail if the input 	buffer is empty. Essential. See Object documentation whatIsAPrimitive."	<primitive: 95>	^self primitiveFailed! !!IdentityDictionary methodsFor: 'accessing'!keys	"Answer a set containing the receiver's keys."	| aSet key |	aSet _ IdentitySet new: self size.	self keysDo: [:key | aSet add: key].	^aSet! !!FileDirectory methodsFor: 'accessing'!completePathname	"Answer the complete path name of the receiver.   A trailing '/' is considered	 part of a directory name even if not explicity stored." 	name  = '.'		ifTrue: [^SystemCall currentDirectory, '/']		ifFalse: [^self fullName]! !!OnlyWhenSelectedCodeController methodsFor: 'control defaults'!isControlWanted	self viewHasCursor ifFalse: [^false].	view isSelected		ifFalse: 			[sensor yellowButtonPressed ifTrue: [view flash].			self deselect. 			^false].	^true! !!ListView methodsFor: 'deEmphasizing'!deEmphasizeView	"Deemphasize the selections in the view by bolding the text and then 	adding the gray."	| aRectangle newForm |	self deselect.	selection ~= 0		ifTrue: 			[aRectangle _ (self selectionBox intersect: self clippingBox) insetOriginBy: 0 @ -1 cornerBy: 0 @ 0.			newForm _ Form fromDisplay: (aRectangle insetOriginBy: 1 @ 0 cornerBy: 0 @ 0).			newForm				displayOn: Display				at: aRectangle topLeft				clippingBox: aRectangle				rule: Form under				mask: Form black.			Display				fill: aRectangle				rule: Form under				mask: Form lightGray]! !!ListView methodsFor: 'deEmphasizing'!deEmphasizeView: form andClip: clipBox 	" Deemphasize the window only in the given clipping box"	| aRectangle newForm |	self deselectAndClip: clipBox.	selection ~= 0		ifTrue: 			[aRectangle _ (self selectionBox intersect: clipBox)						insetOriginBy: 0 @ -1 cornerBy: 0 @ 0.			aRectangle _ aRectangle intersect: clipBox.			newForm _ Form fromDisplay: (aRectangle insetOriginBy: 1 @ 0 cornerBy: 0 @ 0).			newForm				displayOn: Display				at: aRectangle topLeft				clippingBox: aRectangle				rule: Form under				mask: Form black.			Display				fill: aRectangle				rule: Form under				mask: Form lightGray]! !!SwitchView methodsFor: 'deEmphasizing'!deEmphasizeView: form andClip: clipBox	| newForm |	complemented		ifTrue: [self highlightAndClip: clipBox.				newForm _ Form fromDisplay: (self insetDisplayBox insetOriginBy: (1@0) cornerBy: (0@0)).				newForm					displayOn: Display					at: self insetDisplayBox topLeft					clippingBox: (self insetDisplayBox intersect: clipBox)					rule: Form under 					mask: Form black.				Display fill: (self insetDisplayBox intersect: clipBox) rule: Form under mask: Form lightGray]! !!StandardSystemView methodsFor: 'saved window form'!validDisplayForm	"The window form flag is set to #saved if ok to display fast way and,	#updated or #unused (if the form field is nil) if necessary to display slow way. 	Return true or false indicating the validity of displaying the fast way. "	^ windowForm notNil and: [windowFormFlag == #saved]! !ListView removeSelector: #emphasizeView!!FileStream methodsFor: 'converting'!asFileDirectory	^FileDirectory directoryNamed: (self fullName)! !!Object methodsFor: 'private'!exitToDebugger	"Enter the machine language debugger, if one exists.  Essential.  See Object 	documentation whatIsAPrimitive. "	<primitive: 114>	self primitiveFailed! !!SystemDictionary methodsFor: 'system backup-out'!snapshotAs: imageFileName onReloadDo: aBlock	"Write the OT and Data of this Smalltalk image out on an external file. "	self snapshotAs: imageFileName thenQuit: true.	^ aBlock value! !!SystemOrganizer methodsFor: 'fileIn-Out'!fileOutCategory: category 	| aFileStream |	aFileStream _ Disk file: (category , '.st') asFileName.	aFileStream timeStamp.	self fileOutCategory: category on: aFileStream. 	aFileStream close! !!Time class methodsFor: 'general inquiries'!timeWords	"Answer with the seconds (in GMT) since Jan 1 1901: as a four element 	ByteArray.  The high-order 8-bits of the answer are stored in the byte 	indexed by 1 and the low-order 8-bits in the byte indexed 4.  Note: this	order is not consistent with the primitives or the other time messages.	Obsolete."	| seconds bytes |	seconds _ ByteArray new: 4.	self secondClockInto: seconds.	bytes _ ByteArray new: 4.	"Reverse the bytes"	1 to: 4 do: [:i | bytes at: i put: (seconds at: 5 - i)].	^bytes! !!Explainer methodsFor: 'explaining'!explainCtxt: symbol 	"Is symbol a context variable?"	| reply classes text |	symbol = #nil ifTrue: [reply _ '"is a constant.  It is the only instance of class UndefinedObject.  nil is the initial value of all variables."'].	symbol = #true ifTrue: [reply _ '"is a constant.  It is the only instance of class True and is the receiver of many control messages."'].	symbol = #false ifTrue: [reply _ '"is a constant.  It is the only instance of class False and is the receiver of many control messages."'].	class == nil ifTrue: [^nil].	  "no message selected"	symbol = #self		ifTrue: 			[classes _ class withAllSubclasses.			classes size > 12				ifTrue: [text _ class printString , ' or a subclass']				ifFalse: 					[classes _ classes printString.					text _ 'one of these classes' , (classes copyFrom: 4 to: classes size)].			reply _ '"is the receiver of this message; an instance of ' , text , '"'].	symbol = #super ifTrue: [reply _ '"is just like self.  Messages to super are looked up in the superclass (' , class superclass printString , ')"'].	symbol = #thisContext ifTrue: [reply _ '"is a context variable.  Its value is always the MethodContext which is executing this method."'].	^reply! !!FillInTheBlankController methodsFor: 'scrolling'!moveMarker: ignored! !
MouseMenuController subclass: #ScrollController
	instanceVariableNames: 'scrollBar marker savedArea '
	classVariableNames: 'MillisecondsOfScrollDelay SmallestMarker '
	poolDictionaries: ''
	category: 'Interface-Support'!

ScrollController comment:
'I represent control for scrolling using a scrollBar.  I am a MouseMenuController that creates a scrollBar, rather than menus.  My subclasses add the button menus.  I keep control as long as the cursor is inside the view or the scrollBar area.

A scrollBar is a rectangular area representing the length of the information being viewed.  It contains an inner rectangle whose top y-coordinate represents the relative position of the information visible on the screen with respect to all of the information, and whose size represents the relative amount of that information visible on the screen.  The user controls which part of the information is visible by pressing the red button.  If the cursor is to the right of the inner rectangle, the window onto the visible information moves upward, if the cursor is to the left, the window moves downward, and if the cursor is inside, the inner rectangle is grabbed and moved to a desired position.  

Instance Variables:
	scrollBar	<Quadrangle> inside white, the outer rectangle
	marker		<Quadrangle> inside gray, the inner rectangle
	savedArea	<Form> the area the scrollBar overlaps, restored whenever
				the scrollBar is hidden
Class Variables:
	SmallestMarker <Rectangle> the smallest allowable size for marker.
	MillisecondsOfScrollDelay	<Integer>	number of milliseconds to delay scrolling.'
!



!ScrollController class methodsFor: 'class initialization'!

initialize
	"ScrollController initialize."
	"Set up the smallest rectangle allowable for scroll bar markers and the delay to slow down scrolling."

	SmallestMarker _ Rectangle origin: 0@0 corner: 10@3.
	MillisecondsOfScrollDelay _ 200! !
ScrollController initialize!

!ScrollController methodsFor: 'private'!scrollDelayLength
	"Answer the length of the delay to slow down continuous relative scrolling."

	^MillisecondsOfScrollDelay! !!ScrollController methodsFor: 'basic control sequence'!

controlInitialize
	super controlInitialize.
	scrollBar region: (0 @ 0 extent: 32 @ (view displayBox height + 2)).
	marker region: (self computeMarkerRegion merge: SmallestMarker).
	scrollBar _ scrollBar align: scrollBar topRight with: view displayBox topLeft - (0 @ 1).
	marker _ marker align: marker topCenter with: scrollBar inside topCenter.
	savedArea _ Form fromDisplay: scrollBar.
	scrollBar displayOn: Display.
	self moveMarker! !

!ScrollController methodsFor: 'private'!

scrollDown
	"Scroll the text down a relative amount.  Don't go faster than the user's reaction time."
	| delay | 
	self changeCursor: Cursor down.
	delay _ Delay forMilliseconds: self scrollDelayLength.
	self canScrollDown ifTrue: [
			[sensor anyButtonPressed]
				whileTrue: [self canScrollDown
						ifTrue: 
							[self scrollViewDown.
							self moveMarker].
				delay wait]]!

scrollUp
	"Scroll the text up a relative amount.  Don't go faster than the user's reaction time."
	| delay | 
	self changeCursor: Cursor up.
	delay _ Delay forMilliseconds: self scrollDelayLength.
	self canScrollUp ifTrue: [[sensor anyButtonPressed]
			whileTrue: [self canScrollUp
					ifTrue: 
						[self scrollViewUp.
						self moveMarker].
					delay wait]]! !


!ListController methodsFor: 'scrolling'!

viewDelta
	| viewList |
	viewList _ view list.
	^(viewList clippingRectangle top -
			viewList compositionRectangle top -
			((marker top - scrollBar inside top) asFloat /
				scrollBar inside height asFloat *
				viewList compositionRectangle height asFloat))
		roundTo: viewList lineGrid +1! !


!ParagraphEditor methodsFor: 'marker adjustment'!

updateMarker
	"A variation of moveMarker--only redisplay the marker in the scrollbar
	if an actual change has occurred in the positioning of the paragraph."

	| newMarkerRegion |
	newMarkerRegion _ (self computeMarkerRegion merge: SmallestMarker).
	newMarkerRegion extent ~= marker region extent
		ifTrue: 
			[self markerRegion: newMarkerRegion.
			self moveMarker]! !

!StrikeFont methodsFor: 'initialize-release'!initializeFrom: aFontFile 	"I read a font from aFontFile.  This must be in Tektronix 	format.  I return aStrikefont unless I discover something 	wrong, in which case I return nil."	| nameField face bitmapPos height mapPos bitmap xTablePos |	aFontFile text.	(aFontFile next: 4) = 'Font'		"check for magic"		ifFalse: 			[self error: aFontFile fullName , ' is not a font file'.			^nil].	nameField _ (aFontFile next: 32) copyUpTo: 0 asCharacter.		"name is 32 bytes"	face _ (aFontFile next: 32) copyUpTo: 0 asCharacter.		"face is 32 bytes"	aFontFile binary.	aFontFile nextWord = 1		"2 bytes designating type"		ifFalse: 			[self error: aFontFile fullName , ' is not of the proper font type'.			^nil].	type _ aFontFile nextWord.		"2 bytes designating compatibility"	(type < 1 or: [type > 3])		ifTrue: [self notify: aFontFile fullName , ' type (' , type printString , ') is not compatible with Smalltalk.Proceed to continue loading this font.'].	name _ nameField , aFontFile nextWord printString , (FaceNames at: face).		"point size"	aFontFile skip: 3 * 2 + 4.		" skip resolution, mul, div, and pointer to comment"	mapPos _ aFontFile nextNumber: 4.	aFontFile skip: 4.	xTablePos _ aFontFile nextNumber: 4.	aFontFile skip: 4 * 4.	"skip spares"	bitmapPos _ aFontFile nextNumber: 4.	strikeLength _ aFontFile nextWord.	"width"	raster _ strikeLength + 15 // 16.	height _ aFontFile nextWord.	aFontFile skip: 2.		"skip offsetw"	ascent _ aFontFile nextWord.		"offseth"	descent _ height - ascent.	aFontFile position: mapPos.	aFontFile skip: 2.		"skip white"	maxWidth _ aFontFile nextWord.	aFontFile skip: 2 * 3.	minAscii _ aFontFile nextWord.		"first"	maxAscii _ aFontFile nextWord.		"last"	xTable _ Array new: maxAscii - minAscii + 2.	1 to: xTable size do: [:i | xTable at: i put: aFontFile nextWord].	"Smalltalk's use of maxAscii assumes that the last value in the 	xTable is non-printing."	maxAscii _ 126.	"Build the glyphs from the bitmap area. "	aFontFile position: bitmapPos.	bitmap _ WordArray new: raster * height.	1 to: raster * height do: [:i | bitmap at: i put: aFontFile nextWord].	glyphs _ Form				extent: strikeLength @ height				fromArray: bitmap				offset: 0 @ 0.	"If this is a Tektronix font,  switch the  	caret and underscore with the upArrow and rightArrow in  	both the xTable and the bitmap."	(type = 2 or: [type = 1]) ifTrue: [		glyphs _ self glyphsSwitchCharacters.		xTable _ self xTableSwitchCharacters].	"Fill in various information not provided in the file."	stopConditions _ DefaultStopConditions copy.	(type = 2)			ifTrue: [stopConditions at:1 put:#characterNotInFont.					stopConditions at:11 put:#characterNotInFont. 					stopConditions at:13 put:#characterNotInFont. 					stopConditions at:14 put:#characterNotInFont]			ifFalse: [(type = 1)|(type =3)				ifTrue: [1 to: 32 do:								[: i | stopConditions at: i put: #characterNotInFont].						stopConditions							at: 10 put: #tab;							at: 11 put: #cr;							at: 14 put: #cr]].	emphasis _ 0! !Smalltalk install !